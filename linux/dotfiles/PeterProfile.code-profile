{"name":"PeterProfile","icon":"rocket","settings":"{\"settings\":\"{\\n    \\\"update.mode\\\": \\\"none\\\",\\n    \\\"workbench.startupEditor\\\": \\\"none\\\",\\n    \\\"remote.SSH.remotePlatform\\\": {\\n        \\\"dgx4850\\\": \\\"linux\\\",\\n        \\\"eos\\\": \\\"linux\\\",\\n        \\\"oci3\\\": \\\"linux\\\",\\n        \\\"dgx3841\\\": \\\"linux\\\",\\n        \\\"dgx104\\\": \\\"linux\\\",\\n        \\\"precision\\\": \\\"linux\\\",\\n        \\\"oci1\\\": \\\"linux\\\",\\n        \\\"k8ord\\\": \\\"linux\\\",\\n        \\\"eos2\\\": \\\"linux\\\",\\n        \\\"oci2\\\": \\\"linux\\\",\\n        \\\"eos1\\\": \\\"linux\\\"\\n    },\\n    \\\"workbench.editorAssociations\\\": {\\n        \\\"*.ipynb\\\": \\\"jupyter-notebook\\\"\\n    },\\n    \\\"terminal.integrated.commandsToSkipShell\\\": [\\n        \\\"language-julia.interrupt\\\"\\n    ],\\n    \\\"julia.enableTelemetry\\\": false,\\n    \\\"notebook.cellToolbarLocation\\\": {\\n        \\\"default\\\": \\\"right\\\",\\n        \\\"jupyter-notebook\\\": \\\"left\\\"\\n    },\\n    \\\"julia.symbolCacheDownload\\\": true,\\n    \\\"git.enableSmartCommit\\\": true,\\n    \\\"explorer.confirmDragAndDrop\\\": false,\\n    \\\"julia.NumThreads\\\": 8,\\n    \\\"notebook.output.textLineLimit\\\": 150,\\n    \\\"github.copilot.editor.enableAutoCompletions\\\": true,\\n    \\\"files.autoSave\\\": \\\"afterDelay\\\",\\n    \\\"remote.SSH.defaultForwardedPorts\\\": [],\\n    \\\"remote.SSH.defaultExtensions\\\": [\\n        \\\"ms-python.python\\\",\\n        \\\"ms-toolsai.jupyter\\\",\\n        \\\"charliermarsh.ruff\\\"\\n    ],\\n    \\\"explorer.confirmPasteNative\\\": false,\\n    \\\"explorer.compactFolders\\\": false,\\n    \\\"scm.compactFolders\\\": false,\\n    \\\"workbench.tree.expandMode\\\": \\\"doubleClick\\\",\\n    \\\"editor.showFoldingControls\\\": \\\"always\\\",\\n    \\\"notebook.showFoldingControls\\\": \\\"always\\\",\\n    \\\"git.confirmSync\\\": false,\\n    \\\"workbench.list.openMode\\\": \\\"doubleClick\\\",\\n    \\\"explorer.incrementalNaming\\\": \\\"smart\\\",\\n    \\\"git.autofetch\\\": \\\"all\\\",\\n    \\\"terminal.integrated.defaultProfile.windows\\\": \\\"Command Prompt\\\",\\n    \\\"terminal.integrated.cursorBlinking\\\": true,\\n    \\\"terminal.integrated.tabs.hideCondition\\\": \\\"never\\\",\\n    \\\"editor.scrollbar.horizontal\\\": \\\"visible\\\",\\n    \\\"editor.scrollbar.vertical\\\": \\\"visible\\\",\\n    \\\"workbench.colorCustomizations\\\": {\\n        \\\"scrollbarSlider.background\\\": \\\"#dddddd\\\",\\n        \\\"scrollbarSlider.hoverBackground\\\": \\\"#ffffff\\\",\\n    },\\n    \\\"editor.scrollbar.verticalScrollbarSize\\\": 10,\\n    \\\"editor.scrollbar.horizontalScrollbarSize\\\": 10,\\n    \\\"latex-workshop.formatting.latex\\\": \\\"latexindent\\\",\\n    \\\"latex-workshop.latex.outDir\\\": \\\"./out/\\\",\\n    \\\"latex-workshop.latex.recipes\\\": [\\n    \\n    \\n        {\\n            \\\"name\\\": \\\"xelatexmk -> ghostscript\\\",\\n            \\\"tools\\\": [\\n                \\\"xelatexmk\\\",\\n                \\\"ghostscript\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk\\\",\\n            \\\"tools\\\": [\\n                \\\"latexmk\\\",\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (latexmkrc)\\\",\\n            \\\"tools\\\": [\\n                \\\"latexmk_rconly\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (lualatex)\\\",\\n            \\\"tools\\\": [\\n                \\\"lualatexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (xelatex)\\\",\\n            \\\"tools\\\": [\\n                \\\"xelatexmk\\\",\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"pdflatex -> bibtex -> pdflatex * 2\\\",\\n            \\\"tools\\\": [\\n                \\\"pdflatex\\\",\\n                \\\"bibtex\\\",\\n                \\\"pdflatex\\\",\\n                \\\"pdflatex\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Rnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"rnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Jnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"jnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Pnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"pnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"tectonic\\\",\\n            \\\"tools\\\": [\\n                \\\"tectonic\\\"\\n            ]\\n        }\\n    ],\\n    \\\"terminal.integrated.profiles.windows\\\": {\\n        \\\"PowerShell\\\": {\\n            \\\"source\\\": \\\"PowerShell\\\",\\n            \\\"icon\\\": \\\"terminal-powershell\\\"\\n        },\\n        \\\"Command Prompt\\\": {\\n            \\\"path\\\": [\\n                \\\"${env:windir}\\\\\\\\Sysnative\\\\\\\\cmd.exe\\\",\\n                \\\"${env:windir}\\\\\\\\System32\\\\\\\\cmd.exe\\\"\\n            ],\\n            \\\"args\\\": [],\\n            \\\"icon\\\": \\\"terminal-cmd\\\"\\n        },\\n        \\\"Git Bash\\\": {\\n            \\\"source\\\": \\\"Git Bash\\\"\\n        },\\n        \\\"Ubuntu (WSL)\\\": {\\n            \\\"path\\\": \\\"C:\\\\\\\\Windows\\\\\\\\System32\\\\\\\\wsl.exe\\\",\\n            \\\"args\\\": [\\n                \\\"-d\\\",\\n                \\\"Ubuntu\\\"\\n            ]\\n        }\\n    },\\n    \\\"latex-workshop.latex.tools\\\": [\\n        {\\n            \\\"name\\\": \\\"ghostscript\\\",\\n            \\\"command\\\": \\\"ghostscript\\\", // Linux\\n            // \\\"command\\\": \\\"gswin64c\\\", // Windows\\n            \\\"args\\\": [\\n                \\\"-sDEVICE=pdfwrite\\\",\\n                \\\"-dCompatibilityLevel=1.5\\\",\\n                \\\"-dPDFSETTINGS=/printer\\\",\\n                \\\"-o\\\",\\n                \\\"%OUTDIR%/%DOCFILE%_compressed.pdf\\\",\\n                \\\"%OUTDIR%/%DOCFILE%.pdf\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk\\\",\\n            \\\"command\\\": \\\"latexmk\\\",\\n            \\\"args\\\": [\\n                \\\"--shell-escape\\\",\\n                \\\"-synctex=1\\\",\\n                \\\"-interaction=nonstopmode\\\",\\n                \\\"-file-line-error\\\",\\n                \\\"-pdf\\\",\\n                \\\"-outdir=%OUTDIR%\\\",\\n                \\\"%DOC%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"lualatexmk\\\",\\n            \\\"command\\\": \\\"latexmk\\\",\\n            \\\"args\\\": [\\n                \\\"--shell-escape\\\",\\n                \\\"-synctex=1\\\",\\n                \\\"-interaction=nonstopmode\\\",\\n                \\\"-file-line-error\\\",\\n                \\\"-lualatex\\\",\\n                \\\"-outdir=%OUTDIR%\\\",\\n                \\\"%DOC%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"xelatexmk\\\",\\n            \\\"command\\\": \\\"latexmk\\\",\\n            \\\"args\\\": [\\n                \\\"--shell-escape\\\",\\n                \\\"-synctex=1\\\",\\n                \\\"-interaction=nonstopmode\\\",\\n                \\\"-file-line-error\\\",\\n                \\\"-xelatex\\\",\\n                \\\"-outdir=%OUTDIR%\\\",\\n                \\\"%DOC%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk_rconly\\\",\\n            \\\"command\\\": \\\"latexmk\\\",\\n            \\\"args\\\": [\\n                \\\"%DOC%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"pdflatex\\\",\\n            \\\"command\\\": \\\"pdflatex\\\",\\n            \\\"args\\\": [\\n                \\\"-synctex=1\\\",\\n                \\\"-interaction=nonstopmode\\\",\\n                \\\"-file-line-error\\\",\\n                \\\"%DOC%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"bibtex\\\",\\n            \\\"command\\\": \\\"bibtex\\\",\\n            \\\"args\\\": [\\n                \\\"%DOCFILE%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"rnw2tex\\\",\\n            \\\"command\\\": \\\"Rscript\\\",\\n            \\\"args\\\": [\\n                \\\"-e\\\",\\n                \\\"knitr::opts_knit$set(concordance = TRUE); knitr::knit('%DOCFILE_EXT%')\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"jnw2tex\\\",\\n            \\\"command\\\": \\\"julia\\\",\\n            \\\"args\\\": [\\n                \\\"-e\\\",\\n                \\\"using Weave; weave(\\\\\\\"%DOC_EXT%\\\\\\\", doctype=\\\\\\\"tex\\\\\\\")\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"jnw2texminted\\\",\\n            \\\"command\\\": \\\"julia\\\",\\n            \\\"args\\\": [\\n                \\\"-e\\\",\\n                \\\"using Weave; weave(\\\\\\\"%DOC_EXT%\\\\\\\", doctype=\\\\\\\"texminted\\\\\\\")\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"pnw2tex\\\",\\n            \\\"command\\\": \\\"pweave\\\",\\n            \\\"args\\\": [\\n                \\\"-f\\\",\\n                \\\"tex\\\",\\n                \\\"%DOC_EXT%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"pnw2texminted\\\",\\n            \\\"command\\\": \\\"pweave\\\",\\n            \\\"args\\\": [\\n                \\\"-f\\\",\\n                \\\"texminted\\\",\\n                \\\"%DOC_EXT%\\\"\\n            ],\\n            \\\"env\\\": {}\\n        },\\n        {\\n            \\\"name\\\": \\\"tectonic\\\",\\n            \\\"command\\\": \\\"tectonic\\\",\\n            \\\"args\\\": [\\n                \\\"--synctex\\\",\\n                \\\"--keep-logs\\\",\\n                \\\"--print\\\",\\n                \\\"%DOC%.tex\\\"\\n            ],\\n            \\\"env\\\": {}\\n        }\\n    ],\\n    \\\"latex-workshop.latex.autoBuild.run\\\": \\\"onSave\\\",\\n    \\\"cursor.cpp.disabledLanguages\\\": [\\n        \\\"plaintext\\\"\\n    ],\\n    \\\"explorer.confirmDelete\\\": false,\\n    \\\"jupyter.interactiveWindow.textEditor.executeSelection\\\": true,\\n    \\\"window.newWindowProfile\\\": \\\"Default\\\",\\n    \\\"jupyter.askForKernelRestart\\\": false,\\n    \\\"editor.tabCompletion\\\": \\\"on\\\",\\n    \\\"scm.diffDecorationsIgnoreTrimWhitespace\\\": \\\"inherit\\\",\\n    \\\"diffEditor.codeLens\\\": true,\\n    \\\"diffEditor.experimental.useTrueInlineView\\\": true,\\n    \\\"[python]\\\": {\\n        \\\"diffEditor.ignoreTrimWhitespace\\\": false,\\n        \\\"editor.defaultFormatter\\\": \\\"charliermarsh.ruff\\\",\\n    },\\n    \\\"diffEditor.renderSideBySide\\\": true,\\n    \\\"editor.minimap.enabled\\\": true,\\n    \\\"editor.minimap.autohide\\\": true,\\n    \\\"editor.acceptSuggestionOnEnter\\\": \\\"smart\\\",\\n    \\\"explorer.sortOrder\\\": \\\"type\\\",\\n    \\\"editor.defaultFormatter\\\": \\\"charliermarsh.ruff\\\",\\n    \\\"notebook.defaultFormatter\\\": \\\"charliermarsh.ruff\\\",\\n    \\\"remote.autoForwardPortsSource\\\": \\\"hybrid\\\",\\n    \\\"window.openFoldersInNewWindow\\\": \\\"on\\\",\\n    \\\"git.openDiffOnClick\\\": false,\\n    \\\"gitlens.views.remotes.files.layout\\\": \\\"tree\\\",\\n    \\\"window.titleBarStyle\\\": \\\"custom\\\",\\n    \\\"window.customMenuBarAltFocus\\\": false,\\n   