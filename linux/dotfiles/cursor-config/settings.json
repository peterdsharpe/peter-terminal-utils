{
    "update.mode": "none",
    "workbench.startupEditor": "none",
    "remote.SSH.remotePlatform": {
        "dgx4850": "linux",
        "eos": "linux",
        "oci3": "linux",
        "dgx3841": "linux",
        "dgx104": "linux",
        "precision": "linux",
        "oci1": "linux",
        "k8ord": "linux",
        "eos2": "linux",
        "oci2": "linux",
        "eos1": "linux"
    },
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook"
    },
    "terminal.integrated.commandsToSkipShell": [
        "language-julia.interrupt"
    ],
    "julia.enableTelemetry": false,
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "julia.symbolCacheDownload": true,
    "git.enableSmartCommit": true,
    "explorer.confirmDragAndDrop": false,
    "julia.NumThreads": 8,
    "notebook.output.textLineLimit": 150,
    "github.copilot.editor.enableAutoCompletions": true,
    "files.autoSave": "afterDelay",
    "remote.SSH.defaultForwardedPorts": [],
    "remote.SSH.defaultExtensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "charliermarsh.ruff"
    ],
    "explorer.confirmPasteNative": false,
    "explorer.compactFolders": false,
    "scm.compactFolders": false,
    "workbench.tree.expandMode": "doubleClick",
    "editor.showFoldingControls": "always",
    "notebook.showFoldingControls": "always",
    "git.confirmSync": false,
    "workbench.list.openMode": "doubleClick",
    "explorer.incrementalNaming": "smart",
    "git.autofetch": "all",
    "terminal.integrated.defaultProfile.windows": "Command Prompt",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.tabs.hideCondition": "never",
    "editor.scrollbar.horizontal": "visible",
    "editor.scrollbar.vertical": "visible",
    "workbench.colorCustomizations": {
        "scrollbarSlider.background": "#dddddd",
        "scrollbarSlider.hoverBackground": "#ffffff"
    },
    "editor.scrollbar.verticalScrollbarSize": 10,
    "editor.scrollbar.horizontalScrollbarSize": 10,
    "latex-workshop.formatting.latex": "latexindent",
    "latex-workshop.latex.outDir": "./out/",
    "latex-workshop.latex.recipes": [
        {
            "name": "xelatexmk -> ghostscript",
            "tools": [
                "xelatexmk",
                "ghostscript"
            ]
        },
        {
            "name": "latexmk",
            "tools": [
                "latexmk"
            ]
        },
        {
            "name": "latexmk (latexmkrc)",
            "tools": [
                "latexmk_rconly"
            ]
        },
        {
            "name": "latexmk (lualatex)",
            "tools": [
                "lualatexmk"
            ]
        },
        {
            "name": "latexmk (xelatex)",
            "tools": [
                "xelatexmk"
            ]
        },
        {
            "name": "pdflatex -> bibtex -> pdflatex * 2",
            "tools": [
                "pdflatex",
                "bibtex",
                "pdflatex",
                "pdflatex"
            ]
        },
        {
            "name": "Compile Rnw files",
            "tools": [
                "rnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Jnw files",
            "tools": [
                "jnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Pnw files",
            "tools": [
                "pnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "tectonic",
            "tools": [
                "tectonic"
            ]
        }
    ],
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        },
        "Ubuntu (WSL)": {
            "path": "C:\\Windows\\System32\\wsl.exe",
            "args": [
                "-d",
                "Ubuntu"
            ]
        }
    },
    "latex-workshop.latex.tools": [
        {
            "name": "ghostscript",
            "command": "ghostscript",
            "args": [
                "-sDEVICE=pdfwrite",
                "-dCompatibilityLevel=1.5",
                "-dPDFSETTINGS=/printer",
                "-o",
                "%OUTDIR%/%DOCFILE%_compressed.pdf",
                "%OUTDIR%/%DOCFILE%.pdf"
            ],
            "env": {}
        },
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "--shell-escape",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-outdir=%OUTDIR%",
                "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "lualatexmk",
            "command": "latexmk",
            "args": [
                "--shell-escape",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-lualatex",
                "-outdir=%OUTDIR%",
                "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "xelatexmk",
            "command": "latexmk",
            "args": [
                "--shell-escape",
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-xelatex",
                "-outdir=%OUTDIR%",
                "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "latexmk_rconly",
            "command": "latexmk",
            "args": [
                "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "pdflatex",
            "command": "pdflatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ],
            "env": {}
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "%DOCFILE%"
            ],
            "env": {}
        },
        {
            "name": "rnw2tex",
            "command": "Rscript",
            "args": [
                "-e",
                "knitr::opts_knit$set(concordance = TRUE); knitr::knit('%DOCFILE_EXT%')"
            ],
            "env": {}
        },
        {
            "name": "jnw2tex",
            "command": "julia",
            "args": [
                "-e",
                "using Weave; weave(\"%DOC_EXT%\", doctype=\"tex\")"
            ],
            "env": {}
        },
        {
            "name": "jnw2texminted",
            "command": "julia",
            "args": [
                "-e",
                "using Weave; weave(\"%DOC_EXT%\", doctype=\"texminted\")"
            ],
            "env": {}
        },
        {
            "name": "pnw2tex",
            "command": "pweave",
            "args": [
                "-f",
                "tex",
                "%DOC_EXT%"
            ],
            "env": {}
        },
        {
            "name": "pnw2texminted",
            "command": "pweave",
            "args": [
                "-f",
                "texminted",
                "%DOC_EXT%"
            ],
            "env": {}
        },
        {
            "name": "tectonic",
            "command": "tectonic",
            "args": [
                "--synctex",
                "--keep-logs",
                "--print",
                "%DOC%.tex"
            ],
            "env": {}
        }
    ],
    "latex-workshop.latex.autoBuild.run": "onSave",
    "cursor.cpp.disabledLanguages": [
        "plaintext"
    ],
    "explorer.confirmDelete": false,
    "jupyter.interactiveWindow.textEditor.executeSelection": true,
    "window.newWindowProfile": "PeterProfile",
    "jupyter.askForKernelRestart": false,
    "editor.tabCompletion": "on",
    "scm.diffDecorationsIgnoreTrimWhitespace": "inherit",
    "diffEditor.codeLens": true,
    "diffEditor.experimental.useTrueInlineView": true,
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "diffEditor.renderSideBySide": true,
    "editor.minimap.enabled": true,
    "editor.minimap.autohide": true,
    "editor.acceptSuggestionOnEnter": "smart",
    "explorer.sortOrder": "type",
    "editor.defaultFormatter": "charliermarsh.ruff",
    "notebook.defaultFormatter": "charliermarsh.ruff",
    "remote.autoForwardPortsSource": "hybrid",
    "window.openFoldersInNewWindow": "on",
    "git.openDiffOnClick": false,
    "gitlens.views.remotes.files.layout": "tree",
    "window.titleBarStyle": "custom",
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "ty.experimental.completions.enable": true,
    "python.languageServer": "None",
    "notebook.variablesView": true,
    "gitlens.showWelcomeOnInstall": false,
    "gitlens.showWhatsNewAfterUpgrades": false,
    "gitlens.currentLine.enabled": false,
    "gitlens.defaultGravatarsStyle": "wavatar",
    "gitlens.views.commits.files.layout": "tree",
    "gitlens.views.stashes.files.layout": "tree",
    "git.allowNoVerifyCommit": true,
    "git.autoStash": true,
    "git.branchPrefix": "psharpe/",
    "git.closeDiffOnOperation": true,
    "git.fetchOnPull": true,
    "git.mergeEditor": true,
    "git.pruneOnFetch": true,
    "git.pullBeforeCheckout": true,
    "git.untrackedChanges": "separate",
    "diffEditor.experimental.showMoves": true,
    "gitlens.gitCommands.skipConfirmations": [
        "fetch:command",
        "stash-push:command",
        "switch:command",
        "pull:menu",
        "push:menu"
    ],
    "files.exclude": {
        "**/__pycache__": true,
        "**/.coverage*": true,
        "**/.idea": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true,
        "**/*.egg-info": true
    },
    "makefile.configureOnOpen": false,
    "cursor.diffs.useCharacterLevelDiffs": true,
    "[latex]": {
        "editor.defaultFormatter": "James-Yu.latex-workshop"
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "notebook.cellExecutionTimeVerbosity": "verbose",
    "notebook.diff.ignoreMetadata": true,
    "notebook.diff.ignoreOutputs": true,
    "notebook.diff.experimental.toggleInline": true,
    "window.title": "${rootName}",
    "window.titleSeparator": " | ",
    "workbench.colorTheme": "Monokai",
    "workbench.tree.indent": 30,
    "workbench.iconTheme": "material-icon-theme",
    "python.experiments.enabled": false,
    "debugpy.showPythonInlineValues": true,
    "jupyter.enableExtendedPythonKernelCompletions": true,
    "jupyter.executionAnalysis.enabled": true,
    "jupyter.interactiveWindow.creationMode": "single",
    "jupyter.interactiveWindow.textEditor.normalizeSelection": true,
    "git.smartCommitChanges": "tracked",
    "git.useEditorAsCommitInput": false,
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer"
    },
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "cursor.composer.usageSummaryDisplay": "always",
    "githubPullRequests.createOnPublishBranch": "never",
    "editor.fontFamily": "'FiraCode Nerd Font', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": false,
    "editor.fontSize": 13,
    "terminal.integrated.defaultProfile.linux": "zsh"
}