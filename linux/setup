#!/usr/bin/env python3
"""
Peter Sharpe's Linux Setup Script - Interactive TUI

A curses-based terminal interface for selecting and installing system components.
Parses install_scripts/manifest.conf and provides interactive selection with presets.

Usage:
    setup              # Interactive TUI mode
    setup --preset 1   # Non-interactive: Desktop preset
    setup --preset 2   # Non-interactive: Headless preset
    setup --list       # Show available presets
    setup --dry-run    # Dry run mode
    setup --help       # Show help
"""

import argparse
import concurrent.futures
import curses
import json
import os
import pty
import re
import select
import subprocess
import sys
import tomllib
from dataclasses import dataclass, field
from pathlib import Path
from typing import Literal, Self

# Type aliases for literal values
SectionState = Literal["all", "none", "partial"]
ScriptStatusValue = Literal["pending", "running", "success", "failed", "skipped"]
ColorName = Literal[
    "green", "yellow", "cyan", "red", "blue", "header", "dim", "bold", "reverse"
]

# Regex to match ANSI escape sequences
ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-9;]*[a-zA-Z]|\x1b\][^\x07]*\x07|\x1b[()][AB012]")

# Control characters to strip (carriage return, bell, etc.) - excluding newline and tab
CONTROL_CHARS = str.maketrans(
    "", "", "\r\x00\x01\x02\x03\x04\x05\x06\x07\x08\x0b\x0c\x0e\x0f"
)


###############################################################################
### Configuration Loading
###############################################################################


def load_config(config_path: Path) -> dict:
    """Load configuration from TOML file.

    Returns:
        Parsed config dict with 'user' and 'presets' sections.
    """
    with open(config_path, "rb") as f:
        return tomllib.load(f)


def get_config_path() -> Path:
    """Get path to config.toml (same directory as this script)."""
    return Path(__file__).parent / "config.toml"


# Load configuration at module level
_CONFIG = load_config(get_config_path())

# User defaults from config
DEFAULT_GIT_NAME = _CONFIG["user"]["git_name"]
DEFAULT_GIT_EMAIL = _CONFIG["user"]["git_email"]


def strip_ansi(text: str) -> str:
    """Remove ANSI escape sequences and control characters from text.

    Strips ANSI color codes, cursor movement sequences, and control characters
    like carriage return that could corrupt curses display.
    """
    text = ANSI_ESCAPE_RE.sub("", text)
    return text.translate(CONTROL_CHARS)


WRAP_INDICATOR = "↩"
WRAP_INDENT = "  "  # 2 spaces for continuation lines


def wrap_line(line: str, width: int) -> list[str]:
    """Hard-wrap a line to the given width with visual continuation indicators.

    Wrapped lines end with a continuation indicator (↩), and continuation lines
    are indented with 2 spaces to visually distinguish them from new lines.

    For very small widths (≤3), falls back to basic wrapping without indicators
    to avoid infinite loops.

    Args:
        line: The line to wrap.
        width: Maximum width per wrapped segment.

    Returns:
        List of wrapped line segments. Empty or short lines return as single-element list.
    """
    if not line or width <= 0:
        return [line]
    if len(line) <= width:
        return [line]

    indent_len = len(WRAP_INDENT)

    # Fall back to basic wrapping for very small widths where indicators don't fit
    if width <= indent_len + 1:
        result = []
        while len(line) > width:
            result.append(line[:width])
            line = line[width:]
        result.append(line)
        return result

    result = []

    # First segment: width - 1 chars + wrap indicator
    first_content_width = width - 1
    result.append(line[:first_content_width] + WRAP_INDICATOR)
    line = line[first_content_width:]

    # Continuation segments: indent + content + optional wrap indicator
    continuation_width = width - indent_len - 1  # space for indent and indicator

    while len(line) > width - indent_len:
        result.append(WRAP_INDENT + line[:continuation_width] + WRAP_INDICATOR)
        line = line[continuation_width:]

    # Final segment: indent + remaining (no indicator)
    result.append(WRAP_INDENT + line)
    return result


def wrap_lines(lines: list[str], width: int) -> list[str]:
    """Wrap multiple lines to a given width, expanding tabs.

    Each input line is processed: tabs expanded to 4 spaces, trailing whitespace
    stripped, then hard-wrapped to fit within width.

    Args:
        lines: List of lines to wrap.
        width: Maximum width per wrapped segment.

    Returns:
        Flattened list of wrapped line segments.
    """
    result = []
    for line in lines:
        cleaned = line.expandtabs(4).rstrip()
        result.extend(wrap_line(cleaned, width))
    return result


###############################################################################
### Scroll State
###############################################################################


@dataclass
class ScrollState:
    """Manages scroll position for a scrollable panel.

    Tracks offset (first visible item), total items, and visible height.
    Provides methods for navigation and ensures offset stays in valid range.
    """

    offset: int = 0  # Index of first visible item
    total: int = 0  # Total number of items
    visible: int = 0  # Number of items that fit in the view

    def clamp(self) -> None:
        """Ensure offset is within valid range."""
        max_offset = max(0, self.total - self.visible)
        self.offset = max(0, min(self.offset, max_offset))

    def scroll_up(self, n: int = 1) -> None:
        """Scroll up by n items."""
        self.offset -= n
        self.clamp()

    def scroll_down(self, n: int = 1) -> None:
        """Scroll down by n items."""
        self.offset += n
        self.clamp()

    def page_up(self) -> None:
        """Scroll up by one page."""
        self.scroll_up(max(1, self.visible - 1))

    def page_down(self) -> None:
        """Scroll down by one page."""
        self.scroll_down(max(1, self.visible - 1))

    def go_top(self) -> None:
        """Scroll to the top."""
        self.offset = 0

    def go_bottom(self) -> None:
        """Scroll to the bottom."""
        self.offset = max(0, self.total - self.visible)

    def ensure_visible(self, idx: int) -> None:
        """Adjust offset to ensure item at idx is visible."""
        if idx < self.offset:
            self.offset = idx
        elif idx >= self.offset + self.visible:
            self.offset = idx - self.visible + 1
        self.clamp()


###############################################################################
### Data Model
###############################################################################


@dataclass
class Script:
    """A single install script."""

    name: str  # Display name (e.g., "apt_packages")
    path: str  # Relative path from install_scripts/ (e.g., "system_packages/apt_packages.sh")
    enabled: bool = True
    metadata: dict[str, str] = field(default_factory=dict)

    @property
    def display_name(self) -> str:
        """Human-readable name from @name metadata, or derived from filename."""
        return self.metadata.get("name", self.name.replace("_", " ").title())

    @property
    def description(self) -> str:
        """Script description from @description metadata."""
        return self.metadata.get("description", "")

    @property
    def requires_sudo(self) -> bool:
        """Whether script requires sudo (from @requires metadata)."""
        return "sudo" in self.metadata.get("requires", "")

    @property
    def is_parallel(self) -> bool:
        """Whether script can run in parallel (from @parallel metadata)."""
        return self.metadata.get("parallel", "").lower() == "true"

    @property
    def is_headless_skip(self) -> bool:
        """Whether script should be skipped in headless mode."""
        return self.metadata.get("headless", "").lower() == "skip"

    @property
    def dependencies(self) -> list[str]:
        """List of script names this script depends on (from @depends metadata)."""
        depends_str = self.metadata.get("depends", "")
        if not depends_str:
            return []
        # Parse comma-separated list, strip .sh extension if present
        return [d.strip().removesuffix(".sh") for d in depends_str.split(",")]


@dataclass
class Section:
    """A section containing multiple scripts."""

    name: str
    scripts: list[Script] = field(default_factory=list)

    @property
    def state(self) -> SectionState:
        """Returns 'all', 'none', or 'partial' based on enabled scripts."""
        enabled_count = sum(1 for s in self.scripts if s.enabled)
        if enabled_count == len(self.scripts):
            return "all"
        elif enabled_count == 0:
            return "none"
        else:
            return "partial"

    def set_all(self, enabled: bool) -> None:
        """Set all scripts to enabled or disabled."""
        for script in self.scripts:
            script.enabled = enabled

    def toggle(self) -> None:
        """Toggle section: if any enabled, disable all; otherwise enable all."""
        if self.state == "none":
            self.set_all(True)
        else:
            self.set_all(False)


@dataclass
class Manifest:
    """The complete manifest of sections and scripts."""

    sections: list[Section] = field(default_factory=list)
    dep_graph: "DependencyGraph | None" = field(default=None, repr=False)

    def get_enabled_scripts(self) -> list[tuple[Section, Script]]:
        """Return list of (section, script) tuples for enabled scripts."""
        result = []
        for section in self.sections:
            for script in section.scripts:
                if script.enabled:
                    result.append((section, script))
        return result

    def get_flat_items(self) -> list[Section | Script]:
        """Return flat list of sections and scripts for navigation."""
        items: list[Section | Script] = []
        for section in self.sections:
            items.append(section)
            items.extend(section.scripts)
        return items

    def get_script_order(self) -> dict[str, int]:
        """Return dict mapping script names to their order index in the manifest."""
        order: dict[str, int] = {}
        idx = 0
        for section in self.sections:
            for script in section.scripts:
                order[script.name] = idx
                idx += 1
        return order

    def get_script_by_name(self, name: str) -> Script | None:
        """Find a script by its name (stem without .sh)."""
        for section in self.sections:
            for script in section.scripts:
                if script.name == name:
                    return script
        return None


@dataclass
class DependencyGraph:
    """DAG for computing transitive script dependencies with order validation.

    All transitive dependencies are pre-computed at construction time since
    the graph is immutable after creation.
    """

    adj: dict[str, list[str]] = field(default_factory=dict)
    transitive: dict[str, set[str]] = field(default_factory=dict)
    script_order: dict[str, int] = field(default_factory=dict)

    @classmethod
    def from_manifest(cls, manifest: Manifest) -> Self:
        """Build dependency graph from a parsed manifest."""
        graph = cls()
        idx = 0
        for section in manifest.sections:
            for script in section.scripts:
                graph.adj[script.name] = script.dependencies
                graph.script_order[script.name] = idx
                idx += 1

        # Pre-compute all transitive dependencies
        for name in graph.adj:
            graph.transitive[name] = graph._compute_transitive(name)

        return graph

    def _compute_transitive(self, name: str) -> set[str]:
        """Compute all transitive dependencies for a script via DFS."""
        result: set[str] = set()
        visiting: set[str] = set()

        def dfs(current: str) -> None:
            if current in visiting:
                return  # Cycle - skip
            visiting.add(current)
            for dep in self.adj.get(current, []):
                result.add(dep)
                dfs(dep)
            visiting.remove(current)

        dfs(name)
        return result

    def get_transitive_deps(self, name: str) -> set[str]:
        """Get all dependencies (direct + transitive) for a script."""
        return self.transitive.get(name, set())

    def get_order(self, name: str) -> int:
        """Get manifest order index for a script (0-indexed position)."""
        return self.script_order.get(name, 0)


###############################################################################
### Script Metadata Parser
###############################################################################


def parse_script_metadata(script_path: Path) -> dict[str, str]:
    """Extract @key: value metadata from script header comments.

    Parses lines like:
        # @name: bat
        # @description: Modern cat replacement
        # @requires: sudo
        # @parallel: true
    """
    metadata: dict[str, str] = {}
    try:
        with open(script_path) as f:
            for line in f:
                line = line.strip()
                # Stop at first non-comment, non-shebang, non-empty line
                if line and not line.startswith("#"):
                    break
                # Parse @key: value pattern
                if match := re.match(r"^#\s*@(\w+):\s*(.+)$", line):
                    metadata[match.group(1)] = match.group(2).strip()
    except (OSError, IOError):
        pass  # File not readable, return empty metadata
    return metadata


###############################################################################
### Manifest Parser
###############################################################################


def parse_manifest(manifest_path: Path, scripts_dir: Path | None = None) -> Manifest:
    """Parse INI-style manifest.conf into a Manifest object.

    If scripts_dir is provided, also loads @metadata from each script file.
    """
    manifest = Manifest()
    current_section: Section | None = None

    # Default scripts_dir to same directory as manifest
    if scripts_dir is None:
        scripts_dir = manifest_path.parent

    with open(manifest_path) as f:
        for line in f:
            line = line.strip()

            # Skip empty lines and comments
            if not line or line.startswith("#"):
                continue

            # Section header: [Section Name]
            if line.startswith("[") and line.endswith("]"):
                section_name = line[1:-1]
                current_section = Section(name=section_name)
                manifest.sections.append(current_section)
            elif current_section is not None:
                # Script path
                script_path = line
                # Extract script name from path (remove directory and .sh)
                script_name = Path(script_path).stem
                # Load metadata from script file
                metadata = parse_script_metadata(scripts_dir / script_path)
                current_section.scripts.append(
                    Script(name=script_name, path=script_path, metadata=metadata)
                )

    # Build dependency graph after all scripts are loaded
    manifest.dep_graph = DependencyGraph.from_manifest(manifest)

    return manifest


###############################################################################
### Script Execution Helpers
###############################################################################


def check_sudo_available() -> bool:
    """Check if sudo is available without password (NOPASSWD or cached credentials)."""
    if os.geteuid() == 0:
        return True  # Running as root
    try:
        result = subprocess.run(
            ["sudo", "-n", "true"],
            capture_output=True,
            timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def prompt_sudo_if_needed(enabled_scripts: list[tuple[Section, Script]]) -> bool:
    """Prompt for sudo credentials if any enabled scripts require sudo.

    Args:
        enabled_scripts: List of (section, script) tuples to be executed.

    Returns:
        True if sudo is available (or not needed), False if user declined/failed.
    """
    # Check if any scripts require sudo
    needs_sudo = any(script.requires_sudo for _, script in enabled_scripts)
    if not needs_sudo:
        return True  # No sudo needed

    # Already have sudo?
    if check_sudo_available():
        return True

    # Prompt user
    print("\n" + "─" * 60)
    print(" Some selected scripts require sudo.")
    print("─" * 60)

    try:
        response = input(" Authenticate with sudo? [Y/n] ").strip().lower()
        if response and response[0] == "n":
            print(" Continuing without sudo (some scripts will be skipped)")
            return True  # User chose to continue without sudo

        # Try to cache sudo credentials
        result = subprocess.run(["sudo", "-v"], timeout=60)
        if result.returncode == 0:
            print(" ✓ Sudo credentials cached")
            return True
        else:
            print(" ✗ Sudo authentication failed")
            return True  # Continue anyway, scripts will skip
    except (KeyboardInterrupt, EOFError):
        print("\n Cancelled")
        return False
    except Exception as e:
        print(f" Error: {e}")
        return True  # Continue anyway


def prepare_script_env(dry_run: bool, headless: bool) -> dict[str, str]:
    """Prepare environment variables for script execution.

    Args:
        dry_run: Whether to run in dry-run mode (preview changes only).
        headless: Whether to skip GUI components.

    Returns:
        Environment dictionary with all required variables set.
    """
    env = os.environ.copy()
    env["_SOURCED"] = "1"
    env["ORCHESTRATED"] = "true"
    env["DRY_RUN"] = "true" if dry_run else "false"
    env["HEADLESS"] = "Y" if headless else "N"
    env["INSTALL_SNAPS"] = "N" if headless else "Y"
    env["HAS_SUDO"] = "true" if check_sudo_available() else "false"
    env["GIT_NAME"] = env.get("GIT_NAME", DEFAULT_GIT_NAME)
    env["GIT_EMAIL"] = env.get("GIT_EMAIL", DEFAULT_GIT_EMAIL)
    return env


def build_script_command(scripts_dir: Path, script_path: Path) -> str:
    """Build bash command that sources _common.sh then executes a script.

    Args:
        scripts_dir: Directory containing install scripts (install_scripts/).
        script_path: Full path to the script to execute.

    Returns:
        Bash command string suitable for `bash -c`.
    """
    common_sh = scripts_dir.parent / "_common.sh"
    return f'source "{common_sh}" && source "{script_path}"'


def run_script_simple(
    script_path: Path,
    scripts_dir: Path,
    env: dict[str, str],
) -> subprocess.CompletedProcess[str]:
    """Execute a script with captured output (non-interactive).

    Args:
        script_path: Full path to the script to execute.
        scripts_dir: Directory containing install scripts.
        env: Environment variables for execution.

    Returns:
        CompletedProcess with captured stdout/stderr.
    """
    bash_cmd = build_script_command(scripts_dir, script_path)
    return subprocess.run(
        ["bash", "-c", bash_cmd],
        env=env,
        cwd=scripts_dir.parent,
        capture_output=True,
        text=True,
    )


###############################################################################
### Presets
###############################################################################


@dataclass(frozen=True)
class PresetDef:
    """Definition of an installation preset.

    Attributes:
        description: Human-readable description (e.g., "Desktop - Full installation").
        disabled_sections: Section names to disable for this preset.
        flags: Modifier flags ("no_sudo" disables @requires:sudo scripts,
               "headless" disables @headless:skip scripts).
    """

    description: str
    disabled_sections: tuple[str, ...] = ()
    flags: tuple[str, ...] = ()


def _load_presets_from_config() -> dict[str, PresetDef]:
    """Load presets from config.toml and map to numeric keys.

    Maps preset names to keys 1-5 in order:
    desktop=1, headless=2, desktop_no_sudo=3, headless_no_sudo=4, empty=5
    """
    preset_order = [
        "desktop",
        "headless",
        "desktop_no_sudo",
        "headless_no_sudo",
        "empty",
    ]
    presets: dict[str, PresetDef] = {}

    for i, name in enumerate(preset_order, start=1):
        if name not in _CONFIG.get("presets", {}):
            continue
        cfg = _CONFIG["presets"][name]
        presets[str(i)] = PresetDef(
            description=cfg.get("description", name),
            disabled_sections=tuple(cfg.get("disabled_sections", [])),
            flags=tuple(cfg.get("flags", [])),
        )

    return presets


PRESETS: dict[str, PresetDef] = _load_presets_from_config()


def is_headless_preset(preset_key: str) -> bool:
    """Check if a preset is a headless preset (no GUI components)."""
    return preset_key in PRESETS and "headless" in PRESETS[preset_key].flags


def apply_preset(manifest: Manifest, preset_key: str) -> None:
    """Apply a preset to the manifest, enabling/disabling sections and scripts.

    Uses script metadata (@requires, @headless) to determine what to disable.
    """
    if preset_key not in PRESETS:
        return

    preset = PRESETS[preset_key]

    # Handle "empty" preset - disable everything for manual selection
    if "empty" in preset.flags:
        for section in manifest.sections:
            section.set_all(False)
        return

    # First, enable everything
    for section in manifest.sections:
        section.set_all(True)

    # Disable specified sections
    for section in manifest.sections:
        if section.name in preset.disabled_sections:
            section.set_all(False)

    # Apply flags based on script metadata
    for section in manifest.sections:
        for script in section.scripts:
            # Disable sudo-requiring scripts if no_sudo flag set
            if "no_sudo" in preset.flags and script.requires_sudo:
                script.enabled = False
            # Disable headless-skip scripts if headless flag set
            if "headless" in preset.flags and script.is_headless_skip:
                script.enabled = False


###############################################################################
### Curses Helpers
###############################################################################


def make_title_bar(title: str, width: int) -> str:
    """Create a centered title bar with ═ borders.

    Example: "══════ My Title ══════" (padded to width).
    """
    padding = (width - len(title) - 2) // 2
    return "═" * padding + title + "═" * (width - padding - len(title) - 2)


def init_colors() -> dict[ColorName, int]:
    """Initialize curses color pairs and return a mapping."""
    curses.start_color()
    curses.use_default_colors()

    # Define color pairs
    curses.init_pair(1, curses.COLOR_GREEN, -1)  # Enabled
    curses.init_pair(2, curses.COLOR_YELLOW, -1)  # Partial
    curses.init_pair(3, curses.COLOR_CYAN, -1)  # Running/info
    curses.init_pair(4, curses.COLOR_RED, -1)  # Failed/error
    curses.init_pair(5, curses.COLOR_BLUE, -1)  # Header
    curses.init_pair(6, curses.COLOR_BLACK, curses.COLOR_CYAN)  # Header bar

    return {
        "green": curses.color_pair(1),
        "yellow": curses.color_pair(2),
        "cyan": curses.color_pair(3),
        "red": curses.color_pair(4),
        "blue": curses.color_pair(5),
        "header": curses.color_pair(6),
        "dim": curses.A_DIM,
        "bold": curses.A_BOLD,
        "reverse": curses.A_REVERSE,
    }


def draw_scrollbar(
    stdscr: curses.window,
    x: int,
    y_start: int,
    height: int,
    scroll: ScrollState,
    color: int,
) -> None:
    """Draw a vertical scrollbar showing position in content.

    Args:
        stdscr: Curses window to draw on.
        x: Column position for the scrollbar.
        y_start: First row of the scrollbar.
        height: Height of the scrollbar area.
        scroll: Current scroll state.
        color: Color attribute for the scrollbar (use for focus indication).
    """
    if height < 2 or scroll.total <= scroll.visible:
        # No scrollbar needed if everything fits
        return

    # Calculate thumb size and position
    # Thumb size proportional to visible/total ratio, minimum 1 char
    thumb_size = max(1, int(height * scroll.visible / scroll.total))
    # Thumb position based on scroll offset
    max_offset = max(1, scroll.total - scroll.visible)
    thumb_pos = int((height - thumb_size) * scroll.offset / max_offset)

    for i in range(height):
        y = y_start + i
        if thumb_pos <= i < thumb_pos + thumb_size:
            char = "█"  # Thumb
        else:
            char = "░"  # Track
        try:
            stdscr.addstr(y, x, char, color)
        except curses.error:
            pass


###############################################################################
### Selection TUI
###############################################################################


class SelectionTUI:
    """Interactive TUI for selecting scripts to install."""

    def __init__(self, stdscr: curses.window, manifest: Manifest, scripts_dir: Path):
        self.stdscr = stdscr
        self.manifest = manifest
        self.scripts_dir = scripts_dir
        self.colors = init_colors()
        self.cursor = 0  # Index in flat items list
        self.scroll = ScrollState()  # Scroll state for the tree view
        self.current_preset = "1"  # Start with Desktop preset
        apply_preset(self.manifest, self.current_preset)
        # Search state
        self.search_mode = False
        self.search_query = ""
        self.filtered_indices: list[int] | None = None  # None = no filter
        self.last_key = -1  # For detecting 'gg' sequence

    def get_dependency_warnings(self, script: Script) -> list[str]:
        """Get list of dependency warnings for a script.

        Checks all transitive dependencies for:
        - Dependencies that are unknown (typo in @depends)
        - Dependencies that are disabled
        - Dependencies that run after this script (wrong manifest order)
        """
        warnings: list[str] = []
        dep_graph = self.manifest.dep_graph
        if dep_graph is None:
            return warnings

        all_deps = dep_graph.get_transitive_deps(script.name)
        if not all_deps:
            return warnings

        script_idx = dep_graph.get_order(script.name)
        direct_deps = set(script.dependencies)

        for dep_name in all_deps:
            dep_script = self.manifest.get_script_by_name(dep_name)
            suffix = "" if dep_name in direct_deps else " (transitive)"

            if dep_script is None:
                warnings.append(f"unknown: {dep_name}{suffix}")
            elif not dep_script.enabled:
                warnings.append(f"{dep_script.display_name} disabled{suffix}")
            else:
                # Check order - dependency must run BEFORE this script
                dep_idx = dep_graph.get_order(dep_name)
                if dep_idx >= script_idx:
                    warnings.append(f"{dep_script.display_name} runs later{suffix}")

        return warnings

    def get_visible_height(self) -> int:
        """Get number of lines available for the tree view."""
        height, _ = self.stdscr.getmaxyx()
        return height - 7  # Header (3) + footer (4)

    def draw(self) -> None:
        """Draw the complete selection screen."""
        self.stdscr.clear()
        height, width = self.stdscr.getmaxyx()

        # Draw header
        self.draw_header(width)

        # Draw tree
        self.draw_tree(height, width)

        # Draw footer
        self.draw_footer(height, width)

        self.stdscr.refresh()

    def draw_header(self, width: int) -> None:
        """Draw the header section."""
        title = " Peter Sharpe's Linux Setup "
        header_line = make_title_bar(title, width)
        self.stdscr.attron(self.colors["header"] | self.colors["bold"])
        self.stdscr.addstr(0, 0, header_line[:width])
        self.stdscr.attroff(self.colors["header"] | self.colors["bold"])

        # Subtitle
        subtitle = f"Preset: [{self.current_preset}] {PRESETS[self.current_preset].description}"
        self.stdscr.addstr(1, 2, subtitle[: width - 4], self.colors["cyan"])

        # Separator
        self.stdscr.addstr(2, 0, "─" * width, self.colors["dim"])

    def draw_tree(self, height: int, width: int) -> None:
        """Draw the tree of sections and scripts."""
        items = self.manifest.get_flat_items()
        visible_height = self.get_visible_height()

        # Update scroll state
        self.scroll.total = len(items)
        self.scroll.visible = visible_height
        self.scroll.ensure_visible(self.cursor)

        # Draw visible items (reserve rightmost column for scrollbar)
        for i in range(visible_height):
            item_idx = self.scroll.offset + i
            if item_idx >= len(items):
                break

            item = items[item_idx]
            y = 3 + i
            is_selected = item_idx == self.cursor

            self.draw_item(y, width - 1, item, is_selected)

        # Draw scrollbar
        draw_scrollbar(
            self.stdscr,
            x=width - 1,
            y_start=3,
            height=visible_height,
            scroll=self.scroll,
            color=self.colors["cyan"],
        )

    def draw_item(
        self, y: int, width: int, item: Section | Script, is_selected: bool
    ) -> None:
        """Draw a single tree item (section or script)."""
        if isinstance(item, Section):
            self.draw_section(y, width, item, is_selected)
        else:
            self.draw_script(y, width, item, is_selected)

    def draw_section(
        self, y: int, width: int, section: Section, is_selected: bool
    ) -> None:
        """Draw a section header."""
        state = section.state
        if state == "all":
            checkbox = "[x]"
            color = self.colors["green"]
        elif state == "partial":
            checkbox = "[~]"
            color = self.colors["yellow"]
        else:
            checkbox = "[ ]"
            color = self.colors["dim"]

        line = f"  {checkbox} {section.name}"

        # Combine with reverse if selected
        rev = self.colors["reverse"] if is_selected else 0

        self.stdscr.addstr(y, 0, " " * width, rev)  # Clear line with selection
        self.stdscr.addstr(y, 0, line[: width - 1], color | self.colors["bold"] | rev)

    def draw_script(
        self, y: int, width: int, script: Script, is_selected: bool
    ) -> None:
        """Draw a script entry with its description and dependency warnings."""
        if script.enabled:
            checkbox = "[x]"
            color = self.colors["green"]
        else:
            checkbox = "[ ]"
            color = self.colors["dim"]

        name = script.display_name
        desc = script.description

        # Check for dependency warnings
        dep_warnings = self.get_dependency_warnings(script) if script.enabled else []

        # Calculate how much space we have for description
        # Format: "        [x] Name - Description"
        prefix = f"        {checkbox} {name}"
        prefix_len = len(prefix)

        # Reserve space for description (dim separator + text)
        desc_available = width - prefix_len - 4  # 4 = " - " + margin

        # Combine with reverse if selected
        rev = self.colors["reverse"] if is_selected else 0

        self.stdscr.addstr(y, 0, " " * width, rev)  # Clear line with selection
        self.stdscr.addstr(y, 0, prefix[: width - 1], color | rev)

        # Current position after prefix
        pos = prefix_len

        # Add description in dim/faded style if there's room
        if desc and desc_available > 10 and not dep_warnings:
            desc_text = desc[:desc_available]
            if len(desc) > desc_available:
                desc_text = desc[: desc_available - 1] + "…"
            try:
                # Draw separator and description in dim color
                dim_attr = self.colors["dim"] | rev
                self.stdscr.addstr(y, pos, " - ", dim_attr)
                self.stdscr.addstr(y, pos + 3, desc_text, dim_attr)
            except curses.error:
                pass  # Line too long, skip description
        elif dep_warnings:
            # Show dependency warnings in bold red (make them obvious)
            warning_text = " ⚠ " + ", ".join(dep_warnings)
            available = width - pos - 2
            if len(warning_text) > available:
                warning_text = warning_text[: available - 1] + "…"
            try:
                self.stdscr.addstr(
                    y, pos, warning_text, self.colors["red"] | self.colors["bold"] | rev
                )
            except curses.error:
                pass

    def draw_footer(self, height: int, width: int) -> None:
        """Draw the footer with key bindings."""
        footer_y = height - 4

        # Separator
        self.stdscr.addstr(footer_y, 0, "─" * width, self.colors["dim"])

        # Search mode display
        if self.search_mode:
            search_line = f" Search: {self.search_query}_ "
            self.stdscr.addstr(
                footer_y + 1, 2, search_line[: width - 4], self.colors["cyan"]
            )
            self.stdscr.addstr(
                footer_y + 2,
                2,
                " [Enter] Apply   [Esc] Cancel "[: width - 4],
                self.colors["dim"],
            )
        elif self.filtered_indices is not None:
            # Show filter active
            filter_line = f" Filter: '{self.search_query}' ({len(self.filtered_indices)} matches)   [Esc] Clear "
            self.stdscr.addstr(
                footer_y + 1, 2, filter_line[: width - 4], self.colors["yellow"]
            )
            keys2 = " [/] Search   [gg] Top   [G] Bottom   [x] Install   [q] Quit "
            self.stdscr.addstr(footer_y + 2, 2, keys2[: width - 4], self.colors["cyan"])
        else:
            # Key bindings - line 1
            keys1 = " [j/k] Up/Down   [Space] Toggle   [o] View   [/] Search   [x] Install   [q] Quit "
            self.stdscr.addstr(footer_y + 1, 2, keys1[: width - 4], self.colors["cyan"])

            # Key bindings - line 2
            preset_keys = "   ".join(
                f"[{k}] {p.description.split(' - ')[0]}" for k, p in PRESETS.items()
            )
            keys2 = f" {preset_keys}   [?] Help "
            self.stdscr.addstr(footer_y + 2, 2, keys2[: width - 4], self.colors["cyan"])

        # Status line showing selected/total scripts and warning count
        enabled_scripts = self.manifest.get_enabled_scripts()
        enabled_count = len(enabled_scripts)
        total_count = sum(len(s.scripts) for s in self.manifest.sections)

        # Count scripts with dependency warnings
        warning_count = sum(
            1 for _, script in enabled_scripts if self.get_dependency_warnings(script)
        )

        status = f" {enabled_count}/{total_count} scripts selected "
        self.stdscr.addstr(
            footer_y + 3,
            2,
            status[: width - 4],
            self.colors["green"] | self.colors["bold"],
        )

        # Show warning count if any
        if warning_count > 0:
            warning_text = f" ⚠ {warning_count} with possible dependency issues "
            warning_x = 2 + len(status)
            if warning_x + len(warning_text) < width - 2:
                self.stdscr.addstr(
                    footer_y + 3,
                    warning_x,
                    warning_text,
                    self.colors["red"] | self.colors["bold"],
                )

    def handle_input(self) -> Literal["execute", "quit"] | None:
        """Handle keyboard input. Returns 'execute' or 'quit' or None."""
        key = self.stdscr.getch()
        items = self.manifest.get_flat_items()

        # Search mode input handling
        if self.search_mode:
            if key == 27:  # Escape - cancel search
                self.search_mode = False
                self.search_query = ""
            elif key in (curses.KEY_ENTER, 10, 13):  # Enter (KEY_ENTER, LF, CR)
                self.search_mode = False
                if self.search_query:
                    self._apply_search_filter(items)
                else:
                    self.filtered_indices = None
            elif key in (curses.KEY_BACKSPACE, 127, 8):  # Backspace
                self.search_query = self.search_query[:-1]
            elif 32 <= key < 127:  # Printable ASCII
                self.search_query += chr(key)
            self.last_key = -1
            return None

        # Clear filter on Escape
        if key == 27 and self.filtered_indices is not None:
            self.filtered_indices = None
            self.search_query = ""
            self.last_key = -1
            return None

        # Start search mode
        if key == ord("/"):
            self.search_mode = True
            self.search_query = ""
            self.last_key = -1
            return None

        # Vim-style gg (go to top) - need to detect 'g' followed by 'g'
        if key == ord("g"):
            if self.last_key == ord("g"):
                self.cursor = 0
                self.scroll.go_top()
                self.last_key = -1
                return None
            else:
                self.last_key = key
                return None

        # Vim-style G (go to bottom)
        if key == ord("G"):
            self.cursor = len(items) - 1
            self.last_key = -1
            return None

        # Reset last_key for non-g keys
        self.last_key = -1

        # Navigation
        if key in (ord("w"), ord("k"), curses.KEY_UP):
            if self.cursor > 0:
                self.cursor -= 1
        elif key in (ord("s"), ord("j"), curses.KEY_DOWN):
            if self.cursor < len(items) - 1:
                self.cursor += 1
        elif key == curses.KEY_PPAGE:  # Page Up
            self.cursor = max(0, self.cursor - max(1, self.scroll.visible - 1))
        elif key == curses.KEY_NPAGE:  # Page Down
            self.cursor = min(
                len(items) - 1, self.cursor + max(1, self.scroll.visible - 1)
            )

        # Toggle
        elif key in (ord(" "), curses.KEY_ENTER, 10, 13):
            item = items[self.cursor]
            if isinstance(item, Section):
                item.toggle()
            else:
                item.enabled = not item.enabled

        # Presets (keys 1-5)
        elif ord("1") <= key <= ord("5") and (preset_key := chr(key)) in PRESETS:
            self.current_preset = preset_key
            apply_preset(self.manifest, preset_key)
            # Clear any filter when applying preset
            self.filtered_indices = None
            self.search_query = ""

        # Execute
        elif key == ord("x"):
            return "execute"

        # Quit
        elif key == ord("q"):
            return "quit"

        # Help
        elif key == ord("?"):
            self.show_help()

        # View script content
        elif key == ord("o"):
            self.show_script_content()

        return None

    def _apply_search_filter(self, items: list[Section | Script]) -> None:
        """Apply search filter and highlight matching items."""
        query = self.search_query.lower()
        self.filtered_indices = []
        for i, item in enumerate(items):
            name = item.name if isinstance(item, Section) else item.display_name
            if query in name.lower():
                self.filtered_indices.append(i)
        # Move cursor to first match
        if self.filtered_indices:
            self.cursor = self.filtered_indices[0]

    def show_help(self) -> None:
        """Show help overlay."""
        height, width = self.stdscr.getmaxyx()

        help_text = [
            "╔══════════════════════════════════════════╗",
            "║            Keyboard Shortcuts            ║",
            "╠══════════════════════════════════════════╣",
            "║  j, k, ↑↓    Move cursor up/down         ║",
            "║  PgUp/PgDn   Page up/down                ║",
            "║  gg          Jump to top                 ║",
            "║  G           Jump to bottom              ║",
            "║  Space/Enter Toggle selection            ║",
            "║  o           View script content         ║",
            "║  /           Search scripts              ║",
            "║  Esc         Clear search filter         ║",
            "║  1-5         Apply preset                ║",
            "║  x           Start installation          ║",
            "║  q           Quit                        ║",
            "║  ?           Show this help              ║",
            "╠══════════════════════════════════════════╣",
            "║  Sections toggle all children            ║",
            "║  [x]=enabled [~]=partial [ ]=disabled    ║",
            "╚══════════════════════════════════════════╝",
            "",
            "         Press any key to continue         ",
        ]

        # Center the help box
        box_height = len(help_text)
        box_width = len(help_text[0])
        start_y = (height - box_height) // 2
        start_x = (width - box_width) // 2

        for i, line in enumerate(help_text):
            self.stdscr.addstr(
                start_y + i, start_x, line, self.colors["cyan"] | self.colors["bold"]
            )

        self.stdscr.refresh()
        self.stdscr.getch()  # Wait for any key

    def show_script_content(self) -> None:
        """Show the full script content in a scrollable overlay.

        Only works when the cursor is on a Script (not a Section).
        Displays the shell script file in a box with scroll support.
        """
        items = self.manifest.get_flat_items()
        if self.cursor >= len(items):
            return

        item = items[self.cursor]
        if not isinstance(item, Script):
            return  # Only show for scripts, not sections

        # Read script file
        script_path = self.scripts_dir / item.path
        try:
            with open(script_path) as f:
                content = f.read()
        except (OSError, IOError) as e:
            content = f"Error reading script: {e}"

        lines = content.split("\n")

        # Overlay dimensions
        height, width = self.stdscr.getmaxyx()
        box_width = min(width - 4, 100)  # Max 100 chars wide, 2 char margin each side
        box_height = height - 4  # 2 char margin top/bottom
        start_x = (width - box_width) // 2
        start_y = 2

        # Content area (inside box borders)
        content_width = box_width - 4  # 2 chars for border + 1 char padding each side
        content_height = box_height - 4  # Header + separator + footer + border

        # Wrap lines to content width
        wrapped_lines = wrap_lines(lines, content_width)

        # Scroll state for the overlay (uses wrapped line count)
        scroll = ScrollState(offset=0, total=len(wrapped_lines), visible=content_height)
        last_key = -1  # For detecting 'gg' sequence

        while True:
            # Draw box background
            for y in range(box_height):
                try:
                    self.stdscr.addstr(
                        start_y + y, start_x, " " * box_width, self.colors["reverse"]
                    )
                except curses.error:
                    pass

            # Draw box border
            # Top border
            header = f" {item.path} "
            top_line = "╔" + "═" * (box_width - 2) + "╗"
            # Insert header into top border
            header_start = (box_width - len(header)) // 2
            top_line = (
                top_line[:header_start] + header + top_line[header_start + len(header) :]
            )
            try:
                self.stdscr.addstr(
                    start_y, start_x, top_line, self.colors["cyan"] | self.colors["bold"]
                )
            except curses.error:
                pass

            # Bottom border with scroll hint
            scroll_hint = f" {scroll.offset + 1}-{min(scroll.offset + content_height, len(wrapped_lines))}/{len(wrapped_lines)} "
            bot_line = "╚" + "═" * (box_width - 2) + "╝"
            hint_start = (box_width - len(scroll_hint)) // 2
            bot_line = (
                bot_line[:hint_start]
                + scroll_hint
                + bot_line[hint_start + len(scroll_hint) :]
            )
            try:
                self.stdscr.addstr(
                    start_y + box_height - 1,
                    start_x,
                    bot_line,
                    self.colors["cyan"] | self.colors["bold"],
                )
            except curses.error:
                pass

            # Side borders
            for y in range(1, box_height - 1):
                try:
                    self.stdscr.addstr(
                        start_y + y, start_x, "║", self.colors["cyan"] | self.colors["bold"]
                    )
                    self.stdscr.addstr(
                        start_y + y,
                        start_x + box_width - 1,
                        "║",
                        self.colors["cyan"] | self.colors["bold"],
                    )
                except curses.error:
                    pass

            # Draw content lines
            for i in range(content_height):
                line_idx = scroll.offset + i
                y = start_y + 1 + i
                x = start_x + 2

                if line_idx < len(wrapped_lines):
                    line = wrapped_lines[line_idx]
                    try:
                        self.stdscr.addstr(y, x, line.ljust(content_width))
                    except curses.error:
                        pass

            # Draw scrollbar
            scrollbar_x = start_x + box_width - 2
            draw_scrollbar(
                self.stdscr,
                x=scrollbar_x,
                y_start=start_y + 1,
                height=content_height,
                scroll=scroll,
                color=self.colors["cyan"],
            )

            # Footer hint
            hint = " [j/k] Scroll   [gg/G] Top/Bottom   [q/Esc] Close "
            hint_y = start_y + box_height - 2
            hint_x = start_x + (box_width - len(hint)) // 2
            try:
                self.stdscr.addstr(hint_y, hint_x, hint, self.colors["dim"])
            except curses.error:
                pass

            self.stdscr.refresh()

            # Handle input
            key = self.stdscr.getch()

            # Vim-style gg (go to top)
            if key == ord("g"):
                if last_key == ord("g"):
                    scroll.go_top()
                    last_key = -1
                else:
                    last_key = key
                continue
            last_key = -1

            if key in (27, ord("q")):  # Escape or 'q' to close
                break
            elif key in (ord("j"), ord("s"), curses.KEY_DOWN):
                scroll.scroll_down()
            elif key in (ord("k"), ord("w"), curses.KEY_UP):
                scroll.scroll_up()
            elif key == curses.KEY_NPAGE:  # Page Down
                scroll.page_down()
            elif key == curses.KEY_PPAGE:  # Page Up
                scroll.page_up()
            elif key == ord("G"):  # Go to bottom
                scroll.go_bottom()

    def run(self) -> bool:
        """Run the selection TUI. Returns True if user wants to execute, False to quit."""
        curses.curs_set(0)  # Hide cursor

        while True:
            self.draw()
            result = self.handle_input()
            if result == "execute":
                return True
            elif result == "quit":
                return False


###############################################################################
### Execution TUI
###############################################################################


@dataclass
class ScriptStatus:
    """Status of a script during execution."""

    section: Section
    script: Script
    status: ScriptStatusValue = "pending"
    output_lines: list[str] = field(default_factory=list)
    exit_code: int | None = None


class ExecutionTUI:
    """TUI for showing installation progress with live output."""

    def __init__(
        self,
        stdscr: curses.window,
        manifest: Manifest,
        scripts_dir: Path,
        dry_run: bool = False,
        headless: bool = False,
    ):
        self.stdscr = stdscr
        self.manifest = manifest
        self.scripts_dir = scripts_dir
        self.dry_run = dry_run
        self.headless = headless
        self.colors = init_colors()

        # Build status list from enabled scripts
        self.statuses: list[ScriptStatus] = []
        for section, script in manifest.get_enabled_scripts():
            self.statuses.append(ScriptStatus(section=section, script=script))

        # Execution progress tracking
        self.running_idx = 0  # Index of currently running (or last run) script
        self.viewing_idx = 0  # Index of script user is viewing (for log browsing)
        self.following = True  # When True, viewing_idx tracks running_idx automatically
        self.left_scroll = ScrollState()  # Script list scroll
        self.right_scroll = ScrollState()  # Output panel scroll
        self.cancelled = False
        self._last_key = -1  # For detecting 'gg' sequence
        self.focus_panel = "left"  # "left" (script list) or "right" (output)

    def _set_running_idx(self, idx: int) -> None:
        """Update running index, and viewing index if following."""
        self.running_idx = idx
        if self.following:
            self.viewing_idx = idx
            self.right_scroll.offset = 0  # Reset scroll when switching scripts

    def _handle_input_during_execution(self, key: int) -> None:
        """Handle keyboard input during script execution for log navigation.

        Allows users to browse logs of already-completed scripts while
        installation continues. Supports switching focus between left (script
        list) and right (output) panels for independent scrolling.
        """
        # Vim-style gg (go to top) - detect 'g' followed by 'g'
        if key == ord("g"):
            if self._last_key == ord("g"):
                if self.focus_panel == "left":
                    self.viewing_idx = 0
                    self.left_scroll.go_top()
                    self.following = False
                else:
                    self.right_scroll.go_top()
                    self.following = False
                self._last_key = -1
            else:
                self._last_key = key
            return
        self._last_key = -1

        # Panel switching keys
        if key in (ord("h"), ord("a"), curses.KEY_LEFT, 27):  # 27 = Esc
            self.focus_panel = "left"
            return
        elif key in (ord("l"), ord("d"), curses.KEY_RIGHT, curses.KEY_ENTER, 10, 13):
            self.focus_panel = "right"
            return

        # Navigation behavior depends on focused panel
        if self.focus_panel == "left":
            # Left panel: navigate script list
            if key in (ord("w"), ord("k"), curses.KEY_UP):
                if self.viewing_idx > 0:
                    self.viewing_idx -= 1
                    self.right_scroll.offset = 0  # Reset scroll for new script
                    self.following = False
            elif key in (ord("s"), ord("j"), curses.KEY_DOWN):
                if self.viewing_idx < len(self.statuses) - 1:
                    self.viewing_idx += 1
                    self.right_scroll.offset = 0
                # Resume following if we've navigated back to running script
                if self.viewing_idx == self.running_idx:
                    self.following = True
            elif key == curses.KEY_PPAGE:  # Page Up
                self.viewing_idx = max(
                    0, self.viewing_idx - max(1, self.left_scroll.visible - 1)
                )
                self.right_scroll.offset = 0
                self.following = False
            elif key == curses.KEY_NPAGE:  # Page Down
                self.viewing_idx = min(
                    len(self.statuses) - 1,
                    self.viewing_idx + max(1, self.left_scroll.visible - 1),
                )
                self.right_scroll.offset = 0
                if self.viewing_idx == self.running_idx:
                    self.following = True
            elif key == ord("G"):
                # Jump to running script and resume following
                self.viewing_idx = self.running_idx
                self.following = True
                self.right_scroll.offset = 0
        else:
            # Right panel: scroll output
            if key in (ord("w"), ord("k"), curses.KEY_UP):
                self.right_scroll.scroll_up()
                self.following = False  # Manual scroll disables auto-follow
            elif key in (ord("s"), ord("j"), curses.KEY_DOWN):
                self.right_scroll.scroll_down()
                self.following = False
            elif key == curses.KEY_PPAGE:  # Page Up
                self.right_scroll.page_up()
                self.following = False
            elif key == curses.KEY_NPAGE:  # Page Down
                self.right_scroll.page_down()
                self.following = False
            elif key == ord("G"):
                # Jump to bottom of output and resume following
                self.right_scroll.go_bottom()
                self.following = True
        # Note: 'q' is handled in the run() loop, not here

    def _poll_input(self) -> None:
        """Poll for and handle any pending keyboard input (non-blocking).

        Uses a short timeout to allow multi-byte escape sequences (arrow keys)
        to be read correctly while remaining responsive.
        """
        self.stdscr.timeout(50)  # 50ms timeout for escape sequences
        while True:
            key = self.stdscr.getch()
            if key == -1:
                break
            self._handle_input_during_execution(key)
        self.stdscr.timeout(-1)  # Restore blocking

    def draw(self) -> None:
        """Draw the execution screen."""
        self.stdscr.clear()
        height, width = self.stdscr.getmaxyx()

        # Draw header
        self.draw_header(width)

        # Draw script list (left side)
        list_width = min(40, width // 2)
        self.draw_script_list(height, list_width)

        # Draw output panel (right side)
        self.draw_output_panel(height, width, list_width)

        # Draw footer
        self.draw_footer(height, width)

        self.stdscr.refresh()

    def draw_header(self, width: int) -> None:
        """Draw the header with progress bar."""
        completed = sum(
            1 for s in self.statuses if s.status in ("success", "failed", "skipped")
        )
        total = len(self.statuses)

        if self.cancelled:
            title = " Installation Cancelled "
            title_color = self.colors["yellow"]
        elif completed == total:
            failed = sum(1 for s in self.statuses if s.status == "failed")
            if failed > 0:
                title = f" Installation Complete - {failed} Failed "
                title_color = self.colors["red"]
            else:
                title = " Installation Complete "
                title_color = self.colors["green"]
        else:
            title = f" Installing... [{completed}/{total}] "
            title_color = self.colors["cyan"]

        if self.dry_run:
            title = f" [DRY RUN]{title}"

        header_line = make_title_bar(title, width)
        self.stdscr.attron(title_color | self.colors["bold"])
        self.stdscr.addstr(0, 0, header_line[:width])
        self.stdscr.attroff(title_color | self.colors["bold"])

        # Draw progress bar on line 1
        bar_width = min(40, width - 20)
        if total > 0 and bar_width > 5:
            filled = int(bar_width * completed / total)
            bar = "█" * filled + "░" * (bar_width - filled)
            pct = int(100 * completed / total)
            progress_str = f" [{bar}] {pct:3d}% "
            try:
                self.stdscr.addstr(1, 2, progress_str[: width - 4], self.colors["cyan"])
            except curses.error:
                pass

    def draw_script_list(self, height: int, list_width: int) -> None:
        """Draw the list of scripts with status indicators."""
        # Scripts start at row 2 (after header rows 0-1)
        start_row = 2
        visible_height = height - 5  # Accounts for header (2) + footer (3)

        # Update scroll state
        self.left_scroll.total = len(self.statuses)
        self.left_scroll.visible = visible_height
        self.left_scroll.ensure_visible(self.viewing_idx)

        # Draw separator (reserve 1 column for scrollbar)
        scrollbar_x = list_width - 1
        separator_x = list_width
        for y in range(start_row, height - 3):
            try:
                self.stdscr.addch(y, separator_x, "│", self.colors["dim"])
            except curses.error:
                pass

        for i in range(visible_height):
            idx = self.left_scroll.offset + i
            if idx >= len(self.statuses):
                break

            status = self.statuses[idx]
            y = start_row + i
            is_viewing = idx == self.viewing_idx
            is_running = idx == self.running_idx
            # Reserve 1 column for scrollbar
            self.draw_status_line(y, list_width - 2, status, is_viewing, is_running)

        # Draw scrollbar with color based on focus
        scrollbar_color = (
            self.colors["cyan"] if self.focus_panel == "left" else self.colors["dim"]
        )
        draw_scrollbar(
            self.stdscr,
            x=scrollbar_x,
            y_start=start_row,
            height=visible_height,
            scroll=self.left_scroll,
            color=scrollbar_color,
        )

    def draw_status_line(
        self,
        y: int,
        width: int,
        status: ScriptStatus,
        is_viewing: bool,
        is_running: bool,
    ) -> None:
        """Draw a single script status line.

        Args:
            y: Row position to draw at.
            width: Available width for the line.
            status: The ScriptStatus object to display.
            is_viewing: Whether this is the script the user is currently viewing.
            is_running: Whether this is the currently running (or last run) script.
        """
        # Status indicator based on script execution state
        if status.status == "pending":
            indicator = "○"
            color = self.colors["dim"]
        elif status.status == "running":
            indicator = "▶"
            color = self.colors["cyan"]
        elif status.status == "success":
            indicator = "✓"
            color = self.colors["green"]
        elif status.status == "failed":
            indicator = "✗"
            color = self.colors["red"]
        else:  # skipped
            indicator = "○"
            color = self.colors["yellow"]

        # Show cursor marker for running script when user is viewing elsewhere
        cursor = "»" if is_running and not is_viewing else " "
        line = f"{cursor}{indicator} {status.script.display_name}"

        # Combine color with reverse highlight if this script is being viewed
        attr = color | self.colors["reverse"] if is_viewing else color
        self.stdscr.addstr(y, 0, line[:width].ljust(width), attr)

    def draw_output_panel(self, height: int, width: int, list_width: int) -> None:
        """Draw the live output panel for the currently viewed script."""
        panel_x = list_width + 1
        panel_width = width - list_width - 3  # Reserve 1 column for scrollbar
        panel_height = height - 5
        scrollbar_x = width - 1

        # Get viewed script's output
        if 0 <= self.viewing_idx < len(self.statuses):
            viewed = self.statuses[self.viewing_idx]
            raw_lines = viewed.output_lines
        else:
            raw_lines = []

        # Strip ANSI codes and wrap lines to panel width
        cleaned_lines = [strip_ansi(line) for line in raw_lines]
        wrapped_lines = wrap_lines(cleaned_lines, panel_width)

        # Update scroll state using wrapped line count
        self.right_scroll.total = len(wrapped_lines)
        self.right_scroll.visible = panel_height

        # Auto-scroll to bottom only when following the running script
        if self.following:
            self.right_scroll.go_bottom()
        else:
            self.right_scroll.clamp()

        # Draw output lines (starting at row 2, after header)
        start_row = 2
        for i in range(panel_height):
            line_idx = self.right_scroll.offset + i
            y = start_row + i

            # Clear the line area first
            try:
                self.stdscr.addstr(y, panel_x, " " * panel_width)
            except curses.error:
                pass

            if line_idx < len(wrapped_lines):
                line = wrapped_lines[line_idx]
                try:
                    self.stdscr.addstr(y, panel_x, line, self.colors["dim"])
                except curses.error:
                    pass

        # Draw scrollbar with color based on focus
        scrollbar_color = (
            self.colors["cyan"] if self.focus_panel == "right" else self.colors["dim"]
        )
        draw_scrollbar(
            self.stdscr,
            x=scrollbar_x,
            y_start=start_row,
            height=panel_height,
            scroll=self.right_scroll,
            color=scrollbar_color,
        )

    def draw_footer(self, height: int, width: int) -> None:
        """Draw the footer with navigation hints."""
        footer_y = height - 3

        # Separator
        self.stdscr.addstr(footer_y, 0, "─" * width, self.colors["dim"])

        # Status line showing viewed script and focused panel
        if self.viewing_idx < len(self.statuses):
            viewed = self.statuses[self.viewing_idx]
            panel_indicator = "◀ scripts" if self.focus_panel == "left" else "output ▶"
            status_text = f" {viewed.section.name} / {viewed.script.display_name} [{panel_indicator}]"
            if not self.following:
                status_text += " (browsing)"
        else:
            status_text = " Complete "

        self.stdscr.addstr(
            footer_y + 1, 2, status_text[: width - 4], self.colors["cyan"]
        )

        # Controls with navigation hints
        controls = (
            " [h/l] Panel   [j/k] Scroll   [PgUp/Dn]   [gg/G] Top/Bottom   [q] Quit "
        )
        self.stdscr.addstr(footer_y + 2, 2, controls[: width - 4], self.colors["dim"])

    def _execute_script(self, status: ScriptStatus, silent: bool = False) -> bool:
        """Execute a script and update its status.

        Args:
            status: ScriptStatus object to update.
            silent: If True, capture output without PTY (for parallel execution).
                   If False, use PTY for live output with display updates.

        Returns:
            True on success, False on failure.
        """
        script_path = self.scripts_dir / status.script.path

        if not script_path.exists() or not os.access(script_path, os.X_OK):
            status.output_lines.append(
                f"Script not found or not executable: {script_path}"
            )
            status.status = "failed"
            status.exit_code = 1
            return False

        env = prepare_script_env(self.dry_run, self.headless)
        bash_cmd = build_script_command(self.scripts_dir, script_path)

        try:
            if silent:
                # Batch capture for parallel execution
                result = subprocess.run(
                    ["bash", "-c", bash_cmd],
                    env=env,
                    cwd=self.scripts_dir.parent,
                    capture_output=True,
                    text=True,
                    timeout=600,  # 10 minute timeout
                )
                status.exit_code = result.returncode
                if result.stdout:
                    status.output_lines.extend(result.stdout.strip().split("\n"))
                if result.stderr:
                    status.output_lines.extend(result.stderr.strip().split("\n"))
            else:
                # PTY for live output with display updates and keyboard input
                master_fd, slave_fd = pty.openpty()
                process = subprocess.Popen(
                    ["bash", "-c", bash_cmd],
                    stdout=slave_fd,
                    stderr=slave_fd,
                    stdin=subprocess.DEVNULL,
                    env=env,
                    cwd=self.scripts_dir.parent,
                )
                os.close(slave_fd)

                # Enable non-blocking keyboard input with short timeout for escape sequences
                self.stdscr.timeout(50)  # 50ms allows arrow key sequences to be read

                # Read output with non-blocking I/O
                while True:
                    retcode = process.poll()

                    # Poll for keyboard input (non-blocking with timeout)
                    key = self.stdscr.getch()
                    if key != -1:
                        self._handle_input_during_execution(key)
                        self.draw()

                    ready, _, _ = select.select([master_fd], [], [], 0.05)
                    if ready:
                        try:
                            data = os.read(master_fd, 4096)
                            if data:
                                text = data.decode("utf-8", errors="replace")
                                for line in text.split("\n"):
                                    if line:
                                        status.output_lines.append(line)
                                self.draw()
                        except OSError:
                            break
                    if retcode is not None:
                        # Drain remaining output
                        while True:
                            ready, _, _ = select.select([master_fd], [], [], 0)
                            if not ready:
                                break
                            try:
                                data = os.read(master_fd, 4096)
                                if not data:
                                    break
                                for line in data.decode(
                                    "utf-8", errors="replace"
                                ).split("\n"):
                                    if line:
                                        status.output_lines.append(line)
                            except OSError:
                                break
                        break

                os.close(master_fd)
                self.stdscr.timeout(-1)  # Restore blocking input
                status.exit_code = process.returncode

            # Update status based on exit code
            if status.exit_code == 0:
                status.status = "success"
                return True
            else:
                status.status = "failed"
                return False

        except subprocess.TimeoutExpired:
            status.output_lines.append("Script timed out after 10 minutes")
            status.status = "failed"
            status.exit_code = 124
            return False
        except Exception as e:
            status.output_lines.append(f"Error: {e}")
            status.status = "failed"
            status.exit_code = 1
            return False

    def run_script(self, status: ScriptStatus) -> bool:
        """Run a single script with live output capture. Returns True on success."""
        status.status = "running"
        self.draw()
        return self._execute_script(status, silent=False)

    def _group_by_parallelism(self) -> list[list[ScriptStatus]]:
        """Group consecutive scripts by whether they can run in parallel.

        Returns list of groups where each group is either:
        - A single non-parallel script, or
        - Multiple parallel-safe scripts that can run concurrently
        """
        groups: list[list[ScriptStatus]] = []
        current_group: list[ScriptStatus] = []
        current_is_parallel = False

        for status in self.statuses:
            is_parallel = status.script.is_parallel
            if not current_group:
                current_group = [status]
                current_is_parallel = is_parallel
            elif is_parallel and current_is_parallel:
                # Continue parallel group
                current_group.append(status)
            else:
                # Different parallelism - start new group
                groups.append(current_group)
                current_group = [status]
                current_is_parallel = is_parallel

        if current_group:
            groups.append(current_group)

        return groups

    def run(self) -> tuple[int, int]:
        """Run all selected scripts, parallelizing where safe.

        Returns (success_count, fail_count).
        """
        curses.curs_set(0)
        self.stdscr.keypad(True)  # Enable arrow key recognition

        success_count = 0
        fail_count = 0

        try:
            groups = self._group_by_parallelism()

            for group in groups:
                if self.cancelled:
                    for status in group:
                        status.status = "skipped"
                    continue

                # Check if this is a parallel group (multiple parallel-safe scripts)
                is_parallel_group = len(group) > 1 and all(
                    s.script.is_parallel for s in group
                )

                if is_parallel_group:
                    # Run group in parallel
                    for status in group:
                        status.status = "running"
                    self._set_running_idx(self.statuses.index(group[0]))
                    self._poll_input()
                    self.draw()

                    with concurrent.futures.ThreadPoolExecutor(
                        max_workers=4
                    ) as executor:
                        futures = {
                            executor.submit(self._run_script_silent, s): s
                            for s in group
                        }
                        for future in concurrent.futures.as_completed(futures):
                            status = futures[future]
                            self._set_running_idx(self.statuses.index(status))
                            try:
                                if future.result():
                                    success_count += 1
                                else:
                                    fail_count += 1
                            except Exception:
                                status.status = "failed"
                                fail_count += 1
                            self._poll_input()
                            self.draw()
                else:
                    # Run sequentially
                    for status in group:
                        if self.cancelled:
                            status.status = "skipped"
                            continue

                        self._set_running_idx(self.statuses.index(status))
                        self._poll_input()
                        self.draw()

                        if self.run_script(status):
                            success_count += 1
                        else:
                            fail_count += 1

                        self._poll_input()
                        self.draw()

        except KeyboardInterrupt:
            self.cancelled = True
            # Mark remaining as skipped
            for status in self.statuses:
                if status.status in ("pending", "running"):
                    status.status = "skipped"

        # Final draw and allow browsing until 'q' is pressed
        self.draw()

        # Allow user to continue browsing logs after completion
        self.stdscr.timeout(-1)  # Blocking input
        while True:
            key = self.stdscr.getch()
            if key == ord("q"):
                break
            self._handle_input_during_execution(key)
            self.draw()

        return success_count, fail_count

    def _run_script_silent(self, status: ScriptStatus) -> bool:
        """Run a script without display updates (for parallel execution)."""
        return self._execute_script(status, silent=True)


###############################################################################
### Main Entry Point
###############################################################################


def get_script_dir() -> Path:
    """Get the directory containing this script."""
    return Path(__file__).parent.resolve()


def run_interactive(
    stdscr: curses.window, manifest: Manifest, scripts_dir: Path, dry_run: bool
) -> int:
    """Run the interactive TUI. Returns exit code."""
    # Selection phase
    selection_tui = SelectionTUI(stdscr, manifest, scripts_dir)
    if not selection_tui.run():
        return 0  # User quit

    # Check if any scripts selected
    enabled = manifest.get_enabled_scripts()
    if not enabled:
        return 0

    # Prompt for sudo if needed (exit curses temporarily)
    curses.endwin()
    if not prompt_sudo_if_needed(enabled):
        return 0  # User cancelled
    stdscr.refresh()  # Restore curses screen

    # Determine if headless mode based on selected preset
    headless = is_headless_preset(selection_tui.current_preset)

    # Execution phase
    execution_tui = ExecutionTUI(stdscr, manifest, scripts_dir, dry_run, headless)
    success, fail = execution_tui.run()

    return 1 if fail > 0 else 0


def run_non_interactive(
    manifest: Manifest, scripts_dir: Path, dry_run: bool, headless: bool = False
) -> int:
    """Run scripts without TUI. Returns exit code."""
    enabled = manifest.get_enabled_scripts()
    if not enabled:
        print("No scripts selected.")
        return 0

    # Prompt for sudo if needed
    if not prompt_sudo_if_needed(enabled):
        return 0  # User cancelled

    print(f"\n{'=' * 60}")
    print(f" Installing {len(enabled)} components...")
    if headless:
        print(" (Headless mode - skipping GUI packages)")
    print(f"{'=' * 60}\n")

    env = prepare_script_env(dry_run, headless)

    success = 0
    fail = 0

    for section, script in enabled:
        script_path = scripts_dir / script.path
        print(f"▶ {script.display_name}...", end=" ", flush=True)

        if not script_path.exists() or not os.access(script_path, os.X_OK):
            print("✗ (not found or not executable)")
            fail += 1
            continue

        try:
            result = run_script_simple(script_path, scripts_dir, env)
            if result.returncode == 0:
                print("✓")
                success += 1
            else:
                print("✗")
                if result.stderr:
                    for line in result.stderr.strip().split("\n")[:5]:
                        print(f"    {line}")
                fail += 1
        except Exception as e:
            print(f"✗ ({e})")
            fail += 1

    print(f"\n{'=' * 60}")
    print(f" Complete: {success} succeeded, {fail} failed")
    print(f"{'=' * 60}\n")

    return 1 if fail > 0 else 0


def list_presets() -> None:
    """Print available presets."""
    print("\nAvailable presets:\n")
    for key, preset in PRESETS.items():
        print(f"  [{key}] {preset.description}")
        if preset.disabled_sections:
            print(f"       Disables sections: {', '.join(preset.disabled_sections)}")
        if preset.flags:
            flag_desc = []
            if "no_sudo" in preset.flags:
                flag_desc.append("scripts requiring sudo")
            if "headless" in preset.flags:
                flag_desc.append("GUI-only scripts")
            if flag_desc:
                print(f"       Disables: {', '.join(flag_desc)}")
    print()


###############################################################################
### Export/Import
###############################################################################


def export_selections(manifest: Manifest, output_path: Path) -> None:
    """Export current script selections to a JSON file."""
    scripts = [script.path for _, script in manifest.get_enabled_scripts()]
    data = {
        "version": 1,
        "description": "peter-terminal-utils selection export",
        "scripts": scripts,
    }
    with open(output_path, "w") as f:
        json.dump(data, f, indent=2)
    print(f"Exported {len(scripts)} selections to {output_path}")


def import_selections(manifest: Manifest, input_path: Path) -> None:
    """Import script selections from a JSON file."""
    with open(input_path) as f:
        data = json.load(f)

    if data.get("version") != 1:
        print(f"Warning: Unknown export version {data.get('version')}", file=sys.stderr)

    enabled_paths = set(data.get("scripts", []))

    # Disable all, then enable only those in the import
    for section in manifest.sections:
        for script in section.scripts:
            script.enabled = script.path in enabled_paths

    enabled_count = len(manifest.get_enabled_scripts())
    print(f"Imported selections: {enabled_count} scripts enabled")


###############################################################################
### Documentation Generation
###############################################################################


def generate_docs(manifest: Manifest) -> None:
    """Generate markdown documentation from script metadata."""
    print("# Install Scripts")
    print()
    print("Auto-generated documentation from script `@metadata` headers.")
    print()

    for section in manifest.sections:
        print(f"## {section.name}")
        print()
        print("| Script | Description | Requirements |")
        print("|--------|-------------|--------------|")

        for script in section.scripts:
            name = script.display_name
            desc = script.description or "-"
            reqs = []
            if script.requires_sudo:
                reqs.append("sudo")
            if script.is_headless_skip:
                reqs.append("GUI")
            req_str = ", ".join(reqs) if reqs else "-"
            print(f"| {name} | {desc} | {req_str} |")

        print()


def main() -> int:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Peter Sharpe's Linux Setup - Interactive TUI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  setup                    Interactive TUI mode
  setup --preset 1         Non-interactive with Desktop preset
  setup --preset 2         Non-interactive with Headless preset
  setup --list             Show available presets
  setup --dry-run          Preview changes without making them
  setup --export sel.json  Export current selections
  setup --import sel.json  Import selections from file
  setup --docs             Generate markdown documentation
""",
    )
    parser.add_argument(
        "-p",
        "--preset",
        metavar="N",
        help="Apply preset N and run non-interactively",
    )
    parser.add_argument(
        "-l",
        "--list",
        action="store_true",
        help="List available presets",
    )
    parser.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="Dry run mode (preview changes)",
    )
    parser.add_argument(
        "--export",
        metavar="FILE",
        help="Export current selections to JSON file",
    )
    parser.add_argument(
        "--import",
        dest="import_file",
        metavar="FILE",
        help="Import selections from JSON file",
    )
    parser.add_argument(
        "--docs",
        action="store_true",
        help="Generate markdown documentation from script metadata",
    )

    args = parser.parse_args()

    # Find paths
    script_dir = get_script_dir()
    manifest_path = script_dir / "install_scripts" / "manifest.conf"
    scripts_dir = script_dir / "install_scripts"

    if not manifest_path.exists():
        print(f"Error: Manifest not found: {manifest_path}", file=sys.stderr)
        return 1

    # List presets
    if args.list:
        list_presets()
        return 0

    # Parse manifest (with metadata)
    manifest = parse_manifest(manifest_path, scripts_dir)

    # Generate documentation
    if args.docs:
        generate_docs(manifest)
        return 0

    # Export selections
    if args.export:
        # Apply preset if specified, otherwise use preset 1 (all enabled)
        if args.preset:
            apply_preset(manifest, args.preset)
        else:
            apply_preset(manifest, "1")
        export_selections(manifest, Path(args.export))
        return 0

    # Import selections
    if args.import_file:
        import_path = Path(args.import_file)
        if not import_path.exists():
            print(f"Error: Import file not found: {import_path}", file=sys.stderr)
            return 1
        import_selections(manifest, import_path)
        # When importing, check if HEADLESS was set in environment or default to N
        headless = os.environ.get("HEADLESS", "N") == "Y"
        return run_non_interactive(manifest, scripts_dir, args.dry_run, headless)

    # Non-interactive mode with preset
    if args.preset:
        if args.preset not in PRESETS:
            print(f"Error: Unknown preset '{args.preset}'", file=sys.stderr)
            print("Use --list to see available presets.", file=sys.stderr)
            return 1
        apply_preset(manifest, args.preset)
        headless = is_headless_preset(args.preset)
        return run_non_interactive(manifest, scripts_dir, args.dry_run, headless)

    # Interactive mode
    try:
        return curses.wrapper(
            lambda stdscr: run_interactive(stdscr, manifest, scripts_dir, args.dry_run)
        )
    except KeyboardInterrupt:
        print("\nCancelled.")
        return 130


if __name__ == "__main__":
    sys.exit(main())
