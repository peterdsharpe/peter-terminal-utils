#!/usr/bin/env python3
"""
Peter Sharpe's Linux Setup Script - Interactive TUI

A curses-based terminal interface for selecting and installing system components.
Parses install_scripts/manifest.conf and provides interactive selection with presets.

Usage:
    setup                       # Interactive TUI mode
    setup --preset 1            # Non-interactive: Desktop preset
    setup --preset 2            # Non-interactive: Headless preset
    setup --preset 2 --verbose  # Stream live output (for Docker/CI)
    setup --list                # Show available presets
    setup --dry-run             # Dry run mode
    setup --help                # Show help
"""

import argparse
import concurrent.futures
import curses
import json
import math
import os
import pty
import re
import select
import subprocess
import sys
import threading
import time
import tomllib
from dataclasses import dataclass, field
from enum import Enum
from itertools import batched, chain
from pathlib import Path
from typing import Callable, Literal, NamedTuple, Self

# Type aliases for literal values
SectionState = Literal["all", "none", "partial"]
ColorName = Literal[
    "green", "yellow", "cyan", "red", "blue", "header", "dim", "bold", "reverse"
]


class ScriptState(Enum):
    """Script execution state with display properties.

    Each state carries its indicator character, color name, and priority
    (lower priority = worse status for "worst wins" aggregation).
    """

    PENDING = ("○", "dim", 3)
    RUNNING = ("⠋", "cyan", 2)  # Spinner frame overrides at runtime
    SUCCESS = ("✓", "green", 4)
    FAILED = ("✗", "red", 0)
    SKIPPED = ("○", "yellow", 1)

    def __init__(self, indicator: str, color_name: ColorName, priority: int):
        self.indicator = indicator
        self.color_name = color_name
        self.priority = priority


# States that count as "completed" for progress tracking
COMPLETED_STATES = frozenset(
    {ScriptState.SUCCESS, ScriptState.FAILED, ScriptState.SKIPPED}
)

# Regex to match ANSI escape sequences
ANSI_ESCAPE_RE = re.compile(r"\x1b\[[0-9;]*[a-zA-Z]|\x1b\][^\x07]*\x07|\x1b[()][AB012]")

# Control characters to strip (carriage return, bell, etc.) - excluding newline and tab
CONTROL_CHARS = str.maketrans(
    "", "", "\r\x00\x01\x02\x03\x04\x05\x06\x07\x08\x0b\x0c\x0e\x0f"
)


###############################################################################
### Configuration Loading
###############################################################################


def load_config(config_path: Path) -> dict:
    """Load configuration from TOML file.

    Returns:
        Parsed config dict with 'user' and 'presets' sections.
    """
    with open(config_path, "rb") as f:
        return tomllib.load(f)


def get_config_path() -> Path:
    """Get path to config.toml (same directory as this script)."""
    return Path(__file__).parent / "config.toml"


# Load configuration at module level
_CONFIG = load_config(get_config_path())

# User defaults from config
DEFAULT_GIT_NAME = _CONFIG["user"]["git_name"]
DEFAULT_GIT_EMAIL = _CONFIG["user"]["git_email"]


def strip_ansi(text: str) -> str:
    """Remove ANSI escape sequences and control characters from text.

    Strips ANSI color codes, cursor movement sequences, and control characters
    like carriage return that could corrupt curses display.
    """
    text = ANSI_ESCAPE_RE.sub("", text)
    return text.translate(CONTROL_CHARS)


WRAP_INDICATOR = "↩"


def wrap_line(line: str, width: int, indent: int = 2) -> list[str]:
    """Hard-wrap a line to the given width with visual continuation indicators.

    Wrapped lines end with a continuation indicator (↩), and continuation lines
    are indented by the specified amount.

    For very small widths, falls back to basic wrapping without indicators.

    Args:
        line: The line to wrap.
        width: Maximum width per wrapped segment.
        indent: Number of spaces to indent continuation lines. Defaults to 2.

    Returns:
        List of wrapped line segments. Empty or short lines return as single-element list.
    """
    if not line or width <= 0:
        return [line]
    if len(line) <= width:
        return [line]

    wrap_indent = " " * indent

    # Fall back to basic wrapping for very small widths where indicators don't fit
    if width <= indent + 1:
        result = []
        while len(line) > width:
            result.append(line[:width])
            line = line[width:]
        result.append(line)
        return result

    result = []

    # First segment: width - 1 chars + wrap indicator
    first_content_width = width - 1
    result.append(line[:first_content_width] + WRAP_INDICATOR)
    line = line[first_content_width:]

    # Continuation segments: indent + content + optional wrap indicator
    continuation_width = width - indent - 1  # space for indent and indicator

    while len(line) > width - indent:
        result.append(wrap_indent + line[:continuation_width] + WRAP_INDICATOR)
        line = line[continuation_width:]

    # Final segment: indent + remaining (no indicator)
    result.append(wrap_indent + line)
    return result


def wrap_lines(lines: list[str], width: int, indent: int = 2) -> list[str]:
    """Wrap multiple lines to a given width, expanding tabs.

    Each input line is processed: tabs expanded to 4 spaces, trailing whitespace
    stripped, then hard-wrapped to fit within width.

    Args:
        lines: List of lines to wrap.
        width: Maximum width per wrapped segment.
        indent: Number of spaces to indent continuation lines. Defaults to 2.

    Returns:
        Flattened list of wrapped line segments.
    """
    result = []
    for line in lines:
        cleaned = line.expandtabs(4).rstrip()
        result.extend(wrap_line(cleaned, width, indent))
    return result


###############################################################################
### Scroll State
###############################################################################


@dataclass
class ScrollState:
    """Manages scroll position for a scrollable panel.

    Tracks offset (first visible item), total items, and visible height.
    Provides methods for navigation and ensures offset stays in valid range.
    """

    offset: int = 0  # Index of first visible item
    total: int = 0  # Total number of items
    visible: int = 0  # Number of items that fit in the view

    def clamp(self) -> None:
        """Ensure offset is within valid range."""
        max_offset = max(0, self.total - self.visible)
        self.offset = max(0, min(self.offset, max_offset))

    def scroll_up(self, n: int = 1) -> None:
        """Scroll up by n items."""
        self.offset -= n
        self.clamp()

    def scroll_down(self, n: int = 1) -> None:
        """Scroll down by n items."""
        self.offset += n
        self.clamp()

    def page_up(self) -> None:
        """Scroll up by one page."""
        self.scroll_up(max(1, self.visible - 1))

    def page_down(self) -> None:
        """Scroll down by one page."""
        self.scroll_down(max(1, self.visible - 1))

    def go_top(self) -> None:
        """Scroll to the top."""
        self.offset = 0

    def go_bottom(self) -> None:
        """Scroll to the bottom."""
        self.offset = max(0, self.total - self.visible)

    def ensure_visible(self, idx: int) -> None:
        """Adjust offset to ensure item at idx is visible."""
        if idx < self.offset:
            self.offset = idx
        elif idx >= self.offset + self.visible:
            self.offset = idx - self.visible + 1
        self.clamp()

    def set_from_scrollbar_click(self, click_y: int, y_start: int, height: int) -> None:
        """Set scroll offset based on a click position in the scrollbar track.

        Maps the click position to a scroll offset proportionally.

        Args:
            click_y: The y-coordinate of the click.
            y_start: The starting y-coordinate of the scrollbar.
            height: The height of the scrollbar area.
        """
        if height <= 1 or self.total <= self.visible:
            return
        relative_y = click_y - y_start
        max_offset = max(1, self.total - self.visible)
        self.offset = int(relative_y * max_offset / (height - 1))
        self.clamp()


@dataclass
class DragState:
    """Track mouse drag state for scrollbar interaction.

    Used to implement click-and-drag scrolling on scrollbar thumbs.
    """

    active: bool = False
    panel: str = ""  # "left", "right", or "main"
    start_offset: int = 0
    start_y: int = 0


@dataclass
class VimNavHandler:
    """Handles vim-style navigation with gg detection for scrollable content.

    Tracks the last key pressed to detect the 'gg' sequence (go to top).
    Call `handle()` with each key; it returns True if the key was consumed.
    """

    _last_key: int = field(default=-1, repr=False)

    def handle(self, key: int, scroll: ScrollState) -> bool:
        """Handle navigation key, updating scroll state.

        Args:
            key: The curses key code.
            scroll: The ScrollState to modify.

        Returns:
            True if the key was consumed (navigation key), False otherwise.
        """
        # Vim-style gg (go to top) - detect 'g' followed by 'g'
        if key == ord("g"):
            if self._last_key == ord("g"):
                scroll.go_top()
                self._last_key = -1
                return True
            self._last_key = key
            return True  # Consumed (waiting for second g)

        # Reset last_key for non-g keys
        self._last_key = -1

        if key == ord("G"):
            scroll.go_bottom()
            return True
        if key in (ord("j"), ord("s"), curses.KEY_DOWN):
            scroll.scroll_down()
            return True
        if key in (ord("k"), ord("w"), curses.KEY_UP):
            scroll.scroll_up()
            return True
        if key == curses.KEY_NPAGE:
            scroll.page_down()
            return True
        if key == curses.KEY_PPAGE:
            scroll.page_up()
            return True

        return False

    def reset(self) -> None:
        """Reset the last key state (use when exiting a context)."""
        self._last_key = -1


###############################################################################
### Braille Spinner
###############################################################################

# Braille spinner frames - the same pattern uv uses for a smooth spinning effect
BRAILLE_FRAMES = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"


@dataclass
class BrailleSpinner:
    """A braille-based spinner for loading animations.

    Provides smooth spinning animation using braille pattern characters,
    similar to the style used by uv during package installation.
    Call `frame()` to get frame based on elapsed time.
    """

    interval: float = 0.08
    _start_time: float = field(default_factory=time.monotonic, init=False, repr=False)

    def frame(self) -> str:
        """Get current frame based on elapsed time."""
        elapsed = time.monotonic() - self._start_time
        return BRAILLE_FRAMES[int(elapsed / self.interval) % len(BRAILLE_FRAMES)]

    def reset(self) -> None:
        """Reset spinner to initial state."""
        self._start_time = time.monotonic()


@dataclass
class ThreadedSpinner:
    """A threaded spinner for non-curses console output.

    Displays a braille spinner on the current line while a task runs.
    Uses carriage return to update the spinner in place.

    When stdout is not a TTY (e.g., in Docker containers or piped output),
    the animation is disabled and only static messages are shown.
    """

    message: str = ""
    spinner: BrailleSpinner = field(default_factory=BrailleSpinner)
    _stop_event: threading.Event = field(default_factory=threading.Event, init=False)
    _thread: threading.Thread | None = field(default=None, init=False, repr=False)
    _is_tty: bool = field(init=False, repr=False)

    def __post_init__(self) -> None:
        self._is_tty = sys.stdout.isatty()

    def _spin(self) -> None:
        """Spinner thread target. Continuously updates the spinner character."""
        while not self._stop_event.is_set():
            frame = self.spinner.frame()
            sys.stdout.write(f"\r{frame} {self.message}")
            sys.stdout.flush()
            time.sleep(0.08)

    def start(self) -> None:
        """Start the spinner animation in a background thread."""
        if not self._is_tty:
            sys.stdout.write(f"  {self.message}")
            sys.stdout.flush()
            return

        self._stop_event.clear()
        self._thread = threading.Thread(target=self._spin, daemon=True)
        self._thread.start()

    def stop(self, final_char: str = "", clear: bool = False) -> None:
        """Stop the spinner and optionally display a final status.

        Args:
            final_char: Character to display in place of spinner (e.g., "✓" or "✗").
            clear: If True, clear the entire line instead of showing final_char.

        Note:
            This method handles the newline internally. Callers should not add
            additional newlines after calling stop() with a final_char.
        """
        self._stop_event.set()
        if self._thread:
            self._thread.join(timeout=0.5)
            self._thread = None

        if not self._is_tty:
            if not clear and final_char:
                sys.stdout.write(f" {final_char}\n")
            elif not clear:
                sys.stdout.write("\n")
            sys.stdout.flush()
            return

        if clear:
            sys.stdout.write(f"\r{' ' * (len(self.message) + 4)}\r")
        elif final_char:
            sys.stdout.write(f"\r{final_char} {self.message}\n")
        sys.stdout.flush()


###############################################################################
### Data Model
###############################################################################


@dataclass
class Script:
    """A single install script."""

    name: str  # Display name (e.g., "apt_packages")
    path: str  # Relative path from install_scripts/ (e.g., "system_packages/apt_packages.sh")
    enabled: bool = True
    metadata: dict[str, str] = field(default_factory=dict)

    @property
    def display_name(self) -> str:
        """Human-readable name from @name metadata, or derived from filename."""
        return self.metadata.get("name", self.name.replace("_", " ").title())

    @property
    def description(self) -> str:
        """Script description from @description metadata."""
        return self.metadata.get("description", "")

    @property
    def requires_sudo(self) -> bool:
        """Whether script requires sudo (from @requires metadata)."""
        return "sudo" in self.metadata.get("requires", "")

    @property
    def is_parallel(self) -> bool:
        """Whether script can run in parallel (default: true, use @parallel: false to disable)."""
        return self.metadata.get("parallel", "true").lower() != "false"

    @property
    def is_headless_skip(self) -> bool:
        """Whether script should be skipped in headless mode."""
        return self.metadata.get("headless", "").lower() == "skip"

    @property
    def dependencies(self) -> list[str]:
        """List of script names this script depends on (from @depends metadata)."""
        depends_str = self.metadata.get("depends", "")
        if not depends_str:
            return []
        # Parse comma-separated list, strip .sh extension if present
        return [d.strip().removesuffix(".sh") for d in depends_str.split(",")]

    @property
    def locks(self) -> set[str]:
        """Resource locks this script requires exclusively (from @locks metadata).

        Scripts with the same lock cannot run simultaneously.
        Common locks: 'pkg' (package manager), 'cargo', 'fonts'.
        """
        locks_str = self.metadata.get("locks", "")
        return {lock.strip() for lock in locks_str.split(",") if lock.strip()}

    @property
    def resource_type(self) -> str:
        """Resource type affecting concurrency (from @resource metadata).

        - 'network': I/O bound, allows high concurrency
        - 'cpu': Compute bound, limited to CPU count
        - 'mixed' (default): Moderate concurrency
        """
        return self.metadata.get("resource", "mixed")

    @staticmethod
    def parse_metadata(script_path: Path) -> dict[str, str]:
        """Extract @key: value metadata from script header comments.

        Parses lines like:
            # @name: bat
            # @description: Modern cat replacement
            # @requires: sudo

        Args:
            script_path: Path to the script file.

        Returns:
            Dictionary of metadata key-value pairs.
        """
        metadata: dict[str, str] = {}
        try:
            with open(script_path) as f:
                for line in f:
                    line = line.strip()
                    # Stop at first non-comment, non-shebang, non-empty line
                    if line and not line.startswith("#"):
                        break
                    # Parse @key: value pattern
                    if match := re.match(r"^#\s*@(\w+):\s*(.+)$", line):
                        metadata[match.group(1)] = match.group(2).strip()
        except (OSError, IOError):
            pass  # File not readable, return empty metadata
        return metadata


@dataclass
class Section:
    """A section containing multiple scripts."""

    name: str
    scripts: list[Script] = field(default_factory=list)

    @property
    def state(self) -> SectionState:
        """Returns 'all', 'none', or 'partial' based on enabled scripts."""
        enabled_count = sum(1 for s in self.scripts if s.enabled)
        if enabled_count == len(self.scripts):
            return "all"
        elif enabled_count == 0:
            return "none"
        else:
            return "partial"

    def set_all(self, enabled: bool) -> None:
        """Set all scripts to enabled or disabled."""
        for script in self.scripts:
            script.enabled = enabled

    def toggle(self) -> None:
        """Toggle section: if any enabled, disable all; otherwise enable all."""
        if self.state == "none":
            self.set_all(True)
        else:
            self.set_all(False)


@dataclass
class Manifest:
    """The complete manifest of sections and scripts."""

    sections: list[Section] = field(default_factory=list)
    dep_graph: "DependencyGraph | None" = field(default=None, repr=False)

    def get_enabled_scripts(self) -> list[tuple[Section, Script]]:
        """Return list of (section, script) tuples for enabled scripts."""
        return [
            (section, script)
            for section in self.sections
            for script in section.scripts
            if script.enabled
        ]

    def get_flat_items(self) -> list[Section | Script]:
        """Return flat list of sections and scripts for navigation."""
        return list(
            chain.from_iterable(
                (section, *section.scripts) for section in self.sections
            )
        )

    def get_script_order(self) -> dict[str, int]:
        """Return dict mapping script names to their order index in the manifest."""
        order: dict[str, int] = {}
        idx = 0
        for section in self.sections:
            for script in section.scripts:
                order[script.name] = idx
                idx += 1
        return order

    def get_script_by_name(self, name: str) -> Script | None:
        """Find a script by its name (stem without .sh)."""
        for section in self.sections:
            for script in section.scripts:
                if script.name == name:
                    return script
        return None

    @classmethod
    def from_file(cls, manifest_path: Path, scripts_dir: Path | None = None) -> Self:
        """Parse INI-style manifest.conf into a Manifest object.

        Args:
            manifest_path: Path to the manifest.conf file.
            scripts_dir: Directory containing install scripts. Defaults to
                the same directory as manifest_path.

        Returns:
            Parsed Manifest with sections, scripts, and dependency graph.
        """
        manifest = cls()
        current_section: Section | None = None

        # Default scripts_dir to same directory as manifest
        if scripts_dir is None:
            scripts_dir = manifest_path.parent

        with open(manifest_path) as f:
            for line in f:
                line = line.strip()

                # Skip empty lines and comments
                if not line or line.startswith("#"):
                    continue

                # Section header: [Section Name]
                if line.startswith("[") and line.endswith("]"):
                    section_name = line[1:-1]
                    current_section = Section(name=section_name)
                    manifest.sections.append(current_section)
                elif current_section is not None:
                    # Script path
                    script_path = line
                    # Extract script name from path (remove directory and .sh)
                    script_name = Path(script_path).stem
                    # Load metadata from script file
                    metadata = Script.parse_metadata(scripts_dir / script_path)
                    current_section.scripts.append(
                        Script(name=script_name, path=script_path, metadata=metadata)
                    )

        # Build dependency graph after all scripts are loaded
        manifest.dep_graph = DependencyGraph.from_manifest(manifest)

        return manifest

    def apply_preset(self, preset_key: str) -> None:
        """Apply a preset to this manifest, enabling/disabling sections and scripts.

        Uses script metadata (@requires, @headless) to determine what to disable.

        Args:
            preset_key: The preset key (e.g., "1", "2") to apply.
        """
        if preset_key not in PRESETS:
            return

        preset = PRESETS[preset_key]

        # Handle "empty" preset - disable everything for manual selection
        if "empty" in preset.flags:
            for section in self.sections:
                section.set_all(False)
            return

        # First, enable everything
        for section in self.sections:
            section.set_all(True)

        # Disable specified sections
        for section in self.sections:
            if section.name in preset.disabled_sections:
                section.set_all(False)

        # Apply flags based on script metadata
        for section in self.sections:
            for script in section.scripts:
                # Disable sudo-requiring scripts if no_sudo flag set
                if "no_sudo" in preset.flags and script.requires_sudo:
                    script.enabled = False
                # Disable headless-skip scripts if headless flag set
                if "headless" in preset.flags and script.is_headless_skip:
                    script.enabled = False

    def export_selections(self, output_path: Path) -> None:
        """Export current script selections to a JSON file.

        Args:
            output_path: Path to write the JSON file.
        """
        scripts = [script.path for _, script in self.get_enabled_scripts()]
        data = {
            "version": 1,
            "description": "peter-terminal-utils selection export",
            "scripts": scripts,
        }
        with open(output_path, "w") as f:
            json.dump(data, f, indent=2)
        print(f"Exported {len(scripts)} selections to {output_path}")

    def import_selections(self, input_path: Path) -> None:
        """Import script selections from a JSON file.

        Args:
            input_path: Path to the JSON file to import.
        """
        with open(input_path) as f:
            data = json.load(f)

        if data.get("version") != 1:
            print(
                f"Warning: Unknown export version {data.get('version')}",
                file=sys.stderr,
            )

        enabled_paths = set(data.get("scripts", []))

        # Disable all, then enable only those in the import
        for section in self.sections:
            for script in section.scripts:
                script.enabled = script.path in enabled_paths

        enabled_count = len(self.get_enabled_scripts())
        print(f"Imported selections: {enabled_count} scripts enabled")

    def generate_docs(self) -> None:
        """Generate markdown documentation from script metadata to stdout."""
        print("# Install Scripts")
        print()
        print("Auto-generated documentation from script `@metadata` headers.")
        print()

        for section in self.sections:
            print(f"## {section.name}")
            print()
            print("| Script | Description | Requirements |")
            print("|--------|-------------|--------------|")

            for script in section.scripts:
                name = script.display_name
                desc = script.description or "-"
                reqs = []
                if script.requires_sudo:
                    reqs.append("sudo")
                if script.is_headless_skip:
                    reqs.append("GUI")
                req_str = ", ".join(reqs) if reqs else "-"
                print(f"| {name} | {desc} | {req_str} |")

            print()


@dataclass
class DependencyGraph:
    """DAG for computing transitive script dependencies with order validation.

    All transitive dependencies are pre-computed at construction time since
    the graph is immutable after creation.
    """

    adj: dict[str, list[str]] = field(default_factory=dict)
    transitive: dict[str, set[str]] = field(default_factory=dict)
    script_order: dict[str, int] = field(default_factory=dict)

    @classmethod
    def from_manifest(cls, manifest: Manifest) -> Self:
        """Build dependency graph from a parsed manifest."""
        graph = cls()
        idx = 0
        for section in manifest.sections:
            for script in section.scripts:
                graph.adj[script.name] = script.dependencies
                graph.script_order[script.name] = idx
                idx += 1

        # Pre-compute all transitive dependencies
        for name in graph.adj:
            graph.transitive[name] = graph._compute_transitive(name)

        return graph

    def _compute_transitive(self, name: str) -> set[str]:
        """Compute all transitive dependencies for a script via DFS."""
        result: set[str] = set()
        visiting: set[str] = set()

        def dfs(current: str) -> None:
            if current in visiting:
                return  # Cycle - skip
            visiting.add(current)
            for dep in self.adj.get(current, []):
                result.add(dep)
                dfs(dep)
            visiting.remove(current)

        dfs(name)
        return result

    def get_transitive_deps(self, name: str) -> set[str]:
        """Get all dependencies (direct + transitive) for a script."""
        return self.transitive.get(name, set())

    def get_order(self, name: str) -> int:
        """Get manifest order index for a script (0-indexed position)."""
        return self.script_order.get(name, 0)


###############################################################################
### Script Execution Helpers
###############################################################################


def check_sudo_available() -> bool:
    """Check if sudo is available without password (NOPASSWD or cached credentials)."""
    if os.geteuid() == 0:
        return True  # Running as root
    try:
        result = subprocess.run(
            ["sudo", "-n", "true"],
            capture_output=True,
            timeout=5,
        )
        return result.returncode == 0
    except Exception:
        return False


def prompt_sudo_if_needed(enabled_scripts: list[tuple[Section, Script]]) -> bool:
    """Prompt for sudo credentials if any enabled scripts require sudo.

    Args:
        enabled_scripts: List of (section, script) tuples to be executed.

    Returns:
        True if sudo is available (or not needed), False if user declined/failed.
    """
    # Check if any scripts require sudo
    needs_sudo = any(script.requires_sudo for _, script in enabled_scripts)
    if not needs_sudo:
        return True  # No sudo needed

    # Already have sudo?
    if check_sudo_available():
        return True

    # Prompt user
    print("\n" + "─" * 60)
    print(" Some selected scripts require sudo.")
    print("─" * 60)

    try:
        response = input(" Authenticate with sudo? [Y/n] ").strip().lower()
        if response and response[0] == "n":
            print(" Continuing without sudo (some scripts will be skipped)")
            return True  # User chose to continue without sudo

        # Try to cache sudo credentials
        result = subprocess.run(["sudo", "-v"], timeout=60)
        if result.returncode == 0:
            print(" ✓ Sudo credentials cached")
            return True
        else:
            print(" ✗ Sudo authentication failed")
            return True  # Continue anyway, scripts will skip
    except (KeyboardInterrupt, EOFError):
        print("\n Cancelled")
        return False
    except Exception as e:
        print(f" Error checking sudo: {type(e).__name__}: {e}")
        return True  # Continue anyway


def prepare_script_env(
    dry_run: bool, headless: bool, stream_output: bool = False
) -> dict[str, str]:
    """Prepare environment variables for script execution.

    Args:
        dry_run: Whether to run in dry-run mode (preview changes only).
        headless: Whether to skip GUI components.
        stream_output: Whether to stream command output live (for TUI display).

    Returns:
        Environment dictionary with all required variables set.
    """
    env = os.environ.copy()
    env["_SOURCED"] = "1"
    env["ORCHESTRATED"] = "true"
    # Note: Use empty string for false because some scripts (e.g., get.docker.com)
    # treat ANY non-empty DRY_RUN value as dry-run mode
    env["DRY_RUN"] = "true" if dry_run else ""
    env["HEADLESS"] = "Y" if headless else "N"
    env["INSTALL_SNAPS"] = "N" if headless else "Y"
    env["HAS_SUDO"] = "true" if check_sudo_available() else "false"
    env["GIT_NAME"] = env.get("GIT_NAME", DEFAULT_GIT_NAME)
    env["GIT_EMAIL"] = env.get("GIT_EMAIL", DEFAULT_GIT_EMAIL)
    env["STREAM_OUTPUT"] = "true" if stream_output else "false"
    return env


def build_script_command(scripts_dir: Path, script_path: Path) -> str:
    """Build bash command that sources _common.sh then executes a script.

    Args:
        scripts_dir: Directory containing install scripts (install_scripts/).
        script_path: Full path to the script to execute.

    Returns:
        Bash command string suitable for `bash -c`.
    """
    common_sh = scripts_dir.parent / "_common.sh"
    return f'source "{common_sh}" && source "{script_path}"'


def run_script_simple(
    script_path: Path,
    scripts_dir: Path,
    env: dict[str, str],
) -> subprocess.CompletedProcess[str]:
    """Execute a script with captured output (non-interactive).

    Args:
        script_path: Full path to the script to execute.
        scripts_dir: Directory containing install scripts.
        env: Environment variables for execution.

    Returns:
        CompletedProcess with captured stdout/stderr.
    """
    bash_cmd = build_script_command(scripts_dir, script_path)
    return subprocess.run(
        ["bash", "-c", bash_cmd],
        env=env,
        cwd=scripts_dir.parent,
        capture_output=True,
        text=True,
    )


def run_script_streaming(
    script_path: Path,
    scripts_dir: Path,
    env: dict[str, str],
) -> int:
    """Execute a script with live streaming output.

    Streams stdout/stderr to the console in real-time, useful for debugging
    and Docker/CI environments where you want to see script progress.

    Args:
        script_path: Full path to the script to execute.
        scripts_dir: Directory containing install scripts.
        env: Environment variables for execution.

    Returns:
        Exit code from the script.
    """
    bash_cmd = build_script_command(scripts_dir, script_path)
    process = subprocess.Popen(
        ["bash", "-c", bash_cmd],
        env=env,
        cwd=scripts_dir.parent,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        bufsize=1,  # Line buffered
    )
    if process.stdout is not None:
        for line in process.stdout:
            print(f"    {line}", end="")
    process.wait()
    return process.returncode


###############################################################################
### Install Logger
###############################################################################


@dataclass
class InstallLogger:
    """Handles logging for both interactive and non-interactive execution.

    Creates timestamped log files (.log and .json) in the logs/ directory.
    The JSON file stores the script selection; the .log file stores execution output.
    """

    scripts_dir: Path
    dry_run: bool
    headless: bool
    statuses: list["ScriptStatus"]
    start_time: float = field(default_factory=time.monotonic)
    _wall_start: float = field(default_factory=time.time)

    def get_log_paths(self) -> tuple[Path, Path]:
        """Generate timestamped log file paths in the logs/ directory.

        Returns:
            Tuple of (console_log_path, json_log_path).
        """
        logs_dir = self.scripts_dir.parent / "logs"
        logs_dir.mkdir(exist_ok=True)

        timestamp = time.strftime("%Y-%m-%d_%H-%M-%S", time.localtime(self._wall_start))
        console_path = logs_dir / f"{timestamp}.log"
        json_path = logs_dir / f"{timestamp}.json"

        return console_path, json_path

    def write_header(self) -> None:
        """Write log header and JSON selection file. Creates/truncates log file."""
        console_path, json_path = self.get_log_paths()

        # Write JSON selection (same format as --export)
        scripts = [status.script.path for status in self.statuses]
        data = {
            "version": 1,
            "description": "peter-terminal-utils selection export",
            "scripts": scripts,
        }
        with open(json_path, "w") as f:
            json.dump(data, f, indent=2)

        # Write console log header
        start_time_str = time.strftime(
            "%Y-%m-%d %H:%M:%S", time.localtime(self._wall_start)
        )
        with open(console_path, "w") as f:
            f.write("Peter Sharpe's Linux Setup - Installation Log\n")
            f.write("=" * 60 + "\n\n")
            f.write(f"Timestamp: {start_time_str}\n")
            f.write(f"Dry Run:   {self.dry_run}\n")
            f.write(f"Headless:  {self.headless}\n")
            f.write(f"Scripts:   {len(self.statuses)}\n")
            f.write("\n" + "=" * 60 + "\n\n")

    def append_result(self, status: "ScriptStatus") -> None:
        """Append a script's result to the log file."""
        console_path, _ = self.get_log_paths()

        with open(console_path, "a") as f:
            state_indicator = status.state.indicator
            f.write(
                f"{state_indicator} [{status.state.name}] "
                f"{status.section.name} / {status.script.display_name}\n"
            )
            # Log timing information (relative to install start)
            if status.start_time is not None:
                rel_start = status.start_time - self.start_time
                f.write(f"  Started: {rel_start:.2f}s\n")
            if status.end_time is not None:
                rel_end = status.end_time - self.start_time
                f.write(f"  Ended:   {rel_end:.2f}s\n")
            if status.start_time is not None and status.end_time is not None:
                duration = status.end_time - status.start_time
                f.write(f"  Duration: {duration:.2f}s\n")
            # Log lock contention wait time if script was blocked
            if (
                status.ready_time is not None
                and status.start_time is not None
                and status.blocked_by_locks
            ):
                lock_wait = status.start_time - status.ready_time
                if lock_wait > 0.1:  # Avoid noise from scheduling jitter
                    locks_str = ", ".join(sorted(status.blocked_by_locks))
                    f.write(f"  Lock wait: {lock_wait:.2f}s (blocked by: {locks_str})\n")
            if status.exit_code is not None:
                f.write(f"  Exit code: {status.exit_code}\n")
            if status.output_lines:
                f.write("  Output:\n")
                for line in status.output_lines:
                    clean_line = strip_ansi(line)
                    f.write(f"    {clean_line}\n")
            f.write("\n")

    def _compute_concurrency_stats(self) -> dict[str, float | int]:
        """Compute parallelism statistics from script timing data.

        Returns dict with:
            - peak_concurrency: Maximum scripts running simultaneously
            - sum_durations: Total CPU time across all scripts
            - wall_time: Actual elapsed time
            - speedup: sum_durations / wall_time (parallelism efficiency)
        """
        # Collect scripts that actually ran (have both start and end times)
        intervals = [
            (s.start_time, s.end_time)
            for s in self.statuses
            if s.start_time is not None and s.end_time is not None
        ]

        if not intervals:
            return {"peak_concurrency": 0, "sum_durations": 0.0, "wall_time": 0.0, "speedup": 1.0}

        # Sum of all script durations
        sum_durations = sum(end - start for start, end in intervals)

        # Wall time from first start to last end
        min_start = min(start for start, _ in intervals)
        max_end = max(end for _, end in intervals)
        wall_time = max_end - min_start

        # Peak concurrency: use event-based counting
        # Create events: +1 at start, -1 at end
        events: list[tuple[float, int]] = []
        for start, end in intervals:
            events.append((start, 1))   # Script starts
            events.append((end, -1))    # Script ends

        # Sort by time, with ends (-1) before starts (+1) at same time
        # This prevents counting a script that ends exactly when another starts
        events.sort(key=lambda e: (e[0], e[1]))

        peak = 0
        current = 0
        for _, delta in events:
            current += delta
            peak = max(peak, current)

        speedup = sum_durations / wall_time if wall_time > 0 else 1.0

        return {
            "peak_concurrency": peak,
            "sum_durations": sum_durations,
            "wall_time": wall_time,
            "speedup": speedup,
        }

    def write_summary(self, end_time: float | None = None) -> None:
        """Append final summary to the log file."""
        console_path, _ = self.get_log_paths()

        success_count = sum(1 for s in self.statuses if s.state == ScriptState.SUCCESS)
        fail_count = sum(1 for s in self.statuses if s.state == ScriptState.FAILED)
        skipped_count = sum(1 for s in self.statuses if s.state == ScriptState.SKIPPED)

        end = end_time if end_time is not None else time.monotonic()
        duration = end - self.start_time

        # Compute concurrency statistics
        stats = self._compute_concurrency_stats()

        with open(console_path, "a") as f:
            f.write("=" * 60 + "\n")
            f.write(
                f"Summary: {success_count} succeeded, {fail_count} failed, {skipped_count} skipped\n"
            )
            f.write(f"Duration: {duration:.1f}s\n")
            f.write("\n")
            f.write("Parallelism:\n")
            f.write(f"  Peak concurrency: {stats['peak_concurrency']} scripts\n")
            f.write(f"  Total script time: {stats['sum_durations']:.1f}s\n")
            f.write(f"  Wall-clock time: {stats['wall_time']:.1f}s\n")
            f.write(f"  Speedup: {stats['speedup']:.1f}x\n")


###############################################################################
### Parallel Script Execution
###############################################################################


def run_scripts_parallel(
    statuses: list["ScriptStatus"],
    manifest: Manifest,
    scripts_dir: Path,
    env: dict[str, str],
    logger: InstallLogger,
    *,
    run_live: Callable[["ScriptStatus"], bool],
    run_silent: Callable[["ScriptStatus"], bool],
    on_update: Callable[[], None] | None = None,
    is_cancelled: Callable[[], bool] | None = None,
) -> tuple[int, int]:
    """Run scripts with dependency-aware parallelism.

    This is the core execution engine used by both TUI and CLI modes.
    Scripts are scheduled based on dependencies and locks, with parallel
    scripts running in a thread pool.

    Args:
        statuses: List of ScriptStatus objects to execute.
        manifest: The manifest (used to pre-populate disabled scripts as complete).
        scripts_dir: Path to install_scripts directory.
        env: Environment variables for script execution.
        logger: InstallLogger for writing results.
        run_live: Callback to run a non-parallel script with live output.
            Takes ScriptStatus, returns True on success.
        run_silent: Callback to run a parallel script silently.
            Takes ScriptStatus, returns True on success.
        on_update: Optional callback for UI updates (polling input, redrawing).
        is_cancelled: Optional callback to check if execution should stop.

    Returns:
        Tuple of (success_count, fail_count).
    """
    success_count = 0
    fail_count = 0

    # Dynamic worker count based on CPU cores
    max_workers = min((os.cpu_count() or 4) * 2, 16)
    scheduler = ParallelScheduler(statuses, max_workers)

    # Pre-populate completed_paths with disabled scripts (assumed already run)
    for section in manifest.sections:
        for script in section.scripts:
            if not script.enabled:
                scheduler.completed_paths.add(script.path)

    try:
        with concurrent.futures.ThreadPoolExecutor(
            max_workers=max_workers
        ) as executor:
            futures: dict[concurrent.futures.Future[bool], ScriptStatus] = {}

            while True:
                # Check cancellation
                if is_cancelled is not None and is_cancelled():
                    for status in statuses:
                        if status.state == ScriptState.PENDING:
                            status.state = ScriptState.SKIPPED
                            logger.append_result(status)
                    break

                # Find scripts ready to start
                ready = scheduler.get_ready_scripts(len(futures))

                for status in ready:
                    if not status.script.is_parallel:
                        # Non-parallel scripts run synchronously with live output
                        status.state = ScriptState.RUNNING
                        status.start_time = time.monotonic()
                        if on_update:
                            on_update()

                        if run_live(status):
                            success_count += 1
                        else:
                            fail_count += 1

                        scheduler.mark_complete(status)
                        logger.append_result(status)
                        if on_update:
                            on_update()
                    else:
                        # Parallel scripts run in thread pool
                        status.state = ScriptState.RUNNING
                        status.start_time = time.monotonic()
                        scheduler.acquire_locks(status)
                        future = executor.submit(run_silent, status)
                        futures[future] = status

                # Check if we're done
                if not futures and not ready:
                    all_done = all(
                        s.state != ScriptState.PENDING for s in statuses
                    )
                    if all_done:
                        break

                    # Deadlock: pending scripts exist but none can start
                    pending = [
                        s for s in statuses if s.state == ScriptState.PENDING
                    ]
                    for status in pending:
                        unsatisfied = [
                            dep
                            for dep in status.script.dependencies
                            if not any(
                                p.endswith(f"/{dep}.sh") or p == f"{dep}.sh"
                                for p in scheduler.completed_paths
                            )
                        ]
                        status.output_lines.append(
                            f"Deadlock: unsatisfied dependencies: {unsatisfied}"
                        )
                        status.state = ScriptState.FAILED
                        status.exit_code = 1
                        fail_count += 1
                        logger.append_result(status)
                    break

                # Wait for any completion (with timeout for animation/polling)
                if futures:
                    done, _ = concurrent.futures.wait(
                        futures.keys(),
                        timeout=0.08,
                        return_when=concurrent.futures.FIRST_COMPLETED,
                    )

                    for future in done:
                        status = futures.pop(future)
                        scheduler.release_locks(status)
                        scheduler.mark_complete(status)
                        try:
                            if future.result():
                                success_count += 1
                            else:
                                fail_count += 1
                        except Exception:
                            if status.end_time is None:
                                status.end_time = time.monotonic()
                            status.state = ScriptState.FAILED
                            fail_count += 1
                        logger.append_result(status)

                # UI update
                if on_update:
                    on_update()

    except KeyboardInterrupt:
        # Mark remaining as skipped
        for status in statuses:
            if status.state in (ScriptState.PENDING, ScriptState.RUNNING):
                status.state = ScriptState.SKIPPED
                logger.append_result(status)

    return success_count, fail_count


###############################################################################
### Presets
###############################################################################


@dataclass(frozen=True)
class PresetDef:
    """Definition of an installation preset.

    Attributes:
        description: Human-readable description (e.g., "Desktop - Full installation").
        disabled_sections: Section names to disable for this preset.
        flags: Modifier flags ("no_sudo" disables @requires:sudo scripts,
               "headless" disables @headless:skip scripts).
    """

    description: str
    disabled_sections: tuple[str, ...] = ()
    flags: tuple[str, ...] = ()

    @property
    def is_headless(self) -> bool:
        """Check if this preset skips GUI components."""
        return "headless" in self.flags


def _load_presets_from_config() -> dict[str, PresetDef]:
    """Load presets from config.toml and map to numeric keys.

    Presets are assigned keys 1, 2, 3... in the order they appear in config.toml.
    """
    presets: dict[str, PresetDef] = {}

    for i, (name, cfg) in enumerate(_CONFIG.get("presets", {}).items(), start=1):
        presets[str(i)] = PresetDef(
            description=cfg.get("description", name),
            disabled_sections=tuple(cfg.get("disabled_sections", [])),
            flags=tuple(cfg.get("flags", [])),
        )

    return presets


PRESETS: dict[str, PresetDef] = _load_presets_from_config()


###############################################################################
### Curses Helpers
