###############################################################################
### Box Drawing Characters
###############################################################################

# Rounded corner box-drawing (btop-style)
BOX_TL = "╭"  # Top-left
BOX_TR = "╮"  # Top-right
BOX_BL = "╰"  # Bottom-left
BOX_BR = "╯"  # Bottom-right
BOX_H = "─"  # Horizontal
BOX_V = "│"  # Vertical
BOX_DH = "═"  # Double horizontal (for headers)

# Tab-style connectors
TAB_DOWN = "┐"  # Tab end going down
TAB_UP = "┘"  # Tab end going up
TAB_START = "┌"  # Tab start


###############################################################################
### Help System
###############################################################################


class HelpEntry(NamedTuple):
    """A keyboard shortcut entry for help display."""

    keys: str
    description: str


# Shortcuts for SelectionTUI
SELECTION_SHORTCUTS = [
    HelpEntry("j, k, ↑↓", "Move cursor / cycle matches"),
    HelpEntry("n, N", "Next/prev match (when filtered)"),
    HelpEntry("C-n, C-p", "Next/prev match (when filtered)"),
    HelpEntry("PgUp/PgDn", "Page up/down"),
    HelpEntry("gg", "Jump to top"),
    HelpEntry("G", "Jump to bottom"),
    HelpEntry("Space/Enter", "Toggle selection"),
    HelpEntry("Click", "Select / toggle item"),
    HelpEntry("o", "View script content"),
    HelpEntry("/", "Search scripts"),
    HelpEntry("Esc", "Clear search filter"),
    HelpEntry("1-5", "Apply preset"),
    HelpEntry("x", "Start installation"),
    HelpEntry("q", "Quit"),
    HelpEntry("?", "Show this help"),
]

SELECTION_FOOTER_NOTES = [
    "Sections toggle all children",
    "[x]=enabled [~]=partial [ ]=disabled",
]

# Shortcuts for ExecutionTUI
EXECUTION_SHORTCUTS = [
    HelpEntry("h/l, ←→", "Switch panel"),
    HelpEntry("j/k, ↑↓", "Scroll"),
    HelpEntry("PgUp/PgDn", "Page up/down"),
    HelpEntry("gg", "Jump to top"),
    HelpEntry("G", "Jump to bottom"),
    HelpEntry("f", "Toggle follow mode"),
    HelpEntry("o", "View script content"),
    HelpEntry("q", "Quit"),
    HelpEntry("?", "Show this help"),
]

EXECUTION_FOOTER_NOTES = [
    "Left panel: script list, Right panel: output",
    "Follow mode auto-scrolls to running script",
]


def build_help_content(
    title: str,
    shortcuts: list[HelpEntry],
    footer_notes: list[str] | None = None,
) -> list[str]:
    """Generate help content lines for display in an overlay (no box borders).

    Args:
        title: Title to display at the top.
        shortcuts: List of HelpEntry tuples (keys, description).
        footer_notes: Optional list of footer note lines.

    Returns:
        List of plain text lines (title, shortcuts, notes) without borders.
    """
    key_width = max(len(s.keys) for s in shortcuts)
    lines: list[str] = []

    # Title (centered over content)
    lines.append(title)
    lines.append("")

    # Shortcut lines
    for entry in shortcuts:
        lines.append(f"  {entry.keys.ljust(key_width)}   {entry.description}")

    # Footer notes if provided
    if footer_notes:
        lines.append("")
        for note in footer_notes:
            lines.append(note)

    return lines


def make_title_bar(title: str, width: int) -> str:
    """Create a centered title bar with ═ borders.

    Example: "══════ My Title ══════" (padded to width).
    """
    padding = (width - len(title) - 2) // 2
    return BOX_DH * padding + title + BOX_DH * (width - padding - len(title) - 2)


def make_panel_header(label: str, width: int, right_label: str = "") -> str:
    """Create a btop-style tab header line with rounded corners.

    Example: "╭─┐ Scripts ┌────────────────────────╮"

    Args:
        label: Main label text to display in tab.
        width: Total width of the header line.
        right_label: Optional right-aligned label (e.g., elapsed time).

    Returns:
        Formatted header string with tab styling.
    """
    # Build tab: ╭─┐ Label ┌
    tab = f"{BOX_TL}{BOX_H}{TAB_DOWN} {label} {TAB_START}"
    tab_len = len(tab)

    # Build right section if provided: ┐ RightLabel ┌
    if right_label:
        right_section = f"{TAB_DOWN} {right_label} {TAB_START}"
        right_len = len(right_section)
    else:
        right_section = ""
        right_len = 0

    # Calculate fill between tab and right section (or right corner)
    fill_len = width - tab_len - right_len - 1  # -1 for right corner
    if fill_len < 0:
        fill_len = 0

    return tab + BOX_H * fill_len + right_section + BOX_TR


def init_colors() -> dict[ColorName, int]:
    """Initialize curses color pairs and return a mapping."""
    curses.start_color()
    curses.use_default_colors()

    # Define color pairs
    curses.init_pair(1, curses.COLOR_GREEN, -1)  # Enabled
    curses.init_pair(2, curses.COLOR_YELLOW, -1)  # Partial
    curses.init_pair(3, curses.COLOR_CYAN, -1)  # Running/info
    curses.init_pair(4, curses.COLOR_RED, -1)  # Failed/error
    curses.init_pair(5, curses.COLOR_BLUE, -1)  # Header
    curses.init_pair(6, curses.COLOR_BLACK, curses.COLOR_CYAN)  # Header bar

    return {
        "green": curses.color_pair(1),
        "yellow": curses.color_pair(2),
        "cyan": curses.color_pair(3),
        "red": curses.color_pair(4),
        "blue": curses.color_pair(5),
        "header": curses.color_pair(6),
        "dim": curses.A_DIM,
        "bold": curses.A_BOLD,
        "reverse": curses.A_REVERSE,
    }


def enable_mouse() -> None:
    """Enable mouse support with click, drag, and scroll events.

    Should be called after curses initialization. Enables all mouse events
    including button clicks, releases, and position reporting for drag support.
    """
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)


def draw_scrollbar(
    stdscr: curses.window,
    x: int,
    y_start: int,
    height: int,
    scroll: ScrollState,
    color: int,
    focused: bool = True,
) -> None:
    """Draw a vertical scrollbar showing position in content.

    Args:
        stdscr: Curses window to draw on.
        x: Column position for the scrollbar.
        y_start: First row of the scrollbar.
        height: Height of the scrollbar area.
        scroll: Current scroll state.
        color: Color attribute for the scrollbar.
        focused: Whether the parent panel is focused (affects thumb style).
    """
    if height < 2 or scroll.total <= scroll.visible:
        # No scrollbar needed if everything fits
        return

    # Calculate thumb size and position
    # Thumb size proportional to visible/total ratio, minimum 1 char
    thumb_size = max(1, int(height * scroll.visible / scroll.total))
    # Thumb position based on scroll offset
    max_offset = max(1, scroll.total - scroll.visible)
    thumb_pos = int((height - thumb_size) * scroll.offset / max_offset)

    # Use different characters based on focus state
    thumb_char = "█" if focused else "▓"
    track_char = "░"

    for i in range(height):
        y = y_start + i
        if thumb_pos <= i < thumb_pos + thumb_size:
            char = thumb_char
        else:
            char = track_char
        try:
            stdscr.addstr(y, x, char, color)
        except curses.error:
            pass


def handle_scrollbar_mouse(
    bstate: int,
    mx: int,
    my: int,
    scrollbar_x: int,
    y_start: int,
    height: int,
    scroll: ScrollState,
    drag_state: DragState,
) -> bool:
    """Handle mouse events for a vertical scrollbar.

    Handles click-to-position and drag initiation for scrollbar interaction.

    Args:
        bstate: Mouse button state from curses.getmouse().
        mx, my: Mouse x, y coordinates.
        scrollbar_x: X position of the scrollbar column.
        y_start: Starting Y position of the scrollbar track.
        height: Height of the scrollbar track.
        scroll: ScrollState to modify.
        drag_state: DragState to track drag operation.

    Returns:
        True if the mouse event was consumed (on scrollbar), False otherwise.
    """
    # Check if click is on the scrollbar
    if mx != scrollbar_x or not (y_start <= my < y_start + height):
        return False

    is_click = bool(bstate & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED))
    if not is_click:
        return False

    # Start drag on press
    if bstate & curses.BUTTON1_PRESSED:
        drag_state.active = True
        drag_state.start_offset = scroll.offset
        drag_state.start_y = my

    # Click-to-position
    scroll.set_from_scrollbar_click(my, y_start, height)
    return True


def handle_scrollbar_drag(
    my: int,
    height: int,
    scroll: ScrollState,
    drag_state: DragState,
) -> None:
    """Handle scrollbar drag motion.

    Updates scroll offset based on mouse movement during an active drag.

    Args:
        my: Current mouse Y coordinate.
        height: Height of the scrollbar track.
        scroll: ScrollState to modify.
        drag_state: DragState tracking the drag operation.
    """
    if not drag_state.active or height <= 0 or scroll.total <= scroll.visible:
        return

    delta_y = my - drag_state.start_y
    scroll_range = scroll.total - scroll.visible
    offset_delta = int(delta_y * scroll_range / height)
    scroll.offset = max(0, min(scroll_range, drag_state.start_offset + offset_delta))


def handle_scroll_wheel(bstate: int, scroll: ScrollState, amount: int = 1) -> bool:
    """Handle mouse scroll wheel events.

    Args:
        bstate: Mouse button state from curses.getmouse().
        scroll: ScrollState to modify.
        amount: Number of lines to scroll per wheel tick.

    Returns:
        True if the scroll wheel was used (event consumed), False otherwise.
    """
    if bstate & curses.BUTTON4_PRESSED:
        scroll.scroll_up(amount)
        return True
    if bstate & curses.BUTTON5_PRESSED:
        scroll.scroll_down(amount)
        return True
    return False


###############################################################################
### Base TUI
###############################################################################


@dataclass
class BaseTUI:
    """Base class for curses-based TUI screens.

    Provides shared initialization, overlay display, and help functionality.
    Subclasses should call super().__post_init__() to initialize colors and mouse.
    """

    stdscr: curses.window
    manifest: Manifest
    scripts_dir: Path
    colors: dict[ColorName, int] = field(init=False)
    drag_state: DragState = field(default_factory=DragState)

    def __post_init__(self) -> None:
        self.colors = init_colors()
        curses.curs_set(0)
        enable_mouse()

    def safe_addstr(self, y: int, x: int, text: str, attr: int = 0) -> None:
        """Write string to screen, ignoring curses boundary errors."""
        try:
            self.stdscr.addstr(y, x, text, attr)
        except curses.error:
            pass

    def draw_overlay_box(
        self,
        start_x: int,
        start_y: int,
        box_width: int,
        box_height: int,
        title: str,
        scroll_info: tuple[int, int, int] | None = None,
    ) -> None:
        """Draw overlay box borders with title and optional scroll info.

        Args:
            start_x, start_y: Top-left corner of the box.
            box_width, box_height: Dimensions of the box.
            title: Title text to display in the header.
            scroll_info: Optional (offset, visible_end, total) for scroll indicator.
        """
        border_attr = self.colors["cyan"] | self.colors["bold"]

        # Top border with title
        top_line = BOX_TL + BOX_H * (box_width - 2) + BOX_TR
        header = f" {title} "
        header_start = (box_width - len(header)) // 2
        top_line = (
            top_line[:header_start] + header + top_line[header_start + len(header) :]
        )
        self.safe_addstr(start_y, start_x, top_line, border_attr)

        # Bottom border with scroll hint
        bot_line = BOX_BL + BOX_H * (box_width - 2) + BOX_BR
        if scroll_info:
            offset, visible_end, total = scroll_info
            scroll_hint = f" {offset + 1}-{visible_end}/{total} "
            hint_start = (box_width - len(scroll_hint)) // 2
            bot_line = (
                bot_line[:hint_start]
                + scroll_hint
                + bot_line[hint_start + len(scroll_hint) :]
            )
        self.safe_addstr(start_y + box_height - 1, start_x, bot_line, border_attr)

        # Side borders
        for y in range(1, box_height - 1):
            self.safe_addstr(start_y + y, start_x, BOX_V, border_attr)
            self.safe_addstr(start_y + y, start_x + box_width - 1, BOX_V, border_attr)

    def show_overlay(
        self,
        lines: list[str],
        title: str,
        footer_hint: str = " [j/k] Scroll   [gg/G] Top/Bottom   [q/Esc] Close ",
    ) -> None:
        """Display scrollable content in a centered overlay box.

        Args:
            lines: Lines of text to display (will be wrapped to fit).
            title: Title to show in the header bar.
            footer_hint: Hint text for the footer.
        """
        height, width = self.stdscr.getmaxyx()
        box_width = min(width - 4, 100)
        box_height = height - 4
        start_x = (width - box_width) // 2
        start_y = 2

        content_width = box_width - 4
        content_height = box_height - 4

        wrapped_lines = wrap_lines(lines, content_width)
        scroll = ScrollState(offset=0, total=len(wrapped_lines), visible=content_height)
        nav = VimNavHandler()
        drag = DragState()

        scrollbar_x = start_x + box_width - 2
        content_start_y = start_y + 1

        while True:
            # Clear box area
            for y in range(box_height):
                self.safe_addstr(start_y + y, start_x, " " * box_width)

            # Draw box borders with title and scroll info
            visible_end = min(scroll.offset + content_height, len(wrapped_lines))
            self.draw_overlay_box(
                start_x,
                start_y,
                box_width,
                box_height,
                title,
                (scroll.offset, visible_end, len(wrapped_lines)),
            )

            # Content lines
            for i in range(content_height):
                line_idx = scroll.offset + i
                line = wrapped_lines[line_idx] if line_idx < len(wrapped_lines) else ""
                self.safe_addstr(
                    start_y + 1 + i, start_x + 2, line.ljust(content_width)
                )

            # Scrollbar
            draw_scrollbar(
                self.stdscr,
                scrollbar_x,
                content_start_y,
                content_height,
                scroll,
                self.colors["cyan"],
            )

            # Footer hint
            hint_y = start_y + box_height - 2
            hint_x = start_x + (box_width - len(footer_hint)) // 2
            self.safe_addstr(hint_y, hint_x, footer_hint, self.colors["dim"])

            self.stdscr.refresh()

            # Handle input
            key = self.stdscr.getch()

            if key == curses.KEY_MOUSE:
                try:
                    _, mx, my, _, bstate = curses.getmouse()
                    # Scroll wheel
                    if handle_scroll_wheel(bstate, scroll):
                        continue
                    # Click outside closes
                    if bstate & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED):
                        if not (
                            start_x <= mx < start_x + box_width
                            and start_y <= my < start_y + box_height
                        ):
                            break
                        # Scrollbar click - click-to-position then initialize drag from new position
                        if (
                            mx == scrollbar_x
                            and content_start_y <= my < content_start_y + content_height
                        ):
                            scroll.set_from_scrollbar_click(
                                my, content_start_y, content_height
                            )
                            if bstate & curses.BUTTON1_PRESSED:
                                drag.active = True
                                drag.start_y = my
                                drag.start_offset = (
                                    scroll.offset
                                )  # Capture AFTER click-to-position
                    # Drag handling
                    if bstate & curses.BUTTON1_RELEASED:
                        drag.active = False
                    if drag.active and bstate & curses.REPORT_MOUSE_POSITION:
                        delta_y = my - drag.start_y
                        if content_height > 0 and scroll.total > scroll.visible:
                            scroll_range = scroll.total - scroll.visible
                            offset_delta = int(delta_y * scroll_range / content_height)
                            scroll.offset = max(
                                0, min(scroll_range, drag.start_offset + offset_delta)
                            )
                except curses.error:
                    pass
                continue

            # Navigation via VimNavHandler
            if nav.handle(key, scroll):
                continue

            # Close keys
            if key in (27, ord("q"), ord("o")):
                break

    def show_help_overlay(self, shortcuts: list[HelpEntry], notes: list[str]) -> None:
        """Show help using the standard overlay display."""
        help_lines = build_help_content("⌨  Keyboard Shortcuts", shortcuts, notes)
        self.show_overlay(help_lines, "Help")


###############################################################################
### Selection TUI
###############################################################################


@dataclass
class SelectionTUI(BaseTUI):
    """Interactive TUI for selecting scripts to install."""

    cursor: int = field(default=0, init=False)
    scroll: ScrollState = field(default_factory=ScrollState, init=False)
    current_preset: str = field(default="1", init=False)
    search_mode: bool = field(default=False, init=False)
    search_query: str = field(default="", init=False)
    filtered_indices: list[int] | None = field(default=None, init=False)
    last_key: int = field(default=-1, init=False)

    def __post_init__(self) -> None:
        super().__post_init__()
        # Apply initial preset
        self.manifest.apply_preset(self.current_preset)

    def get_dependency_warnings(self, script: Script) -> list[str]:
        """Get list of dependency warnings for a script.

        Checks all transitive dependencies for:
        - Dependencies that are unknown (typo in @depends)
        - Dependencies that are disabled
        - Dependencies that run after this script (wrong manifest order)
        """
        warnings: list[str] = []
        dep_graph = self.manifest.dep_graph
        if dep_graph is None:
            return warnings

        all_deps = dep_graph.get_transitive_deps(script.name)
        if not all_deps:
            return warnings

        script_idx = dep_graph.get_order(script.name)
        direct_deps = set(script.dependencies)

        for dep_name in all_deps:
            dep_script = self.manifest.get_script_by_name(dep_name)
            suffix = "" if dep_name in direct_deps else " (transitive)"

            if dep_script is None:
                warnings.append(f"unknown: {dep_name}{suffix}")
            elif not dep_script.enabled:
                warnings.append(f"{dep_script.display_name} disabled{suffix}")
            else:
                # Check order - dependency must run BEFORE this script
                dep_idx = dep_graph.get_order(dep_name)
                if dep_idx >= script_idx:
                    warnings.append(f"{dep_script.display_name} runs later{suffix}")

        return warnings

    def get_visible_height(self) -> int:
        """Get number of lines available for the tree view."""
        height, _ = self.stdscr.getmaxyx()
        return height - 7  # Header (3) + footer (4)

    def draw(self) -> None:
        """Draw the complete selection screen."""
        self.stdscr.erase()
        height, width = self.stdscr.getmaxyx()

        # Draw header
        self.draw_header(width)

        # Draw tree
        self.draw_tree(height, width)

        # Draw footer
        self.draw_footer(height, width)

        self.stdscr.refresh()

    def draw_header(self, width: int) -> None:
        """Draw the header section."""
        title = " 🐧 Peter Sharpe's Linux Setup "
        header_line = make_title_bar(title, width)
        self.stdscr.attron(self.colors["header"] | self.colors["bold"])
        self.stdscr.addstr(0, 0, header_line[:width])
        self.stdscr.attroff(self.colors["header"] | self.colors["bold"])

        # Subtitle with preset indicator
        preset_desc = PRESETS[self.current_preset].description
        subtitle = f"  ▸ Preset [{self.current_preset}]: {preset_desc}"
        self.stdscr.addstr(1, 0, subtitle[: width - 2], self.colors["cyan"])

        # Elegant separator
        self.stdscr.addstr(2, 0, "─" * width, self.colors["dim"])

    def draw_tree(self, height: int, width: int) -> None:
        """Draw the tree of sections and scripts."""
        items = self.manifest.get_flat_items()
        visible_height = self.get_visible_height()

        # Update scroll state
        self.scroll.total = len(items)
        self.scroll.visible = visible_height
        self.scroll.ensure_visible(self.cursor)

        # Draw visible items (reserve rightmost column for scrollbar)
        for i in range(visible_height):
            item_idx = self.scroll.offset + i
            if item_idx >= len(items):
                break

            item = items[item_idx]
            y = 3 + i
            is_selected = item_idx == self.cursor

            self.draw_item(y, width - 1, item, is_selected)

        # Draw scrollbar
        draw_scrollbar(
            self.stdscr,
            x=width - 1,
            y_start=3,
            height=visible_height,
            scroll=self.scroll,
            color=self.colors["cyan"],
        )

    def draw_item(
        self, y: int, width: int, item: Section | Script, is_selected: bool
    ) -> None:
        """Draw a single tree item (section or script)."""
        if isinstance(item, Section):
            self.draw_section(y, width, item, is_selected)
        else:
            self.draw_script(y, width, item, is_selected)

    def draw_section(
        self, y: int, width: int, section: Section, is_selected: bool
    ) -> None:
        """Draw a section header with folder icon."""
        state = section.state
        if state == "all":
            checkbox = "[x]"
            icon = "📂"
            color = self.colors["green"]
        elif state == "partial":
            checkbox = "[~]"
            icon = "📂"
            color = self.colors["yellow"]
        else:
            checkbox = "[ ]"
            icon = "📁"
            color = self.colors["dim"]

        line = f" {checkbox} {icon} {section.name}"

        # Combine with reverse if selected
        rev = self.colors["reverse"] if is_selected else 0

        self.stdscr.addstr(y, 0, " " * width, rev)  # Clear line with selection
        self.stdscr.addstr(y, 0, line[: width - 1], color | self.colors["bold"] | rev)

    def draw_script(
        self, y: int, width: int, script: Script, is_selected: bool
    ) -> None:
        """Draw a script entry with its description and dependency warnings."""
        if script.enabled:
            checkbox = "[x]"
            color = self.colors["green"]
        else:
            checkbox = "[ ]"
            color = self.colors["dim"]

        name = script.display_name
        desc = script.description

        # Check for dependency warnings
        dep_warnings = self.get_dependency_warnings(script) if script.enabled else []

        # Calculate how much space we have for description
        # Format: "        [x] Name - Description"
        prefix = f"        {checkbox} {name}"
        prefix_len = len(prefix)

        # Reserve space for description (dim separator + text)
        desc_available = width - prefix_len - 4  # 4 = " - " + margin

        # Combine with reverse if selected
        rev = self.colors["reverse"] if is_selected else 0

        self.stdscr.addstr(y, 0, " " * width, rev)  # Clear line with selection
        self.stdscr.addstr(y, 0, prefix[: width - 1], color | rev)

        # Current position after prefix
        pos = prefix_len

        # Add description in dim/faded style if there's room
        if desc and desc_available > 10 and not dep_warnings:
            desc_text = desc[:desc_available]
            if len(desc) > desc_available:
                desc_text = desc[: desc_available - 1] + "…"
            # Draw separator and description in dim color
            dim_attr = self.colors["dim"] | rev
            self.safe_addstr(y, pos, " - ", dim_attr)
            self.safe_addstr(y, pos + 3, desc_text, dim_attr)
        elif dep_warnings:
            # Show dependency warnings in bold red (make them obvious)
            warning_text = " ⚠ " + ", ".join(dep_warnings)
            available = width - pos - 2
            if len(warning_text) > available:
                warning_text = warning_text[: available - 1] + "…"
            self.safe_addstr(
                y, pos, warning_text, self.colors["red"] | self.colors["bold"] | rev
            )

    def draw_footer(self, height: int, width: int) -> None:
        """Draw the footer with key bindings."""
        footer_y = height - 4

        # Separator
        self.stdscr.addstr(footer_y, 0, "─" * width, self.colors["dim"])

        # Search mode display
        if self.search_mode:
            search_line = f" Search: {self.search_query}_ "
            self.stdscr.addstr(
                footer_y + 1, 2, search_line[: width - 4], self.colors["cyan"]
            )
            self.stdscr.addstr(
                footer_y + 2,
                2,
                " [Enter] Apply   [Esc] Cancel "[: width - 4],
                self.colors["dim"],
            )
        elif self.filtered_indices is not None:
            # Show filter active with current match position
            try:
                match_pos = self.filtered_indices.index(self.cursor) + 1
            except ValueError:
                match_pos = 0
            filter_line = f" Filter: '{self.search_query}' ({match_pos}/{len(self.filtered_indices)} matches)   [Esc] Clear "
            self.stdscr.addstr(
                footer_y + 1, 2, filter_line[: width - 4], self.colors["yellow"]
            )
            keys2 = " [j/k] Next/Prev   [n/N] Next/Prev   [x] Install   [q] Quit "
            self.stdscr.addstr(footer_y + 2, 2, keys2[: width - 4], self.colors["cyan"])
        else:
            # Key bindings - line 1
            keys1 = " [j/k] Up/Down   [Space] Toggle   [o] View   [/] Search   [x] Install   [q] Quit "
            self.stdscr.addstr(footer_y + 1, 2, keys1[: width - 4], self.colors["cyan"])

            # Key bindings - line 2
            preset_keys = "   ".join(
                f"[{k}] {p.description.split(' - ')[0]}" for k, p in PRESETS.items()
            )
            keys2 = f" {preset_keys}   [?] Help "
            self.stdscr.addstr(footer_y + 2, 2, keys2[: width - 4], self.colors["cyan"])

        # Status line showing selected/total scripts and warning count
        enabled_scripts = self.manifest.get_enabled_scripts()
        enabled_count = len(enabled_scripts)
        total_count = sum(len(s.scripts) for s in self.manifest.sections)

        # Count scripts with dependency warnings
        warning_count = sum(
            1 for _, script in enabled_scripts if self.get_dependency_warnings(script)
        )

        status = f" {enabled_count}/{total_count} scripts selected "
        self.stdscr.addstr(
            footer_y + 3,
            2,
            status[: width - 4],
            self.colors["green"] | self.colors["bold"],
        )

        # Show warning count if any
        if warning_count > 0:
            warning_text = f" ⚠ {warning_count} with possible dependency issues "
            warning_x = 2 + len(status)
            if warning_x + len(warning_text) < width - 2:
                self.stdscr.addstr(
                    footer_y + 3,
                    warning_x,
                    warning_text,
                    self.colors["red"] | self.colors["bold"],
                )

    def _handle_mouse(
        self, items: list[Section | Script]
    ) -> Literal["execute", "quit"] | None:
        """Handle mouse events for tree selection, scrollbar, and footer clicks.

        Args:
            items: Flat list of sections and scripts for index calculations.

        Returns:
            'execute', 'quit', or None to continue.
        """
        try:
            _, mx, my, _, bstate = curses.getmouse()
        except curses.error:
            return None

        height, width = self.stdscr.getmaxyx()
        visible_height = self.get_visible_height()
        tree_start_y = 3
        tree_end_y = tree_start_y + visible_height
        footer_y = height - 4
        scrollbar_x = width - 1

        # Handle scroll wheel (BUTTON4 = scroll up, BUTTON5 = scroll down)
        if bstate & curses.BUTTON4_PRESSED:
            if tree_start_y <= my < tree_end_y:
                if self.cursor > 0:
                    self.cursor -= 1
            return None
        if bstate & curses.BUTTON5_PRESSED:
            if tree_start_y <= my < tree_end_y:
                if self.cursor < len(items) - 1:
                    self.cursor += 1
            return None

        # Handle button release (end drag)
        if bstate & curses.BUTTON1_RELEASED:
            self.drag_state.active = False
            return None

        # Handle scrollbar drag motion
        if self.drag_state.active and bstate & curses.REPORT_MOUSE_POSITION:
            if self.drag_state.panel == "main":
                delta_y = my - self.drag_state.start_y
                max_offset = max(1, self.scroll.total - self.scroll.visible)
                # Scale delta by content/scrollbar ratio
                if visible_height > 1:
                    content_delta = int(delta_y * max_offset / (visible_height - 1))
                    self.scroll.offset = max(
                        0, min(max_offset, self.drag_state.start_offset + content_delta)
                    )
            return None

        # Handle clicks (BUTTON1_CLICKED or BUTTON1_PRESSED)
        is_click = bool(bstate & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED))
        is_double_click = bool(bstate & curses.BUTTON1_DOUBLE_CLICKED)

        if not is_click and not is_double_click:
            return None

        # Scrollbar click/drag initiation (rightmost column, in tree area)
        if mx == scrollbar_x and tree_start_y <= my < tree_end_y:
            if bstate & curses.BUTTON1_PRESSED:
                # Start drag
                self.drag_state.active = True
                self.drag_state.panel = "main"
                self.drag_state.start_offset = self.scroll.offset
                self.drag_state.start_y = my
            # Click-to-position (always apply on click)
            self.scroll.set_from_scrollbar_click(my, tree_start_y, visible_height)
            # Also move cursor to match scroll position roughly
            self.cursor = min(len(items) - 1, self.scroll.offset)
            return None

        # Tree area click (not scrollbar)
        if tree_start_y <= my < tree_end_y and mx < scrollbar_x:
            item_idx = self.scroll.offset + (my - tree_start_y)
            if 0 <= item_idx < len(items):
                self.cursor = item_idx
                # Toggle on double-click or click in checkbox region (first 12 chars)
                if is_double_click or mx <= 12:
                    item = items[item_idx]
                    if isinstance(item, Section):
                        item.toggle()
                    else:
                        item.enabled = not item.enabled
            return None

        # Footer area clicks
        if my >= footer_y:
            # Skip if in search mode (different footer)
            if self.search_mode:
                return None

            footer_row = my - footer_y

            # Row 1 (footer_y + 1): Key bindings line with [o], [/], [x], [q]
            if footer_row == 1 and not self.filtered_indices:
                # Use the same string as draw_footer for accurate positions
                keys1 = " [j/k] Up/Down   [Space] Toggle   [o] View   [/] Search   [x] Install   [q] Quit "
                line_x = mx - 2  # Offset from start of line content
                if line_x >= 0:
                    # Find clickable regions dynamically
                    view_start = keys1.find("[o]")
                    search_start = keys1.find("[/]")
                    install_start = keys1.find("[x]")
                    quit_start = keys1.find("[q]")

                    if view_start != -1 and view_start <= line_x < view_start + len(
                        "[o] View"
                    ):
                        self.show_script_content()
                    elif (
                        search_start != -1
                        and search_start <= line_x < search_start + len("[/] Search")
                    ):
                        self.search_mode = True
                        self.search_query = ""
                    elif (
                        install_start != -1
                        and install_start <= line_x < install_start + len("[x] Install")
                    ):
                        return "execute"
                    elif quit_start != -1 and quit_start <= line_x < quit_start + len(
                        "[q] Quit"
                    ):
                        return "quit"

            # Row 2 (footer_y + 2): Preset keys [1], [2], etc.
            elif footer_row == 2 and not self.filtered_indices:
                # Look for [1], [2], [3], [4], [5] patterns in click position
                # The presets line starts at x=2
                line_x = mx - 2
                if line_x >= 0:
                    # Build list of preset segments with their positions
                    # Format: "[1] Desktop   [2] Headless   ..."
                    segments = [
                        f"[{k}] {p.description.split(' - ')[0]}"
                        for k, p in PRESETS.items()
                    ]
                    keys2 = " " + "   ".join(segments) + "   [?] Help "

                    # Calculate exact click regions for each preset
                    preset_keys = list(PRESETS.keys())
                    for i, preset_key in enumerate(preset_keys):
                        pattern = f"[{preset_key}]"
                        start = keys2.find(pattern)
                        if start == -1:
                            continue
                        # End is either the start of the next preset or [?] Help
                        if i + 1 < len(preset_keys):
                            next_pattern = f"[{preset_keys[i + 1]}]"
                            end = keys2.find(next_pattern)
                        else:
                            end = keys2.find("[?]")
                        if end == -1:
                            end = len(keys2)
                        if start <= line_x < end:
                            self.current_preset = preset_key
                            self.manifest.apply_preset(preset_key)
                            self.filtered_indices = None
                            self.search_query = ""
                            return None

                    # Check for [?] Help
                    help_idx = keys2.find("[?]")
                    if help_idx != -1 and help_idx <= line_x < len(keys2):
                        self.show_help()
                        return None

        return None

    def handle_input(self) -> Literal["execute", "quit"] | None:
        """Handle keyboard and mouse input. Returns 'execute' or 'quit' or None."""
        key = self.stdscr.getch()
        items = self.manifest.get_flat_items()

        # Handle mouse events
        if key == curses.KEY_MOUSE:
            return self._handle_mouse(items)

        # Search mode input handling
        if self.search_mode:
            if key == 27:  # Escape - cancel search
                self.search_mode = False
                self.search_query = ""
            elif key in (curses.KEY_ENTER, 10, 13):  # Enter (KEY_ENTER, LF, CR)
                self.search_mode = False
                if self.search_query:
                    self._apply_search_filter(items)
                else:
                    self.filtered_indices = None
            elif key in (curses.KEY_BACKSPACE, 127, 8):  # Backspace
                self.search_query = self.search_query[:-1]
            elif 32 <= key < 127:  # Printable ASCII
                self.search_query += chr(key)
            self.last_key = -1
            return None

        # Clear filter on Escape
        if key == 27 and self.filtered_indices is not None:
            self.filtered_indices = None
            self.search_query = ""
            self.last_key = -1
            return None

        # Start search mode
        if key == ord("/"):
            self.search_mode = True
            self.search_query = ""
            self.last_key = -1
            return None

        # Vim-style gg (go to top) - need to detect 'g' followed by 'g'
        if key == ord("g"):
            if self.last_key == ord("g"):
                self.cursor = 0
                self.scroll.go_top()
                self.last_key = -1
                return None
            else:
                self.last_key = key
                return None

        # Vim-style G (go to bottom)
        if key == ord("G"):
            self.cursor = len(items) - 1
            self.last_key = -1
            return None

        # Reset last_key for non-g keys
        self.last_key = -1

        # Navigation - when filter is active, j/k cycle through matches
        if self.filtered_indices is not None:
            if key in (ord("w"), ord("k"), curses.KEY_UP, 16, ord("N")):  # 16 = Ctrl-p
                self._goto_match(-1)
            elif key in (ord("s"), ord("j"), curses.KEY_DOWN, 14, ord("n")):  # 14 = Ctrl-n
                self._goto_match(1)
            elif key == curses.KEY_PPAGE:  # Page Up
                self._goto_match(-1)
            elif key == curses.KEY_NPAGE:  # Page Down
                self._goto_match(1)
        else:
            # Normal navigation through all items
            if key in (ord("w"), ord("k"), curses.KEY_UP):
                if self.cursor > 0:
                    self.cursor -= 1
            elif key in (ord("s"), ord("j"), curses.KEY_DOWN):
                if self.cursor < len(items) - 1:
                    self.cursor += 1
            elif key == curses.KEY_PPAGE:  # Page Up
                self.cursor = max(0, self.cursor - max(1, self.scroll.visible - 1))
            elif key == curses.KEY_NPAGE:  # Page Down
                self.cursor = min(
                    len(items) - 1, self.cursor + max(1, self.scroll.visible - 1)
                )

        # Toggle (also clears filter so Enter selects and exits search)
        if key in (ord(" "), curses.KEY_ENTER, 10, 13):
            item = items[self.cursor]
            if isinstance(item, Section):
                item.toggle()
            else:
                item.enabled = not item.enabled
            # Clear filter on toggle so Enter exits search mode
            if self.filtered_indices is not None:
                self.filtered_indices = None
                self.search_query = ""

        # Presets (keys 1-5)
        elif ord("1") <= key <= ord("5") and (preset_key := chr(key)) in PRESETS:
            self.current_preset = preset_key
            self.manifest.apply_preset(preset_key)
            # Clear any filter when applying preset
            self.filtered_indices = None
            self.search_query = ""

        # Execute
        elif key == ord("x"):
            return "execute"

        # Quit
        elif key == ord("q"):
            return "quit"

        # Help
        elif key == ord("?"):
            self.show_help()

        # View script content
        elif key == ord("o"):
            self.show_script_content()

        return None

    def _apply_search_filter(self, items: list[Section | Script]) -> None:
        """Apply search filter and highlight matching items."""
        query = self.search_query.lower()
        self.filtered_indices = []
        for i, item in enumerate(items):
            name = item.name if isinstance(item, Section) else item.display_name
            if query in name.lower():
                self.filtered_indices.append(i)
        # Move cursor to first match
        if self.filtered_indices:
            self.cursor = self.filtered_indices[0]

    def _goto_match(self, direction: int) -> None:
        """Move cursor to next (+1) or previous (-1) match. Wraps around."""
        if not self.filtered_indices:
            return

        try:
            current_pos = self.filtered_indices.index(self.cursor)
            new_pos = (current_pos + direction) % len(self.filtered_indices)
        except ValueError:
            # Cursor not on a match - find nearest in direction
            new_pos = 0 if direction > 0 else -1

        self.cursor = self.filtered_indices[new_pos]

    def show_help(self) -> None:
        """Show help overlay using base class method."""
        self.show_help_overlay(SELECTION_SHORTCUTS, SELECTION_FOOTER_NOTES)

    def show_script_content(self) -> None:
        """Show the full script content in a scrollable overlay.

        Only works when the cursor is on a Script (not a Section).
        """
        items = self.manifest.get_flat_items()
        if self.cursor >= len(items):
            return

        item = items[self.cursor]
        if not isinstance(item, Script):
            return  # Only show for scripts, not sections

        # Read script file
        script_path = self.scripts_dir / item.path
        try:
            with open(script_path) as f:
                content = f.read()
        except (OSError, IOError) as e:
            content = f"Error reading script: {e}"

        self.show_overlay(content.split("\n"), item.path)

    def run(self) -> bool:
        """Run the selection TUI. Returns True if user wants to execute, False to quit."""
        while True:
            self.draw()
            result = self.handle_input()
            if result == "execute":
                return True
            elif result == "quit":
                return False


###############################################################################
### Execution TUI
###############################################################################


@dataclass
class ScriptStatus:
    """Status of a script during execution."""

    section: Section
    script: Script
    state: ScriptState = ScriptState.PENDING
    output_lines: list[str] = field(default_factory=list)
    exit_code: int | None = None
    start_time: float | None = None  # monotonic time when script started
    end_time: float | None = None  # monotonic time when script finished
    ready_time: float | None = None  # when dependencies became satisfied
    blocked_by_locks: set[str] | None = None  # which locks blocked this script


@dataclass
class ParallelScheduler:
    """Scheduler for dependency-aware parallel script execution.

    Manages:
    - Dependency tracking: scripts start when dependencies complete
    - Lock management: scripts with same locks don't run simultaneously
    - Worker limits: respects max concurrent workers
    """

    statuses: list["ScriptStatus"]
    max_workers: int
    completed_paths: set[str] = field(default_factory=set)
    held_locks: set[str] = field(default_factory=set)

    def deps_satisfied(self, status: ScriptStatus) -> bool:
        """Check if all dependencies have completed (success or failure)."""
        for dep in status.script.dependencies:
            # Dependencies are script names without .sh; completed_paths are full paths
            # Check if any completed path ends with the dependency name
            if not any(
                p.endswith(f"/{dep}.sh") or p == f"{dep}.sh"
                for p in self.completed_paths
            ):
                return False
        return True

    def has_lock_conflict(self, status: ScriptStatus) -> bool:
        """Check if any required locks are currently held."""
        return bool(status.script.locks & self.held_locks)

    def get_ready_scripts(self, running_count: int) -> list[ScriptStatus]:
        """Find scripts that can start now.

        Returns scripts that:
        - Are still pending
        - Have all dependencies satisfied
        - Don't conflict with currently held locks (including locks from other
          scripts in this batch)
        - Fit within worker limit

        Non-parallel scripts only run when nothing else is running.

        Also tracks ready_time (when deps first satisfied) and blocked_by_locks
        (which locks are preventing a ready script from starting) for diagnostics.
        """
        ready: list[ScriptStatus] = []
        # Track locks from scripts added to this batch to prevent conflicts
        # within the same batch (not yet in held_locks since not yet started)
        batch_locks: set[str] = set()

        for status in self.statuses:
            if status.state != ScriptState.PENDING:
                continue

            if not status.script.is_parallel:
                # Non-parallel scripts run alone
                if running_count == 0 and not ready:
                    if self.deps_satisfied(status):
                        # Track when dependencies became satisfied
                        if status.ready_time is None:
                            status.ready_time = time.monotonic()
                        ready.append(status)
                        break  # Only one non-parallel at a time
            else:
                if not self.deps_satisfied(status):
                    continue
                # Track when dependencies became satisfied
                if status.ready_time is None:
                    status.ready_time = time.monotonic()
                if self.has_lock_conflict(status):
                    # Record which locks are blocking (first occurrence only)
                    if status.blocked_by_locks is None:
                        status.blocked_by_locks = status.script.locks & self.held_locks
                    continue
                # Also check for conflicts with other scripts in this batch
                if status.script.locks & batch_locks:
                    continue
                ready.append(status)
                batch_locks |= status.script.locks
                if running_count + len(ready) >= self.max_workers:
                    break

        return ready

    def acquire_locks(self, status: ScriptStatus) -> None:
        """Acquire all locks for a script."""
        self.held_locks |= status.script.locks

    def release_locks(self, status: ScriptStatus) -> None:
        """Release all locks held by a script."""
        self.held_locks -= status.script.locks

    def mark_complete(self, status: ScriptStatus) -> None:
        """Mark a script as completed for dependency tracking."""
        self.completed_paths.add(status.script.path)


@dataclass
class ExecutionTUI(BaseTUI):
    """TUI for showing installation progress with live output."""

    dry_run: bool = False
    headless: bool = False
    # Fields initialized in __post_init__
    statuses: list[ScriptStatus] = field(default_factory=list, init=False)
    running_idx: int = field(default=0, init=False)
    viewing_idx: int = field(default=0, init=False)
    following: bool = field(default=True, init=False)
    left_scroll: ScrollState = field(default_factory=ScrollState, init=False)
    right_scroll: ScrollState = field(default_factory=ScrollState, init=False)
    cancelled: bool = field(default=False, init=False)
    quit_requested: bool = field(default=False, init=False)
    _last_key: int = field(default=-1, init=False)
    focus_panel: str = field(default="left", init=False)
    spinner: BrailleSpinner = field(default_factory=BrailleSpinner, init=False)
    start_time: float = field(default_factory=time.monotonic, init=False)
    end_time: float | None = field(default=None, init=False)
    _logger: InstallLogger | None = field(default=None, init=False)

    def __post_init__(self) -> None:
        super().__post_init__()
        # Build status list from enabled scripts
        self.statuses = [
            ScriptStatus(section=section, script=script)
            for section, script in self.manifest.get_enabled_scripts()
        ]
        # Create logger for file output
        self._logger = InstallLogger(
            scripts_dir=self.scripts_dir,
            dry_run=self.dry_run,
            headless=self.headless,
            statuses=self.statuses,
            start_time=self.start_time,
        )

    def _set_running_idx(self, idx: int) -> None:
        """Update running index, and viewing index if following."""
        self.running_idx = idx
        if self.following:
            self.viewing_idx = idx
            self.right_scroll.offset = 0  # Reset scroll when switching scripts

    def _handle_mouse_during_execution(self) -> None:
        """Handle mouse events during execution for panel navigation and scrolling.

        Supports:
        - Clicking left panel to select script and focus left
        - Clicking right panel to focus right
        - Scrollbar click-to-position and drag on both panels
        - Scroll wheel in both panels
        """
        try:
            _, mx, my, _, bstate = curses.getmouse()
        except curses.error:
            return

        height, width = self.stdscr.getmaxyx()
        list_width = min(40, width // 2)
        start_row = 2
        visible_height = height - 5
        footer_y = height - 3

        left_scrollbar_x = list_width - 1
        right_scrollbar_x = width - 1

        # Handle scroll wheel (BUTTON4 = scroll up, BUTTON5 = scroll down)
        if bstate & curses.BUTTON4_PRESSED:
            if start_row <= my < start_row + visible_height:
                if mx < list_width:
                    # Scroll left panel (script list)
                    if self.viewing_idx > 0:
                        self.viewing_idx -= 1
                        self.right_scroll.offset = 0
                        self.following = self.viewing_idx == self.running_idx
                else:
                    # Scroll right panel (output)
                    self.right_scroll.scroll_up()
                    self.following = False
            return
        if bstate & curses.BUTTON5_PRESSED:
            if start_row <= my < start_row + visible_height:
                if mx < list_width:
                    # Scroll left panel (script list)
                    if self.viewing_idx < len(self.statuses) - 1:
                        self.viewing_idx += 1
                        self.right_scroll.offset = 0
                        self.following = self.viewing_idx == self.running_idx
                else:
                    # Scroll right panel (output)
                    self.right_scroll.scroll_down()
                    self.following = False
            return

        # Handle button release (end drag)
        if bstate & curses.BUTTON1_RELEASED:
            self.drag_state.active = False
            return

        # Handle scrollbar drag motion
        if self.drag_state.active and bstate & curses.REPORT_MOUSE_POSITION:
            delta_y = my - self.drag_state.start_y
            if self.drag_state.panel == "left":
                max_offset = max(1, self.left_scroll.total - self.left_scroll.visible)
                if visible_height > 1:
                    content_delta = int(delta_y * max_offset / (visible_height - 1))
                    self.left_scroll.offset = max(
                        0, min(max_offset, self.drag_state.start_offset + content_delta)
                    )
            elif self.drag_state.panel == "right":
                max_offset = max(1, self.right_scroll.total - self.right_scroll.visible)
                if visible_height > 1:
                    content_delta = int(delta_y * max_offset / (visible_height - 1))
                    self.right_scroll.offset = max(
                        0, min(max_offset, self.drag_state.start_offset + content_delta)
                    )
                    self.following = False
            return

        # Handle clicks
        is_click = bool(bstate & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED))
        if not is_click:
            return

        # Footer area clicks (controls line is at footer_y + 2)
        if my == footer_y + 2:
            # Controls line: " [h/l] Panel   [j/k] Scroll   [o] View   [?] Help   [q] Quit "
            controls = " [h/l] Panel   [j/k] Scroll   [o] View   [?] Help   [q] Quit "
            line_x = mx - 2  # Offset from start of line content

            # Find clickable regions dynamically
            view_start = controls.find("[o]")
            help_start = controls.find("[?]")
            quit_start = controls.find("[q]")

            if view_start != -1 and view_start <= line_x < view_start + len("[o] View"):
                self.show_script_content()
                return
            elif help_start != -1 and help_start <= line_x < help_start + len(
                "[?] Help"
            ):
                self.show_help()
                return
            elif quit_start != -1 and quit_start <= line_x < quit_start + len(
                "[q] Quit"
            ):
                # Signal to quit (handled in run loop via self.quit_requested)
                self.quit_requested = True
                return
            return

        # Ignore other footer clicks
        if my >= footer_y:
            return

        # Left scrollbar click
        if mx == left_scrollbar_x and start_row <= my < start_row + visible_height:
            if bstate & curses.BUTTON1_PRESSED:
                self.drag_state.active = True
                self.drag_state.panel = "left"
                self.drag_state.start_offset = self.left_scroll.offset
                self.drag_state.start_y = my
            self.left_scroll.set_from_scrollbar_click(my, start_row, visible_height)
            # Update viewing_idx to match scroll position
            self.viewing_idx = min(len(self.statuses) - 1, self.left_scroll.offset)
            self.focus_panel = "left"
            self.following = False
            return

        # Right scrollbar click
        if mx == right_scrollbar_x and start_row <= my < start_row + visible_height:
            if bstate & curses.BUTTON1_PRESSED:
                self.drag_state.active = True
                self.drag_state.panel = "right"
                self.drag_state.start_offset = self.right_scroll.offset
                self.drag_state.start_y = my
            self.right_scroll.set_from_scrollbar_click(my, start_row, visible_height)
            self.focus_panel = "right"
            self.following = False
            return

        # Left panel content click (select script)
        if mx < left_scrollbar_x and start_row <= my < start_row + visible_height:
            item_idx = self.left_scroll.offset + (my - start_row)
            if 0 <= item_idx < len(self.statuses):
                self.viewing_idx = item_idx
                self.right_scroll.offset = 0
                self.focus_panel = "left"
                # Resume following if we clicked on the running script
                self.following = item_idx == self.running_idx
            return

        # Right panel content click (focus right panel)
        if (
            list_width < mx < right_scrollbar_x
            and start_row <= my < start_row + visible_height
        ):
            self.focus_panel = "right"
            return

    def _handle_input_during_execution(self, key: int) -> None:
        """Handle keyboard and mouse input during script execution for log navigation.

        Allows users to browse logs of already-completed scripts while
        installation continues. Supports switching focus between left (script
        list) and right (output) panels for independent scrolling.
        """
        # Handle mouse events
        if key == curses.KEY_MOUSE:
            self._handle_mouse_during_execution()
            return

        # Vim-style gg (go to top) - detect 'g' followed by 'g'
        if key == ord("g"):
            if self._last_key == ord("g"):
                if self.focus_panel == "left":
                    self.viewing_idx = 0
                    self.left_scroll.go_top()
                    self.following = False
                else:
                    self.right_scroll.go_top()
                    self.following = False
                self._last_key = -1
            else:
                self._last_key = key
            return
        self._last_key = -1

        # Panel switching keys
        if key in (ord("h"), ord("a"), curses.KEY_LEFT, 27):  # 27 = Esc
            self.focus_panel = "left"
            return
        elif key in (ord("l"), ord("d"), curses.KEY_RIGHT, curses.KEY_ENTER, 10, 13):
            self.focus_panel = "right"
            return

        # Navigation behavior depends on focused panel
        if self.focus_panel == "left":
            # Left panel: navigate script list
            if key in (ord("w"), ord("k"), curses.KEY_UP):
                if self.viewing_idx > 0:
                    self.viewing_idx -= 1
                    self.right_scroll.offset = 0  # Reset scroll for new script
                    self.following = False
            elif key in (ord("s"), ord("j"), curses.KEY_DOWN):
                if self.viewing_idx < len(self.statuses) - 1:
                    self.viewing_idx += 1
                    self.right_scroll.offset = 0
                # Resume following if we've navigated back to running script
                if self.viewing_idx == self.running_idx:
                    self.following = True
            elif key == curses.KEY_PPAGE:  # Page Up
                self.viewing_idx = max(
                    0, self.viewing_idx - max(1, self.left_scroll.visible - 1)
                )
                self.right_scroll.offset = 0
                self.following = False
            elif key == curses.KEY_NPAGE:  # Page Down
                self.viewing_idx = min(
                    len(self.statuses) - 1,
                    self.viewing_idx + max(1, self.left_scroll.visible - 1),
                )
                self.right_scroll.offset = 0
                if self.viewing_idx == self.running_idx:
                    self.following = True
            elif key == ord("G"):
                # Jump to running script and resume following
                self.viewing_idx = self.running_idx
                self.following = True
                self.right_scroll.offset = 0
        else:
            # Right panel: scroll output
            if key in (ord("w"), ord("k"), curses.KEY_UP):
                self.right_scroll.scroll_up()
                self.following = False  # Manual scroll disables auto-follow
            elif key in (ord("s"), ord("j"), curses.KEY_DOWN):
                self.right_scroll.scroll_down()
                self.following = False
            elif key == curses.KEY_PPAGE:  # Page Up
                self.right_scroll.page_up()
                self.following = False
            elif key == curses.KEY_NPAGE:  # Page Down
                self.right_scroll.page_down()
                self.following = False
            elif key == ord("G"):
                # Jump to bottom of output and resume following
                self.right_scroll.go_bottom()
                self.following = True

        # Global keys (work regardless of focused panel)
        if key == ord("o"):
            self.show_script_content()
        elif key == ord("?"):
            self.show_help()
        elif key == ord("f"):
            # Toggle follow mode
            self.following = not self.following
            if self.following:
                self.viewing_idx = self.running_idx
        # Note: 'q' is handled in the run() loop, not here

    def _poll_input(self) -> None:
        """Poll for and handle any pending keyboard input (non-blocking).

        Uses a short timeout to allow multi-byte escape sequences (arrow keys)
        to be read correctly while remaining responsive.
        """
        self.stdscr.timeout(50)  # 50ms timeout for escape sequences
        while True:
            key = self.stdscr.getch()
            if key == -1:
                break
            self._handle_input_during_execution(key)
        self.stdscr.timeout(-1)  # Restore blocking

    def draw(self) -> None:
        """Draw the execution screen."""
        self.stdscr.erase()
        height, width = self.stdscr.getmaxyx()

        # Draw header
        self.draw_header(width)

        # Draw script list (left side)
        list_width = min(40, width // 2)
        self.draw_script_list(height, list_width)

        # Draw output panel (right side)
        self.draw_output_panel(height, width, list_width)

        # Draw footer
        self.draw_footer(height, width)

        self.stdscr.refresh()

    def _format_elapsed(self) -> str:
        """Format elapsed time as HH:MM:SS or MM:SS.

        Uses end_time if set (install complete), otherwise current time.
        """
        end = self.end_time if self.end_time is not None else time.monotonic()
        elapsed = int(end - self.start_time)
        hours, remainder = divmod(elapsed, 3600)
        minutes, seconds = divmod(remainder, 60)
        if hours > 0:
            return f"{hours:02d}:{minutes:02d}:{seconds:02d}"
        return f"{minutes:02d}:{seconds:02d}"

    # Braille column patterns for 2:1 compression mode
    # Left column uses dots 1,2,3,7; Right column uses dots 4,5,6,8
    # Braille base: U+2800, add dot bits to get character
    _LEFT_FULL = 0x47  # ⡇ (dots 1,2,3,7)
    _LEFT_MED = 0x46  # ⡆ (dots 2,3,7)
    _LEFT_MIN = 0x40  # ⡀ (dot 7 only)
    _RIGHT_FULL = 0xB8  # ⢸ (dots 4,5,6,8)
    _RIGHT_MED = 0xB0  # ⢰ (dots 5,6,8)
    _RIGHT_MIN = 0x80  # ⢀ (dot 8 only)

    # Fill animation frames for running script (shows "filling up" effect)
    # Fills bottom-to-top, left column first in each row
    _FILL_FRAMES_FULL = ["⡀", "⣀", "⣄", "⣤", "⣦", "⣶", "⣷", "⣿"]
    _FILL_FRAMES_LEFT = [0x40, 0x44, 0x46, 0x47]  # Left column fill progression
    _FILL_FRAMES_RIGHT = [0x80, 0xA0, 0xB0, 0xB8]  # Right column fill progression

    def _get_animation_frame(self, script_index: int = 0) -> int:
        """Get current animation frame index based on elapsed time.

        Args:
            script_index: Index of script for wave effect phase offset.
                Each script's animation is offset by 0.15s per index,
                creating a flowing wave across multiple running scripts.
        """
        base_time = time.monotonic() - self.start_time
        phase_offset = script_index * 0.15  # Wave offset per script
        return int((base_time + phase_offset) / 0.1)

    def _state_to_pattern(
        self, state: ScriptState, is_left: bool, frame_idx: int
    ) -> int:
        """Convert a script state to a braille column pattern.

        Args:
            state: Script state enum value.
            is_left: True for left column, False for right column.
            frame_idx: Animation frame index for running scripts.

        Returns:
            Braille bit pattern for the column.
        """
        if is_left:
            if state == ScriptState.SUCCESS:
                return self._LEFT_FULL
            elif state == ScriptState.FAILED:
                return self._LEFT_MED  # Distinctive but not full
            elif state == ScriptState.RUNNING:
                return self._FILL_FRAMES_LEFT[frame_idx % len(self._FILL_FRAMES_LEFT)]
            elif state == ScriptState.SKIPPED:
                return self._LEFT_MED
            else:  # PENDING
                return self._LEFT_MIN
        else:
            if state == ScriptState.SUCCESS:
                return self._RIGHT_FULL
            elif state == ScriptState.FAILED:
                return self._RIGHT_MED
            elif state == ScriptState.RUNNING:
                return self._FILL_FRAMES_RIGHT[frame_idx % len(self._FILL_FRAMES_RIGHT)]
            elif state == ScriptState.SKIPPED:
                return self._RIGHT_MED
            else:  # PENDING
                return self._RIGHT_MIN

    def _worst_state(self, states: list[ScriptState]) -> ScriptState:
        """Return the worst state from a list (for color selection)."""
        return min(states, key=lambda s: s.priority)

    def _build_progress_bar(self, max_width: int) -> list[tuple[str, ColorName]]:
        """Build a braille progress bar showing per-script status.

        Always shows all scripts by using compression or aggregation:
        - 1:1 mode: Each script = one character (when scripts <= width)
        - 2:1 mode: Two scripts per character using left/right halves
        - N:1 mode: Multiple scripts per character (aggregated)

        Args:
            max_width: Maximum number of characters to display.

        Returns:
            List of (character, color_name) tuples for per-character rendering.
        """
        num_scripts = len(self.statuses)

        # Mode 1: Direct 1:1 mapping (all scripts fit)
        if num_scripts <= max_width:
            segments: list[tuple[str, ColorName]] = []
            for idx, status in enumerate(self.statuses):
                if status.state == ScriptState.RUNNING:
                    # Wave effect: each running script has phase offset
                    frame_idx = self._get_animation_frame(idx)
                    char = self._FILL_FRAMES_FULL[
                        frame_idx % len(self._FILL_FRAMES_FULL)
                    ]
                elif status.state == ScriptState.SUCCESS:
                    char = "⣿"
                elif status.state == ScriptState.FAILED:
                    char = "⣠"
                elif status.state == ScriptState.SKIPPED:
                    char = "⣤"
                else:  # PENDING
                    char = "⣀"
                segments.append((char, status.state.color_name))
            return segments

        # Mode 2: 2:1 compression (two scripts per character)
        if num_scripts <= max_width * 2:
            segments = []
            for batch_idx, batch in enumerate(batched(self.statuses, 2)):
                left_idx = batch_idx * 2
                left_state = batch[0].state
                right_state = batch[1].state if len(batch) > 1 else ScriptState.PENDING

                # Wave animation with per-script phase offset
                left_frame = self._get_animation_frame(left_idx)
                right_frame = (
                    self._get_animation_frame(left_idx + 1) if len(batch) > 1 else 0
                )
                left_pattern = self._state_to_pattern(left_state, True, left_frame)
                right_pattern = self._state_to_pattern(right_state, False, right_frame)
                combined = chr(0x2800 | left_pattern | right_pattern)

                # Use worst state for color
                worst = self._worst_state([left_state, right_state])
                segments.append((combined, worst.color_name))
            return segments

        # Mode 3: N:1 aggregation (multiple scripts per character)
        scripts_per_char = math.ceil(num_scripts / max_width)
        segments = []
        for batch_idx, batch in enumerate(batched(self.statuses, scripts_per_char)):
            group_states = [s.state for s in batch]
            worst = self._worst_state(group_states)

            # Character based on completion ratio in group
            completed = sum(1 for s in group_states if s in COMPLETED_STATES)
            ratio = completed / len(batch)

            if ScriptState.RUNNING in group_states:
                # Wave animation - use index of first running script in group
                base_idx = batch_idx * scripts_per_char
                running_offset = next(
                    (j for j, s in enumerate(batch) if s.state == ScriptState.RUNNING),
                    0,
                )
                frame_idx = self._get_animation_frame(base_idx + running_offset)
                char = self._FILL_FRAMES_FULL[frame_idx % len(self._FILL_FRAMES_FULL)]
            elif ratio >= 1.0:
                char = "⣿"
            elif ratio >= 0.75:
                char = "⣷"
            elif ratio >= 0.5:
                char = "⣶"
            elif ratio >= 0.25:
                char = "⣤"
            else:
                char = "⣀"

            segments.append((char, worst.color_name))

        return segments

    def draw_header(self, width: int) -> None:
        """Draw the header with btop-style tab, elapsed time, and sparkline."""
        completed = sum(1 for s in self.statuses if s.state in COMPLETED_STATES)
        total = len(self.statuses)

        # Determine title and color based on state
        if self.cancelled:
            title = "Installation Cancelled"
            title_color = self.colors["yellow"]
        elif completed == total:
            failed = sum(1 for s in self.statuses if s.state == ScriptState.FAILED)
            if failed > 0:
                title = f"Complete - {failed} Failed"
                title_color = self.colors["red"]
            else:
                title = "✓ Complete"
                title_color = self.colors["green"]
        else:
            running_count = sum(1 for s in self.statuses if s.state == ScriptState.RUNNING)
            if running_count > 0:
                title = f"Installing {completed}/{total} ({running_count} active)"
            else:
                title = f"Installing {completed}/{total}"
            title_color = self.colors["cyan"]

        if self.dry_run:
            title = f"[DRY RUN] {title}"

        # Build tab-style header with elapsed time
        elapsed = self._format_elapsed()
        header_line = make_panel_header(title, width, elapsed)
        self.stdscr.attron(title_color | self.colors["bold"])
        self.safe_addstr(0, 0, header_line[:width])
        self.stdscr.attroff(title_color | self.colors["bold"])

        # Draw unified braille progress bar on line 1
        # Layout: "   [braille bar] [pct]%"
        if total > 0:
            pct = int(100 * completed / total)
            pct_str = f" {pct:3d}%"

            # Calculate available width for braille bar
            # Leave space for: 3 leading spaces + percentage (5 chars) + 2 trailing
            bar_width = width - 10
            if bar_width > 0:
                # Draw leading spaces
                self.safe_addstr(1, 2, "  ", self.colors["dim"])

                # Draw braille progress bar with per-character colors
                bar_x = 4
                for char, color_name in self._build_progress_bar(bar_width):
                    if bar_x >= width - 7:  # Leave room for percentage
                        break
                    self.safe_addstr(1, bar_x, char, self.colors[color_name])
                    bar_x += 1

                # Draw percentage at the end
                self.safe_addstr(1, bar_x, pct_str, self.colors["cyan"])

    def draw_script_list(self, height: int, list_width: int) -> None:
        """Draw the list of scripts with status indicators."""
        # Scripts start at row 2 (after header rows 0-1)
        start_row = 2
        visible_height = height - 5  # Accounts for header (2) + footer (3)

        # Update scroll state
        self.left_scroll.total = len(self.statuses)
        self.left_scroll.visible = visible_height
        self.left_scroll.ensure_visible(self.viewing_idx)

        # Draw separator with focus-aware styling
        scrollbar_x = list_width - 1
        separator_x = list_width
        sep_color = (
            self.colors["cyan"] if self.focus_panel == "left" else self.colors["dim"]
        )
        for y in range(start_row, height - 3):
            try:
                self.stdscr.addch(y, separator_x, "│", sep_color)
            except curses.error:
                pass

        for i in range(visible_height):
            idx = self.left_scroll.offset + i
            if idx >= len(self.statuses):
                break

            status = self.statuses[idx]
            y = start_row + i
            is_viewing = idx == self.viewing_idx
            is_running = idx == self.running_idx
            # Reserve 1 column for scrollbar
            self.draw_status_line(y, list_width - 2, status, is_viewing, is_running)

        # Draw scrollbar with focus-aware styling
        left_focused = self.focus_panel == "left"
        scrollbar_color = self.colors["cyan"] if left_focused else self.colors["dim"]
        draw_scrollbar(
            self.stdscr,
            x=scrollbar_x,
            y_start=start_row,
            height=visible_height,
            scroll=self.left_scroll,
            color=scrollbar_color,
            focused=left_focused,
        )

    def draw_status_line(
        self,
        y: int,
        width: int,
        status: ScriptStatus,
        is_viewing: bool,
        is_running: bool,
    ) -> None:
        """Draw a single script status line.

        Args:
            y: Row position to draw at.
            width: Available width for the line.
            status: The ScriptStatus object to display.
            is_viewing: Whether this is the script the user is currently viewing.
            is_running: Whether this is the currently running (or last run) script.
        """
        # Status indicator based on script execution state (from enum, with spinner override)
        state = status.state
        if state == ScriptState.RUNNING:
            indicator = self.spinner.frame()  # Animated spinner for running scripts
        else:
            indicator = state.indicator
        color = self.colors[state.color_name]

        # Show cursor marker for running script when user is viewing elsewhere
        cursor = "»" if is_running and not is_viewing else " "

        # Calculate duration string for running/completed scripts
        dur_str = ""
        if status.start_time is not None:
            if status.end_time is not None:
                # Completed: show final duration with one decimal
                dur = status.end_time - status.start_time
                dur_str = f"{dur:.1f}s"
            elif state == ScriptState.RUNNING:
                # Running: show live counter (no decimal, with ellipsis)
                dur = time.monotonic() - status.start_time
                dur_str = f"{dur:.0f}s…"

        # Build line with duration right-aligned
        # Format: "»⠋ Name                 12s…"
        prefix = f"{cursor}{indicator} "
        name = status.script.display_name
        if dur_str:
            # Reserve space for duration (right-aligned)
            name_width = width - len(prefix) - len(dur_str) - 1
            if name_width > 0:
                line = f"{prefix}{name[:name_width].ljust(name_width)} {dur_str}"
            else:
                line = f"{prefix}{name}"[:width]
        else:
            line = f"{prefix}{name}"

        # Combine color with reverse highlight if this script is being viewed
        attr = color | self.colors["reverse"] if is_viewing else color
        self.stdscr.addstr(y, 0, line[:width].ljust(width), attr)

    def draw_output_panel(self, height: int, width: int, list_width: int) -> None:
        """Draw the live output panel for the currently viewed script."""
        panel_x = list_width + 1
        panel_width = width - list_width - 3  # Reserve 1 column for scrollbar
        panel_height = height - 5
        scrollbar_x = width - 1

        # Get viewed script's output
        if 0 <= self.viewing_idx < len(self.statuses):
            viewed = self.statuses[self.viewing_idx]
            raw_lines = viewed.output_lines
        else:
            raw_lines = []

        # Strip ANSI codes and wrap lines to panel width
        # Command lines (starting with "$ ") get continuation aligned after the prefix
        cleaned_lines = [strip_ansi(line) for line in raw_lines]
        wrapped_lines = []
        for line in cleaned_lines:
            line = line.expandtabs(4).rstrip()
            # Detect command prefix like "  $ " and align continuation after it
            if match := re.match(r"^(\s*\$\s)", line):
                indent = len(match.group(1))
            else:
                indent = 2
            wrapped_lines.extend(wrap_line(line, panel_width, indent))

        # Update scroll state using wrapped line count
        self.right_scroll.total = len(wrapped_lines)
        self.right_scroll.visible = panel_height

        # Auto-scroll to bottom only when following the running script
        if self.following:
            self.right_scroll.go_bottom()
        else:
            self.right_scroll.clamp()

        # Draw output lines (starting at row 2, after header)
        start_row = 2
        for i in range(panel_height):
            line_idx = self.right_scroll.offset + i
            y = start_row + i

            # Clear the line area first
            self.safe_addstr(y, panel_x, " " * panel_width)

            if line_idx < len(wrapped_lines):
                line = wrapped_lines[line_idx]
                self.safe_addstr(y, panel_x, line, self.colors["dim"])

        # Draw scrollbar with focus-aware styling
        right_focused = self.focus_panel == "right"
        scrollbar_color = self.colors["cyan"] if right_focused else self.colors["dim"]
        draw_scrollbar(
            self.stdscr,
            x=scrollbar_x,
            y_start=start_row,
            height=panel_height,
            scroll=self.right_scroll,
            color=scrollbar_color,
            focused=right_focused,
        )

    def draw_footer(self, height: int, width: int) -> None:
        """Draw the footer with navigation hints."""
        footer_y = height - 3

        # Separator
        self.stdscr.addstr(footer_y, 0, "─" * width, self.colors["dim"])

        # Status line showing viewed script and focused panel
        if self.viewing_idx < len(self.statuses):
            viewed = self.statuses[self.viewing_idx]
            panel_indicator = "◀ scripts" if self.focus_panel == "left" else "output ▶"
            status_text = f" {viewed.section.name} / {viewed.script.display_name} [{panel_indicator}]"
            if not self.following:
                status_text += " (browsing)"
        else:
            status_text = " Complete "

        self.stdscr.addstr(
            footer_y + 1, 2, status_text[: width - 4], self.colors["cyan"]
        )

        # Controls with navigation hints
        controls = " [h/l] Panel   [j/k] Scroll   [o] View   [?] Help   [q] Quit "
        self.stdscr.addstr(footer_y + 2, 2, controls[: width - 4], self.colors["dim"])

    def show_help(self) -> None:
        """Display a help overlay with keyboard shortcuts."""
        self.show_help_overlay(EXECUTION_SHORTCUTS, EXECUTION_FOOTER_NOTES)

    def show_script_content(self) -> None:
        """Display the currently viewed script's content in an overlay.

        Shows the shell script file in a scrollable box overlay.
        Supports: scrollbar clicks, scroll wheel, click outside to close.
        """
        if self.viewing_idx >= len(self.statuses):
            return

        status = self.statuses[self.viewing_idx]
        script_path = self.scripts_dir / status.script.path

        # Read script file
        try:
            with open(script_path) as f:
                content = f.read()
        except (OSError, IOError) as e:
            content = f"Error reading script: {e}"

        lines = content.split("\n")

        # Overlay dimensions
        height, width = self.stdscr.getmaxyx()
        box_width = min(width - 4, 100)
        box_height = height - 4
        start_x = (width - box_width) // 2
        start_y = 2

        # Content area (inside box borders)
        content_width = box_width - 4
        content_height = box_height - 4

        # Wrap lines to content width
        wrapped_lines = wrap_lines(lines, content_width)

        # Scroll state for the overlay
        scroll = ScrollState(offset=0, total=len(wrapped_lines), visible=content_height)
        last_key = -1
        drag_state = DragState()

        # Scrollbar position
        scrollbar_x = start_x + box_width - 2
        content_start_y = start_y + 1

        # Track last known state to detect changes
        last_running_idx = self.running_idx
        install_active = self.end_time is None

        # Draw background initially
        self.draw()

        # Use longer timeout (500ms) during install to reduce flicker while still updating
        # Use blocking input after install completes
        self.stdscr.timeout(500 if install_active else -1)

        while True:
            # Check if background state changed (new script started)
            if install_active and self.running_idx != last_running_idx:
                last_running_idx = self.running_idx
                self.draw()  # Only redraw when there's actual progress
                # Check if install just completed
                if self.end_time is not None:
                    install_active = False
                    self.stdscr.timeout(-1)

            # Draw overlay on top - clear box area
            for y in range(box_height):
                self.safe_addstr(start_y + y, start_x, " " * box_width)

            # Draw box borders with title and scroll info
            visible_end = min(scroll.offset + content_height, len(wrapped_lines))
            self.draw_overlay_box(
                start_x,
                start_y,
                box_width,
                box_height,
                status.script.path,
                (scroll.offset, visible_end, len(wrapped_lines)),
            )

            # Draw content lines
            for i in range(content_height):
                line_idx = scroll.offset + i
                line = wrapped_lines[line_idx] if line_idx < len(wrapped_lines) else ""
                self.safe_addstr(
                    start_y + 1 + i, start_x + 2, line.ljust(content_width)
                )

            # Draw scrollbar
            draw_scrollbar(
                self.stdscr,
                scrollbar_x,
                content_start_y,
                content_height,
                scroll,
                self.colors["cyan"],
            )

            self.stdscr.refresh()

            # Handle input
            key = self.stdscr.getch()

            # Timeout - continue loop to check for background updates
            if key == -1:
                continue

            if key == curses.KEY_MOUSE:
                try:
                    _, mx, my, _, bstate = curses.getmouse()

                    # Click outside box closes overlay
                    if bstate & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED):
                        if not (
                            start_x <= mx < start_x + box_width
                            and start_y <= my < start_y + box_height
                        ):
                            break

                        # Scrollbar drag
                        if mx == scrollbar_x:
                            drag_state.active = True
                            drag_state.start_y = my
                            drag_state.start_offset = scroll.offset

                    # Scroll wheel
                    handle_scroll_wheel(bstate, scroll, amount=3)

                    # Drag release
                    if bstate & curses.BUTTON1_RELEASED:
                        drag_state.active = False

                    # Handle drag
                    handle_scrollbar_drag(my, content_height, scroll, drag_state)

                except curses.error:
                    pass
                continue

            # Vim-style gg
            if key == ord("g"):
                if last_key == ord("g"):
                    scroll.go_top()
                    last_key = -1
                else:
                    last_key = key
                continue
            last_key = -1

            # Navigation keys
            if key in (ord("j"), curses.KEY_DOWN):
                scroll.scroll_down(1)
            elif key in (ord("k"), curses.KEY_UP):
                scroll.scroll_up(1)
            elif key == curses.KEY_NPAGE:
                scroll.page_down()
            elif key == curses.KEY_PPAGE:
                scroll.page_up()
            elif key == ord("G"):
                scroll.go_bottom()
            elif key in (ord("q"), ord("o"), 27):  # q, o, or Esc closes
                break

    def _execute_script(self, status: ScriptStatus, silent: bool = False) -> bool:
        """Execute a script and update its status.

        Args:
            status: ScriptStatus object to update.
            silent: If True, capture output without PTY (for parallel execution).
                   If False, use PTY for live output with display updates.

        Returns:
            True on success, False on failure.
        """
        script_path = self.scripts_dir / status.script.path

        if not script_path.exists() or not os.access(script_path, os.X_OK):
            status.output_lines.append(
                f"Script not found or not executable: {script_path}"
            )
            status.end_time = time.monotonic()
            status.state = ScriptState.FAILED
            status.exit_code = 1
            return False

        # Enable streaming output for TUI display (live output in right panel)
        env = prepare_script_env(self.dry_run, self.headless, stream_output=True)
        bash_cmd = build_script_command(self.scripts_dir, script_path)

        try:
            if silent:
                # Streaming capture for parallel execution
                # Uses Popen with line-buffered pipes so output appears live in TUI
                process = subprocess.Popen(
                    ["bash", "-c", bash_cmd],
                    env=env,
                    cwd=self.scripts_dir.parent,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,  # Merge stderr into stdout
                    text=True,
                    bufsize=1,  # Line buffered
                )

                # Read output incrementally (thread-safe append to list)
                if process.stdout is not None:
                    for line in process.stdout:
                        status.output_lines.append(line.rstrip())
                process.wait()

                status.exit_code = process.returncode
            else:
                # PTY for live output with display updates and keyboard input
                master_fd, slave_fd = pty.openpty()
                process = subprocess.Popen(
                    ["bash", "-c", bash_cmd],
                    stdout=slave_fd,
                    stderr=slave_fd,
                    stdin=subprocess.DEVNULL,
                    env=env,
                    cwd=self.scripts_dir.parent,
                )
                os.close(slave_fd)

                # Enable non-blocking keyboard input with short timeout for escape sequences
                self.stdscr.timeout(50)  # 50ms allows arrow key sequences to be read

                # Read output with non-blocking I/O
                while True:
                    retcode = process.poll()

                    # Poll for keyboard input (non-blocking with timeout)
                    key = self.stdscr.getch()
                    if key != -1:
                        self._handle_input_during_execution(key)

                    ready, _, _ = select.select([master_fd], [], [], 0.08)
                    if ready:
                        try:
                            data = os.read(master_fd, 4096)
                            if data:
                                text = data.decode("utf-8", errors="replace")
                                for line in text.split("\n"):
                                    if line:
                                        status.output_lines.append(line)
                        except OSError:
                            break

                    # Always redraw to animate spinner (select timeout ~80ms = spinner frame rate)
                    self.draw()

                    if retcode is not None:
                        # Drain remaining output
                        while True:
                            ready, _, _ = select.select([master_fd], [], [], 0)
                            if not ready:
                                break
                            try:
                                data = os.read(master_fd, 4096)
                                if not data:
                                    break
                                for line in data.decode(
                                    "utf-8", errors="replace"
                                ).split("\n"):
                                    if line:
                                        status.output_lines.append(line)
                            except OSError:
                                break
                        break

                os.close(master_fd)
                self.stdscr.timeout(-1)  # Restore blocking input
                status.exit_code = process.returncode

            # Update state based on exit code
            status.end_time = time.monotonic()
            if status.exit_code == 0:
                status.state = ScriptState.SUCCESS
                return True
            else:
                status.state = ScriptState.FAILED
                return False

        except Exception as e:
            status.output_lines.append(
                f"Error executing {status.script.path}: {type(e).__name__}: {e}"
            )
            status.end_time = time.monotonic()
            status.state = ScriptState.FAILED
            status.exit_code = 1
            return False

    def run_script(self, status: ScriptStatus) -> bool:
        """Run a single script with live output capture. Returns True on success."""
        status.state = ScriptState.RUNNING
        self.draw()
        return self._execute_script(status, silent=False)

    def run(self) -> tuple[int, int]:
        """Run all selected scripts with dependency-aware parallelism.

        Uses continuous scheduling: scripts start as soon as their dependencies
        are satisfied and required locks are available.

        Returns (success_count, fail_count).
        """
        self.stdscr.keypad(True)  # Enable arrow key recognition

        # Prepare environment
        env = prepare_script_env(self.dry_run, self.headless, stream_output=True)

        # Write log header
        self._logger.write_header()

        # Define TUI-specific callbacks for the parallel scheduler
        def run_live(status: ScriptStatus) -> bool:
            """Run a non-parallel script with live output in TUI."""
            self._set_running_idx(self.statuses.index(status))
            self._poll_input()
            self.draw()
            return self.run_script(status)

        def run_silent(status: ScriptStatus) -> bool:
            """Run a parallel script silently."""
            return self._run_script_silent(status)

        def on_update() -> None:
            """Update TUI display and handle input."""
            # Update running index to first running script
            running_scripts = [
                s for s in self.statuses if s.state == ScriptState.RUNNING
            ]
            if running_scripts:
                self._set_running_idx(self.statuses.index(running_scripts[0]))
            self._poll_input()
            self.draw()

        def is_cancelled() -> bool:
            """Check if user cancelled execution."""
            return self.cancelled

        # Run the parallel scheduler
        success_count, fail_count = run_scripts_parallel(
            statuses=self.statuses,
            manifest=self.manifest,
            scripts_dir=self.scripts_dir,
            env=env,
            logger=self._logger,
            run_live=run_live,
            run_silent=run_silent,
            on_update=on_update,
            is_cancelled=is_cancelled,
        )

        # Freeze elapsed time at completion and write log summary
        self.end_time = time.monotonic()
        self._logger.write_summary(self.end_time)

        # Final draw and allow browsing until 'q' is pressed
        self.draw()

        # Allow user to continue browsing logs after completion
        self.stdscr.timeout(-1)  # Blocking input
        while True:
            key = self.stdscr.getch()
            if key == ord("q") or self.quit_requested:
                break
            self._handle_input_during_execution(key)
            if self.quit_requested:
                break
            self.draw()

        return success_count, fail_count

    def _run_script_silent(self, status: ScriptStatus) -> bool:
        """Run a script without display updates (for parallel execution)."""
        return self._execute_script(status, silent=True)


###############################################################################
### Main Entry Point
###############################################################################


def get_script_dir() -> Path:
    """Get the directory containing this script."""
    return Path(__file__).parent.resolve()


def run_interactive(
    stdscr: curses.window, manifest: Manifest, scripts_dir: Path, dry_run: bool
) -> int:
    """Run the interactive TUI. Returns exit code."""
    # Selection phase
    selection_tui = SelectionTUI(stdscr, manifest, scripts_dir)
    if not selection_tui.run():
        return 0  # User quit

    # Check if any scripts selected
    enabled = manifest.get_enabled_scripts()
    if not enabled:
        return 0

    # Prompt for sudo if needed (exit curses temporarily)
    curses.endwin()
    if not prompt_sudo_if_needed(enabled):
        return 0  # User cancelled
    stdscr.refresh()  # Restore curses screen

    # Determine if headless mode based on selected preset
    preset = PRESETS.get(selection_tui.current_preset)
    headless = preset.is_headless if preset else False

    # Execution phase
    execution_tui = ExecutionTUI(
        stdscr, manifest, scripts_dir, dry_run=dry_run, headless=headless
    )
    success, fail = execution_tui.run()

    return 1 if fail > 0 else 0


def _execute_cli_script(
    status: ScriptStatus,
    scripts_dir: Path,
    env: dict[str, str],
    verbose: bool,
) -> bool:
    """Execute a script in CLI mode (non-TUI).

    Handles both verbose (streaming) and non-verbose (spinner) modes.
    Updates status.state, status.exit_code, and status.output_lines.

    Args:
        status: ScriptStatus to execute and update.
        scripts_dir: Path to install_scripts directory.
        env: Environment variables for execution.
        verbose: If True, stream output live; otherwise use spinner.

    Returns:
        True on success, False on failure.
    """
    script = status.script
    section = status.section
    script_path = scripts_dir / script.path

    if not script_path.exists() or not os.access(script_path, os.X_OK):
        print(f"✗ {script.display_name} (not found or not executable)", flush=True)
        status.end_time = time.monotonic()
        status.state = ScriptState.FAILED
        status.exit_code = 1
        status.output_lines.append("Script not found or not executable")
        return False

    if verbose:
        # Stream output live for debugging
        print(f"▶ {section.name} / {script.display_name}", flush=True)
        print("─" * 60, flush=True)
        try:
            bash_cmd = build_script_command(scripts_dir, script_path)
            process = subprocess.Popen(
                ["bash", "-c", bash_cmd],
                env=env,
                cwd=scripts_dir.parent,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )
            if process.stdout is not None:
                for line in process.stdout:
                    print(f"    {line}", end="", flush=True)
                    status.output_lines.append(line.rstrip())
            process.wait()
            status.exit_code = process.returncode

            status.end_time = time.monotonic()
            if process.returncode == 0:
                print(f"✓ {script.display_name} succeeded", flush=True)
                status.state = ScriptState.SUCCESS
                print(flush=True)
                return True
            else:
                print(f"✗ {script.display_name} failed (exit code {process.returncode})", flush=True)
                status.state = ScriptState.FAILED
                print(flush=True)
                return False
        except Exception as e:
            print(f"✗ {script.display_name} failed: {e}", flush=True)
            status.end_time = time.monotonic()
            status.state = ScriptState.FAILED
            status.exit_code = 1
            status.output_lines.append(str(e))
            print(flush=True)
            return False
    else:
        # Use spinner while script runs
        spinner = ThreadedSpinner(f"{script.display_name}...")
        spinner.start()

        try:
            result = run_script_simple(script_path, scripts_dir, env)
            status.exit_code = result.returncode
            if result.stdout:
                status.output_lines.extend(result.stdout.strip().split("\n"))
            if result.stderr:
                status.output_lines.extend(result.stderr.strip().split("\n"))

            status.end_time = time.monotonic()
            if result.returncode == 0:
                spinner.stop("✓")
                status.state = ScriptState.SUCCESS
                return True
            else:
                spinner.stop("✗")
                status.state = ScriptState.FAILED
                if result.stderr:
                    for line in result.stderr.strip().split("\n")[:5]:
                        print(f"    {line}")
                return False
        except Exception as e:
            spinner.stop("✗")
            print(f"    {type(e).__name__}: {e}")
            status.end_time = time.monotonic()
            status.state = ScriptState.FAILED
            status.exit_code = 1
            status.output_lines.append(f"{type(e).__name__}: {e}")
            return False


def run_non_interactive(
    manifest: Manifest,
    scripts_dir: Path,
    dry_run: bool,
    headless: bool = False,
    verbose: bool = False,
) -> int:
    """Run scripts without TUI using parallel scheduler. Returns exit code.

    Args:
        manifest: Parsed manifest with script selections.
        scripts_dir: Path to install_scripts directory.
        dry_run: If True, preview changes without executing.
        headless: If True, skip GUI-only packages.
        verbose: If True, stream live script output (useful for Docker/CI).
    """
    enabled = manifest.get_enabled_scripts()
    if not enabled:
        print("No scripts selected.")
        return 0

    # Prompt for sudo if needed
    if not prompt_sudo_if_needed(enabled):
        return 0  # User cancelled

    # Build status list for logging (same structure as ExecutionTUI)
    statuses = [
        ScriptStatus(section=section, script=script) for section, script in enabled
    ]

    # Create logger
    start_time = time.monotonic()
    logger = InstallLogger(
        scripts_dir=scripts_dir,
        dry_run=dry_run,
        headless=headless,
        statuses=statuses,
        start_time=start_time,
    )

    print(f"\n{'=' * 60}", flush=True)
    print(f" Installing {len(enabled)} components...", flush=True)
    if headless:
        print(" (Headless mode - skipping GUI packages)", flush=True)
    if verbose:
        print(" (Verbose mode - streaming script output)", flush=True)
    print(f"{'=' * 60}\n", flush=True)

    env = prepare_script_env(dry_run, headless)

    # Define CLI-specific callbacks for the parallel scheduler
    def run_live(status: ScriptStatus) -> bool:
        """Run a non-parallel script with output display."""
        return _execute_cli_script(status, scripts_dir, env, verbose)

    def run_silent(status: ScriptStatus) -> bool:
        """Run a parallel script silently (captured output)."""
        return _execute_cli_script(status, scripts_dir, env, verbose=False)

    # Run the parallel scheduler (write_header called inside)
    logger.write_header()
    success_count, fail_count = run_scripts_parallel(
        statuses=statuses,
        manifest=manifest,
        scripts_dir=scripts_dir,
        env=env,
        logger=logger,
        run_live=run_live,
        run_silent=run_silent,
        on_update=None,  # CLI doesn't need periodic updates
        is_cancelled=None,  # CLI doesn't support cancellation
    )

    # Write summary
    end_time = time.monotonic()
    logger.write_summary(end_time)

    print(f"\n{'=' * 60}", flush=True)
    print(f" Complete: {success_count} succeeded, {fail_count} failed", flush=True)
    print(f"{'=' * 60}\n", flush=True)

    # Show log location
    console_path, _ = logger.get_log_paths()
    print(f" Log: {console_path}", flush=True)

    return 1 if fail_count > 0 else 0


def list_presets() -> None:
    """Print available presets."""
    print("\nAvailable presets:\n")
    for key, preset in PRESETS.items():
        print(f"  [{key}] {preset.description}")
        if preset.disabled_sections:
            print(f"       Disables sections: {', '.join(preset.disabled_sections)}")
        if preset.flags:
            flag_desc = []
            if "no_sudo" in preset.flags:
                flag_desc.append("scripts requiring sudo")
            if "headless" in preset.flags:
                flag_desc.append("GUI-only scripts")
            if flag_desc:
                print(f"       Disables: {', '.join(flag_desc)}")
    print()


def main() -> int:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Peter Sharpe's Linux Setup - Interactive TUI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  setup                    Interactive TUI mode
  setup --preset 1         Non-interactive with Desktop preset
  setup --preset 2         Non-interactive with Headless preset
  setup --list             Show available presets
  setup --dry-run          Preview changes without making them
  setup --export sel.json  Export current selections
  setup --import sel.json  Import selections from file
  setup --docs             Generate markdown documentation
""",
    )
    parser.add_argument(
        "-p",
        "--preset",
        metavar="N",
        help="Apply preset N and run non-interactively",
    )
    parser.add_argument(
        "-l",
        "--list",
        action="store_true",
        help="List available presets",
    )
    parser.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="Dry run mode (preview changes)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Stream live script output (useful for Docker/CI debugging)",
    )
    parser.add_argument(
        "--export",
        metavar="FILE",
        help="Export current selections to JSON file",
    )
    parser.add_argument(
        "--import",
        dest="import_file",
        metavar="FILE",
        help="Import selections from JSON file",
    )
    parser.add_argument(
        "--docs",
        action="store_true",
        help="Generate markdown documentation from script metadata",
    )

    args = parser.parse_args()

    # Find paths
    script_dir = get_script_dir()
    manifest_path = script_dir / "install_scripts" / "manifest.conf"
    scripts_dir = script_dir / "install_scripts"

    if not manifest_path.exists():
        print(f"Error: Manifest not found: {manifest_path}", file=sys.stderr)
        return 1

    # List presets
    if args.list:
        list_presets()
        return 0

    # Parse manifest (with metadata)
    manifest = Manifest.from_file(manifest_path, scripts_dir)

    # Generate documentation
    if args.docs:
        manifest.generate_docs()
        return 0

    # Export selections
    if args.export:
        # Apply preset if specified, otherwise use preset 1 (all enabled)
        if args.preset:
            manifest.apply_preset(args.preset)
        else:
            manifest.apply_preset("1")
        manifest.export_selections(Path(args.export))
        return 0

    # Import selections
    if args.import_file:
        import_path = Path(args.import_file)
        if not import_path.exists():
            print(f"Error: Import file not found: {import_path}", file=sys.stderr)
            return 1
        manifest.import_selections(import_path)
        # When importing, check if HEADLESS was set in environment or default to N
        headless = os.environ.get("HEADLESS", "N") == "Y"
        return run_non_interactive(
            manifest, scripts_dir, args.dry_run, headless, args.verbose
        )

    # Non-interactive mode with preset
    if args.preset:
        if args.preset not in PRESETS:
            print(f"Error: Unknown preset '{args.preset}'", file=sys.stderr)
            print("Use --list to see available presets.", file=sys.stderr)
            return 1
        manifest.apply_preset(args.preset)
        headless = PRESETS[args.preset].is_headless
        return run_non_interactive(
            manifest, scripts_dir, args.dry_run, headless, args.verbose
        )

    # Interactive mode
    try:
        return curses.wrapper(
            lambda stdscr: run_interactive(stdscr, manifest, scripts_dir, args.dry_run)
        )
    except KeyboardInterrupt:
        print("\nCancelled.")
        return 130


if __name__ == "__main__":
    sys.exit(main())
