#!/bin/bash

set -euo pipefail

### Configuration
SLURM_GROUP="coreai_modulus_cae"
CURRENT_USER="${USER}"

### Setup scope variables
SSHARE_ACCOUNT="-A ${SLURM_GROUP}"
SSHARE_SCOPE="-a"
SQUEUE_SCOPE="-A ${SLURM_GROUP}"
SQUEUE_STATE=""

### Parse command line arguments
SHOW_HELP=false
SCOPE_MODE="group"
RUNNING_ONLY=false
SHOW_TIMING=false

# Process long options first, convert to short options
ARGS=()
for arg in "$@"; do
    case "$arg" in
        --help)
            ARGS+=("-h")
            ;;
        --me)
            ARGS+=("-m")
            ;;
        --all)
            ARGS+=("-a")
            ;;
        --running)
            ARGS+=("-r")
            ;;
        --timing)
            ARGS+=("-t")
            ;;
        -*)
            ARGS+=("$arg")
            ;;
        *)
            echo "Unknown argument: $arg" >&2
            echo "Use --help for usage information" >&2
            exit 1
            ;;
    esac
done

# Use getopts to parse short options (including combined flags)
set -- "${ARGS[@]}"
while getopts "hmart" opt; do
    case "$opt" in
        h)
            SHOW_HELP=true
            ;;
        m)
            SCOPE_MODE="me"
            ;;
        a)
            SCOPE_MODE="all"
            ;;
        r)
            RUNNING_ONLY=true
            ;;
        t)
            SHOW_TIMING=true
            ;;
        \?)
            echo "Invalid option: -$OPTARG" >&2
            echo "Use --help for usage information" >&2
            exit 1
            ;;
    esac
done

if [[ "$SHOW_HELP" == true ]]; then
cat << EOF
Usage: sq [OPTION]...

Display Slurm queue and share information with colorized output.

Scope options (mutually exclusive):
  (none)         Show jobs and shares for your group (${SLURM_GROUP})
  --me,   -m     Show only your jobs and share information
  --all,  -a     Show all jobs and shares across the entire cluster

Filter options (can be combined with scope options):
  --running, -r  Show only running jobs (not pending)
  --timing,  -t  Show estimated start time for pending Priority jobs

Other options:
  --help, -h     Display this help message

Cluster status (all partitions):
  - 2D table: one row per partition, columns for each node state
  - Partitions sorted by total node count; GPU count shown as suffix
  - Empty partitions (0 nodes) are hidden
  - $(tput setaf 1)red$(tput sgr0)=alloc, $(tput setaf 2)green$(tput sgr0)=idle, $(tput setaf 3)yellow$(tput sgr0)=mixed, $(tput setaf 4)blue$(tput sgr0)=completing, $(tput dim)dim$(tput sgr0)=unavailable (drain/maint/resv/down)

sshare output features:
  - $(tput bold)Bold text$(tput sgr0) highlights your user (${CURRENT_USER}) and group (${SLURM_GROUP})
  - Users and groups colored by RawUsage:
    $(tput setaf 4)blue$(tput sgr0)<10k, $(tput setaf 6)cyan$(tput sgr0)=10k-50k, $(tput setaf 2)green$(tput sgr0)=50k-200k, $(tput setaf 3)yellow$(tput sgr0)=200k-1M, $(tput setaf 208)orange$(tput sgr0)=1M-5M, $(tput setaf 1)red$(tput sgr0)≥5M
  - Users listed first (sorted by usage), then groups (sorted by usage)
  - Zero-usage users and groups hidden

squeue output features:
  - $(tput dim)Pending jobs are dimmed$(tput sgr0)
  - Running jobs colored by node count:
    $(tput setaf 4)blue$(tput sgr0)=1, $(tput setaf 6)cyan$(tput sgr0)=2-3, $(tput setaf 2)green$(tput sgr0)=4-7, $(tput setaf 3)yellow$(tput sgr0)=8-15, $(tput setaf 208)orange$(tput sgr0)=16-31, $(tput setaf 1)red$(tput sgr0)=32+
  - Jobs sorted by: state (pending first), user, node count, runtime

Examples:
  sq              Show group jobs (all states)
  sq -m           Show only your jobs
  sq -r           Show only running jobs in your group
  sq -mr          Show only your running jobs (combined flags)
  sq -mt          Show your jobs with ETA for Priority pending jobs
  sq -a -r        Show all running jobs on the cluster
EOF
exit 0
fi

### Apply scope mode
case "$SCOPE_MODE" in
    me)
        SSHARE_SCOPE=""
        SQUEUE_SCOPE="--me"
        ;;
    all)
        SSHARE_ACCOUNT=""
        SSHARE_SCOPE="-a"
        SQUEUE_SCOPE=""
        ;;
esac

### Apply filter options
if [[ "$RUNNING_ONLY" == true ]]; then
    SQUEUE_STATE="-t R"
fi

### Cluster status (all partitions)
sinfo --format="%P %t %D %G" --noheader 2>/dev/null | awk '
BEGIN {
    RED    = "\033[31m"
    GREEN  = "\033[32m"
    YELLOW = "\033[33m"
    BLUE   = "\033[34m"
    DIM    = "\033[2m"
    BOLD   = "\033[1m"
    RESET  = "\033[0m"

    NC = 9
    col_name[1] = "nodes"; col_clr[1] = BOLD
    col_name[2] = "alloc"; col_clr[2] = RED
    col_name[3] = "idle";  col_clr[3] = GREEN
    col_name[4] = "mixed"; col_clr[4] = YELLOW
    col_name[5] = "comp";  col_clr[5] = BLUE
    col_name[6] = "drain"; col_clr[6] = DIM
    col_name[7] = "maint"; col_clr[7] = DIM
    col_name[8] = "resv";  col_clr[8] = DIM
    col_name[9] = "down";  col_clr[9] = DIM

    for (c = 1; c <= NC; c++) col_w[c] = length(col_name[c])
}
{
    part = $1; sub(/\*$/, "", part)
    state = $2; count = $3 + 0

    # Track partition order of first appearance
    if (!(part in part_total)) {
        np++
        part_idx[np] = part
    }

    # Aggregate into state categories
    if      (state == "alloc")  data[part, "alloc"] += count
    else if (state == "idle")   data[part, "idle"]  += count
    else if (state == "mix")    data[part, "mixed"] += count
    else if (state == "comp")   data[part, "comp"]  += count
    else if (state ~ /^drain/)  data[part, "drain"] += count
    else if (state == "maint")  data[part, "maint"] += count
    else if (state == "resv")   data[part, "resv"]  += count
    else if (state ~ /^down/)   data[part, "down"]  += count

    part_total[part] += count

    # Parse GPUs/node from GRES field (e.g. "gpu:4(S:0-1)")
    if (!(part in gpn) && $4 ~ /^gpu:/) {
        g = $4; sub(/^gpu:/, "", g); sub(/\(.*/, "", g)
        gpn[part] = g + 0
    }
}
END {
    if (np == 0) exit

    # Sort partitions by total node count descending (insertion sort)
    for (i = 2; i <= np; i++) {
        key = part_idx[i]
        j = i - 1
        while (j >= 1 && part_total[part_idx[j]] < part_total[key]) {
            part_idx[j + 1] = part_idx[j]
            j--
        }
        part_idx[j + 1] = key
    }

    # Remove partitions with zero nodes
    j = 0
    for (i = 1; i <= np; i++) {
        if (part_total[part_idx[i]] > 0) {
            j++
            part_idx[j] = part_idx[i]
        }
    }
    np = j
    if (np == 0) exit

    # Build display names (append GPU count) and find partition column width
    pw = 0
    for (i = 1; i <= np; i++) {
        p = part_idx[i]
        if (gpn[p] > 0)
            pdsp[p] = p " (" gpn[p] " gpu/node)"
        else
            pdsp[p] = p
        if (length(pdsp[p]) > pw) pw = length(pdsp[p])
    }

    # Map column index to data key (col 1 = total, handled separately)
    dk[2] = "alloc"; dk[3] = "idle";  dk[4] = "mixed"
    dk[5] = "comp";  dk[6] = "drain"; dk[7] = "maint"
    dk[8] = "resv";  dk[9] = "down"

    # Compute column widths from data values
    for (i = 1; i <= np; i++) {
        p = part_idx[i]
        w = length(sprintf("%d", part_total[p]))
        if (w > col_w[1]) col_w[1] = w
        for (c = 2; c <= NC; c++) {
            v = data[p, dk[c]] + 0
            if (v > 0) {
                w = length(sprintf("%d", v))
                if (w > col_w[c]) col_w[c] = w
            }
        }
    }

    # Print title
    printf "%sCluster Status:%s\n", BOLD, RESET

    # Print column headers
    printf "  %-*s", pw, ""
    for (c = 1; c <= NC; c++)
        printf "  %s%*s%s", col_clr[c], col_w[c], col_name[c], RESET
    printf "\n"

    # Print one row per partition
    for (i = 1; i <= np; i++) {
        p = part_idx[i]
        printf "  %-*s", pw, pdsp[p]

        # "nodes" column (total)
        printf "  %s%*d%s", col_clr[1], col_w[1], part_total[p], RESET

        # State columns
        for (c = 2; c <= NC; c++) {
            v = data[p, dk[c]] + 0
            if (v > 0)
                printf "  %s%*d%s", col_clr[c], col_w[c], v, RESET
            else
                printf "  %s%*s%s", DIM, col_w[c], "-", RESET
        }
        printf "\n"
    }
}
'

echo ""

### Process sshare output
sshare $SSHARE_ACCOUNT $SSHARE_SCOPE --format="Account%50,User%30,RawShares,NormShares,RawUsage,NormUsage,EffectvUsage,FairShare,LevelFS" | awk -v current_user="${CURRENT_USER}" -v slurm_group="${SLURM_GROUP}" '
function get_usage_color(usage) {
    if (usage < 10000) return "\033[34m"
    if (usage < 50000) return "\033[36m"
    if (usage < 200000) return "\033[32m"
    if (usage < 1000000) return "\033[33m"
    if (usage < 5000000) return "\033[38;5;208m"
    return "\033[31m"
}

function extract_field(line, col) {
    val = substr(line, col_start[col], col_end[col] - col_start[col] + 1)
    gsub(/^[ \t]+|[ \t]+$/, "", val)
    return val
}

function update_max(col, val) {
    len = length(val)
    if (len > max_width[col]) {
        max_width[col] = len
    }
}

BEGIN {
    BOLD = "\033[1m"
    RESET = "\033[0m"
    
    for (c = 1; c <= 9; c++) {
        max_width[c] = 0
    }
}

NR == 1 {
    header_line = $0
    next
}

NR == 2 {
    # Parse separator line to find column boundaries
    num_cols = 0
    in_dash = 0
    
    for (i = 1; i <= length($0); i++) {
        c = substr($0, i, 1)
        if (c == "-" && !in_dash) {
            num_cols++
            col_start[num_cols] = i
            in_dash = 1
        } else if (c != "-" && in_dash) {
            col_end[num_cols] = i - 1
            in_dash = 0
        }
    }
    if (in_dash) {
        col_end[num_cols] = length($0)
    }
    
    # Extract header fields (only first 9)
    for (f = 1; f <= 9 && f <= num_cols; f++) {
        val = extract_field(header_line, f)
        header[f] = val
        update_max(f, val)
    }
    next
}

{
    # Extract fields by character position
    for (f = 1; f <= 9 && f <= num_cols; f++) {
        fields[f] = extract_field($0, f)
    }
    
    if (fields[1] == "root") next
    
    is_user = (fields[2] ~ /[a-zA-Z]/)
    raw_usage = fields[5] + 0
    if (raw_usage == 0) next
    
    if (is_user) {
        user_count++
        user_usage[user_count] = raw_usage
        user_highlight[user_count] = ($0 ~ current_user)
        for (f = 1; f <= 9; f++) {
            user_data[user_count, f] = fields[f]
            update_max(f, fields[f])
        }
    } else {
        group_count++
        group_usage[group_count] = raw_usage
        group_highlight[group_count] = ($0 ~ slurm_group)
        for (f = 1; f <= 9; f++) {
            group_data[group_count, f] = fields[f]
            update_max(f, fields[f])
        }
    }
}

END {
    # Sort users by usage
    for (i = 1; i <= user_count; i++) {
        for (j = i + 1; j <= user_count; j++) {
            if (user_usage[i] > user_usage[j]) {
                temp = user_usage[i]; user_usage[i] = user_usage[j]; user_usage[j] = temp
                temp = user_highlight[i]; user_highlight[i] = user_highlight[j]; user_highlight[j] = temp
                for (f = 1; f <= 9; f++) {
                    temp = user_data[i, f]; user_data[i, f] = user_data[j, f]; user_data[j, f] = temp
                }
            }
        }
    }
    
    # Sort groups by usage
    for (i = 1; i <= group_count; i++) {
        for (j = i + 1; j <= group_count; j++) {
            if (group_usage[i] > group_usage[j]) {
                temp = group_usage[i]; group_usage[i] = group_usage[j]; group_usage[j] = temp
                temp = group_highlight[i]; group_highlight[i] = group_highlight[j]; group_highlight[j] = temp
                for (f = 1; f <= 9; f++) {
                    temp = group_data[i, f]; group_data[i, f] = group_data[j, f]; group_data[j, f] = temp
                }
            }
        }
    }
    
    # Print header
    for (f = 1; f <= 9; f++) {
        printf "%-*s", max_width[f], header[f]
        if (f < 9) printf "  "
    }
    printf "\n"
    
    # Print users then groups
    for (i = 1; i <= user_count; i++) {
        line = ""
        for (f = 1; f <= 9; f++) {
            line = line sprintf("%-*s", max_width[f], user_data[i, f])
            if (f < 9) line = line "  "
        }
        
        output = get_usage_color(user_usage[i]) line RESET
        if (user_highlight[i]) output = BOLD output
        print output
    }
    
    for (i = 1; i <= group_count; i++) {
        line = ""
        for (f = 1; f <= 9; f++) {
            line = line sprintf("%-*s", max_width[f], group_data[i, f])
            if (f < 9) line = line "  "
        }
        
        output = get_usage_color(group_usage[i]) line RESET
        if (group_highlight[i]) output = BOLD output
        print output
    }
}
'

echo ""

### Define common squeue processing awk script
read -r -d '' SQUEUE_AWK_SCRIPT << 'AWK_EOF' || true
function get_node_color(nodes) {
    n = nodes + 0
    if (n == 0) return "\033[34m"
    log_n = 0
    while (n > 1) {
        n = int(n / 2)
        log_n++
    }
    if (log_n == 0) return "\033[34m"
    if (log_n == 1) return "\033[36m"
    if (log_n == 2) return "\033[32m"
    if (log_n == 3) return "\033[33m"
    if (log_n == 4) return "\033[38;5;208m"
    return "\033[31m"
}

function time_to_seconds(time) {
    if (time ~ /-/) {
        split(time, parts, "-")
        split(parts[2], hms, ":")
        return parts[1] * 86400 + hms[1] * 3600 + hms[2] * 60 + hms[3]
    } else if (time ~ /:.*:/) {
        split(time, hms, ":")
        return hms[1] * 3600 + hms[2] * 60 + hms[3]
    } else if (time ~ /:/) {
        split(time, ms, ":")
        return ms[1] * 60 + ms[2]
    }
    return 0
}

BEGIN {
    BOLD = "\033[1m"
    DIM = "\033[2m"
    RESET = "\033[0m"
    
    for (c = 1; c <= 8; c++) {
        max_width[c] = 0
    }
}

NR == 1 {
    for (f = 1; f <= 8; f++) {
        gsub(/^[ \t]+|[ \t]+$/, "", $f)
        header[f] = $f
        if (length($f) > max_width[f]) {
            max_width[f] = length($f)
        }
    }
    next
}

{
    for (f = 1; f <= 8; f++) {
        gsub(/^[ \t]+|[ \t]+$/, "", $f)
        fields[NR, f] = $f
        
        field_len = length($f)
        if (f == 8 && field_len > max_col8_width) {
            field_len = max_col8_width
        }
        if (field_len > max_width[f]) {
            max_width[f] = field_len
        }
    }
    
    users[NR] = $4
    states[NR] = $5
    times[NR] = time_to_seconds($6)
    node_counts[NR] = $7
}

END {
    for (i = 2; i <= NR; i++) {
        indices[i] = i
    }
    
    for (i = 2; i <= NR; i++) {
        for (j = i + 1; j <= NR; j++) {
            idx_i = indices[i]
            idx_j = indices[j]
            
            # Sort by: state, user, nodes, time, name (lowest priority)
            if (states[idx_i] > states[idx_j] || 
                (states[idx_i] == states[idx_j] && users[idx_i] > users[idx_j]) ||
                (states[idx_i] == states[idx_j] && users[idx_i] == users[idx_j] && node_counts[idx_i] + 0 > node_counts[idx_j] + 0) ||
                (states[idx_i] == states[idx_j] && users[idx_i] == users[idx_j] && node_counts[idx_i] == node_counts[idx_j] && times[idx_i] > times[idx_j]) ||
                (states[idx_i] == states[idx_j] && users[idx_i] == users[idx_j] && node_counts[idx_i] == node_counts[idx_j] && times[idx_i] == times[idx_j] && fields[idx_i, 3] > fields[idx_j, 3])) {
                temp = indices[i]
                indices[i] = indices[j]
                indices[j] = temp
            }
        }
    }
    
    for (f = 1; f <= 8; f++) {
        printf "%-*s", max_width[f], header[f]
        if (f < 8) printf "  "
    }
    printf "\n"
    
    # Print with duplicate collapsing
    i = 2
    while (i <= NR) {
        idx = indices[i]
        state = states[idx]
        nodes = node_counts[idx]
        
        line = ""
        for (f = 1; f <= 8; f++) {
            val = fields[idx, f]
            if (f == 8 && length(val) > max_col8_width) {
                val = substr(val, 1, max_col8_width)
            }
            line = line sprintf("%-*s", max_width[f], val)
            if (f < 8) line = line "  "
        }
        
        if (state == "PD") {
            output = DIM line RESET
        } else {
            output = get_node_color(nodes) line RESET
        }
        
        if (line ~ current_user) {
            output = BOLD output
        }
        
        print output
        
        # Check for duplicates
        dup_count = 0
        first_jobid = fields[idx, 1]
        last_jobid = first_jobid
        j = i + 1
        
        while (j <= NR) {
            idx_j = indices[j]
            is_dup = 1
            
            for (f = 2; f <= 8; f++) {
                if (fields[idx, f] != fields[idx_j, f]) {
                    is_dup = 0
                    break
                }
            }
            
            if (is_dup) {
                dup_count++
                last_jobid = fields[idx_j, 1]
                j++
            } else {
                break
            }
        }
        
        if (dup_count > 0) {
            collapse_line = sprintf("  [x%d, %s-%s]", dup_count + 1, first_jobid, last_jobid)
            if (state == "PD") {
                collapse_output = DIM collapse_line RESET
            } else {
                collapse_output = get_node_color(nodes) collapse_line RESET
            }
            if (line ~ current_user) {
                collapse_output = BOLD collapse_output
            }
            print collapse_output
            i = j
        } else {
            i++
        }
    }
}
AWK_EOF

### Process squeue output
if [[ "$SHOW_TIMING" == true ]]; then
    # When timing enabled, we need to identify Priority jobs first
    TMPFILE=$(mktemp)
    TMPOUT=$(mktemp)
    trap "rm -f $TMPFILE $TMPOUT" EXIT
    
    # Capture raw squeue output and extract Priority jobids
    squeue $SQUEUE_SCOPE $SQUEUE_STATE --format="%18i"$'\x1f'"%12P"$'\x1f'"%200j"$'\x1f'"%20u"$'\x1f'"%2t"$'\x1f'"%10M"$'\x1f'"%6D"$'\x1f'"%R" | tee "$TMPOUT" | awk -F'\x1f' -v tmpfile="$TMPFILE" '
    NR > 1 {
        gsub(/^[ \t]+|[ \t]+$/, "", $1)
        gsub(/^[ \t]+|[ \t]+$/, "", $5)
        gsub(/^[ \t]+|[ \t]+$/, "", $8)
        if ($5 == "PD" && $8 ~ /Priority/) {
            print $1 >> tmpfile
        }
    }
    ' > /dev/null
    
    # Build ETA map
    CURRENT_TIME=$(date +%s)
    declare -A ETAS
    
    if [[ -s "$TMPFILE" ]]; then
        while IFS= read -r jobid; do
            [[ -z "$jobid" ]] && continue
            
            start_time_str=$(scontrol show job "$jobid" 2>/dev/null | grep -oP 'StartTime=\K[^ ]+' || echo "")
            
            if [[ -z "$start_time_str" || "$start_time_str" == "Unknown" || "$start_time_str" == "N/A" ]]; then
                ETAS[$jobid]="Unknown"
            else
                start_time=$(date -d "$start_time_str" +%s 2>/dev/null || echo "")
                
                if [[ -z "$start_time" ]]; then
                    ETAS[$jobid]="Unknown"
                else
                    diff=$((start_time - CURRENT_TIME))
                    
                    if [[ $diff -lt 0 ]]; then
                        ETAS[$jobid]="imminent"
                    else
                        hours=$((diff / 3600))
                        minutes=$(((diff % 3600) / 60))
                        seconds=$((diff % 60))
                        ETAS[$jobid]=$(printf "%d:%02d:%02d" $hours $minutes $seconds)
                    fi
                fi
            fi
        done < "$TMPFILE"
    fi
    
    # Process the captured output with ETA replacement
    cat "$TMPOUT" | awk -F'\x1f' -v current_user="${CURRENT_USER}" -v max_col8_width=35 "$SQUEUE_AWK_SCRIPT" | while IFS= read -r line; do
        # Replace (Priority) with ETA if we have it
        if [[ "$line" =~ \(Priority\) ]]; then
            jobid=$(echo "$line" | awk '{print $1}' | sed 's/\x1b\[[0-9;]*m//g')
            
            if [[ -n "${ETAS[$jobid]:-}" ]]; then
                eta="${ETAS[$jobid]}"
                line="${line//(Priority)/(Priority) ETA: $eta}"
            fi
        fi
        echo "$line"
    done
else
    # No timing - just run normally
    squeue $SQUEUE_SCOPE $SQUEUE_STATE --format="%18i"$'\x1f'"%12P"$'\x1f'"%200j"$'\x1f'"%20u"$'\x1f'"%2t"$'\x1f'"%10M"$'\x1f'"%6D"$'\x1f'"%R" | awk -F'\x1f' -v current_user="${CURRENT_USER}" -v max_col8_width=20 "$SQUEUE_AWK_SCRIPT"
fi

