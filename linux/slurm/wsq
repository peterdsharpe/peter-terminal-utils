ANSI_RE = re.compile(r"\033\[([0-9;]*)m")

### Scrollbar and gradient color pair indices
C_SCROLLBAR = 7
GRADIENT_PALETTE_SIZE = 64
C_GRADIENT_BASE = 10
LOWER_EIGHTHS = " ▁▂▃▄▅▆▇█"
UPPER_EIGHTHS = " ▔🮂🮃▀🮄🮅🮆█"

SCROLL_STEP = 3
SCROLLOFF = 5


@dataclass
class ScrollState:
    """Scroll position tracking for the TUI content area."""

    offset: int = 0
    total: int = 0
    visible: int = 0

    def clamp(self) -> None:
        self.offset = max(0, min(self.offset, max(0, self.total - self.visible)))

    def scroll_up(self, n: int = SCROLL_STEP) -> None:
        self.offset -= n
        self.clamp()

    def scroll_down(self, n: int = SCROLL_STEP) -> None:
        self.offset += n
        self.clamp()

    def page_up(self) -> None:
        self.scroll_up(max(1, self.visible - 1))

    def page_down(self) -> None:
        self.scroll_down(max(1, self.visible - 1))

    def go_top(self) -> None:
        self.offset = 0

    def go_bottom(self) -> None:
        self.offset = max(0, self.total - self.visible)

    def ensure_visible(self, idx: int) -> None:
        """Adjust offset so item at idx is within the visible window.

        Maintains a SCROLLOFF margin so the cursor never reaches the viewport
        edge (keeping context lines above/below). On small terminals the margin
        degrades to visible//2 so the cursor always has room to move.
        """
        margin = min(SCROLLOFF, self.visible // 2)
        if idx < self.offset + margin:
            self.offset = idx - margin
        elif idx >= self.offset + self.visible - margin:
            self.offset = idx - self.visible + margin + 1
        self.clamp()


def _rgb_to_256(r: int, g: int, b: int) -> int:
    """Nearest 256-color index for an RGB value (6x6x6 cube, indices 16-231)."""
    return 16 + 36 * round(r / 255 * 5) + 6 * round(g / 255 * 5) + round(b / 255 * 5)


def _init_colors() -> None:
    """Initialize curses color pairs: base ANSI, scrollbar, and gradient palette."""
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(C_RED, curses.COLOR_RED, -1)
    curses.init_pair(C_GREEN, curses.COLOR_GREEN, -1)
    curses.init_pair(C_YELLOW, curses.COLOR_YELLOW, -1)
    curses.init_pair(C_BLUE, curses.COLOR_BLUE, -1)
    curses.init_pair(C_CYAN, curses.COLOR_CYAN, -1)
    if curses.COLORS >= 256:
        curses.init_pair(C_ORANGE, 208, -1)
        curses.init_pair(C_SCROLLBAR, 249, 236)
        ### Pre-allocate gradient palette for continuous color mapping
        for i in range(GRADIENT_PALETTE_SIZE):
            t = i / (GRADIENT_PALETTE_SIZE - 1)
            r, g, b = _gradient_rgb(t)
            curses.init_pair(C_GRADIENT_BASE + i, _rgb_to_256(r, g, b), -1)
    else:
        curses.init_pair(C_ORANGE, curses.COLOR_YELLOW, -1)
        curses.init_pair(C_SCROLLBAR, curses.COLOR_WHITE, curses.COLOR_BLACK)


### Map ANSI SGR code -> curses attribute
_ANSI_ATTR: dict[str, int] = {}


def _build_attr_map() -> None:
    """Populate _ANSI_ATTR after curses is initialized."""
    _ANSI_ATTR.update(
        {
            "1": curses.A_BOLD,
            "2": curses.A_DIM,
            "31": curses.color_pair(C_RED),
            "32": curses.color_pair(C_GREEN),
            "33": curses.color_pair(C_YELLOW),
            "34": curses.color_pair(C_BLUE),
            "36": curses.color_pair(C_CYAN),
            "38;5;208": curses.color_pair(C_ORANGE),
        }
    )


### Pre-computed table mapping each gradient step's 256-color index back to its pair.
### Built once by _build_attr_map; used by _parse_ansi for O(1) true-color lookup.
_gradient_256_to_pair: dict[int, int] = {}


def _build_gradient_lookup() -> None:
    """Build reverse lookup from 256-color index to gradient curses pair."""
    for i in range(GRADIENT_PALETTE_SIZE):
        t = i / (GRADIENT_PALETTE_SIZE - 1)
        r, g, b = _gradient_rgb(t)
        c256 = _rgb_to_256(r, g, b)
        _gradient_256_to_pair[c256] = curses.color_pair(C_GRADIENT_BASE + i)


def _nearest_gradient_pair(r: int, g: int, b: int) -> int:
    """Find the curses color pair closest to an RGB value from the gradient palette."""
    c256 = _rgb_to_256(r, g, b)
    if c256 in _gradient_256_to_pair:
        return _gradient_256_to_pair[c256]
    ### Fallback: find nearest by RGB distance across all gradient steps
    best_pair = 0
    best_dist = float("inf")
    for i in range(GRADIENT_PALETTE_SIZE):
        t = i / (GRADIENT_PALETTE_SIZE - 1)
        gr, gg, gb = _gradient_rgb(t)
        dist = (r - gr) ** 2 + (g - gg) ** 2 + (b - gb) ** 2
        if dist < best_dist:
            best_dist = dist
            best_pair = curses.color_pair(C_GRADIENT_BASE + i)
    return best_pair


def _apply_sgr(attr: int, code: str) -> int:
    """Apply an ANSI SGR parameter string to the current curses attribute.

    Handles combined codes (e.g., '1;31' for bold red), 256-color ('38;5;N'),
    and true color ('38;2;R;G;B') sequences by splitting on ';' and walking
    sub-codes with a cursor to correctly consume multi-part sequences.
    """
    if code in ("0", ""):
        return 0

    parts = code.split(";")
    i = 0
    while i < len(parts):
        p = parts[i]
        if p in ("0", ""):
            attr = 0
        elif p == "1":
            attr |= curses.A_BOLD
        elif p == "2":
            attr |= curses.A_DIM
        elif p == "38" and i + 1 < len(parts):
            if parts[i + 1] == "2" and i + 4 < len(parts):
                ### True color: 38;2;R;G;B
                try:
                    r = int(parts[i + 2])
                    g = int(parts[i + 3])
                    b = int(parts[i + 4])
                    pair = _nearest_gradient_pair(r, g, b)
                    attr = (attr & (curses.A_BOLD | curses.A_DIM)) | pair
                except (ValueError, IndexError):
                    pass
                i += 4
            elif parts[i + 1] == "5" and i + 2 < len(parts):
                ### 256-color: 38;5;N — check exact map, then gradient palette
                full = f"38;5;{parts[i + 2]}"
                if full in _ANSI_ATTR:
                    attr = (attr & (curses.A_BOLD | curses.A_DIM)) | _ANSI_ATTR[full]
                else:
                    try:
                        pair = _gradient_256_to_pair.get(int(parts[i + 2]), 0)
                        if pair:
                            attr = (attr & (curses.A_BOLD | curses.A_DIM)) | pair
                    except ValueError:
                        pass
                i += 2
            else:
                i += 1
        elif p in _ANSI_ATTR:
            attr = (attr & (curses.A_BOLD | curses.A_DIM)) | _ANSI_ATTR[p]
        i += 1
    return attr


def _parse_ansi(text: str) -> list[tuple[str, int]]:
    """Parse ANSI-escaped string into (text_segment, curses_attr) pairs.

    Handles standard SGR codes (bold, dim, basic colors, 256-color),
    true color codes (38;2;R;G;B), and combined codes (e.g., 1;31m)
    by delegating to _apply_sgr.
    """
    segments: list[tuple[str, int]] = []
    attr = 0
    pos = 0

    for m in ANSI_RE.finditer(text):
        if m.start() > pos:
            segments.append((text[pos : m.start()], attr))
        attr = _apply_sgr(attr, m.group(1))
        pos = m.end()

    if pos < len(text):
        segments.append((text[pos:], attr))
    return segments


def _truncate_ansi(text: str, max_visible: int) -> str:
    """Truncate ANSI-colored string to max_visible visible chars with ellipsis.

    Walks visible-character boundaries so escape sequences are never split.
    Appends RESET after the ellipsis to prevent color bleed into padding.
    """
    if max_visible <= 0:
        return ""
    visible = 0
    prev_end = 0
    for m in ANSI_RE.finditer(text):
        gap = m.start() - prev_end
        if visible + gap >= max_visible:
            return text[: prev_end + max_visible - visible - 1] + f"\u2026{RESET}"
        visible += gap
        prev_end = m.end()
    tail = len(text) - prev_end
    if visible + tail > max_visible:
        return text[: prev_end + max_visible - visible - 1] + f"\u2026{RESET}"
    return text


def _addstr_ansi(
    win: curses.window, y: int, x: int, text: str, max_x: int, base_attr: int = 0
) -> None:
    """Write ANSI-colored text to a curses window, clipping at max_x.

    Args:
        base_attr: Additional curses attribute OR'd with every segment (e.g.,
            curses.A_REVERSE for selection highlighting that preserves colors).
    """
    col = x
    for segment, attr in _parse_ansi(text):
        if col >= max_x:
            break
        avail = max_x - col
        fragment = segment[:avail]
        try:
            win.addstr(y, col, fragment, attr | base_attr)
        except curses.error:
            pass
        col += len(fragment)


def _handle_viewport_scroll(key: int, scroll: ScrollState, page_size: int = 0) -> bool:
    """Handle viewport scroll keys against a ScrollState. Returns True if consumed.

    Covers j/k, arrows, PgUp/Dn, Home/End, Ctrl+D/U, Ctrl+E/Y, and mouse wheel.
    Used by all pure-viewport scroll contexts (overlay boxes, log viewer) so that
    scroll features stay consistent across the codebase.
    """
    ps = page_size or scroll.visible
    if key in (curses.KEY_DOWN, ord("j")):
        scroll.scroll_down(1)
    elif key in (curses.KEY_UP, ord("k")):
        scroll.scroll_up(1)
    elif key == curses.KEY_PPAGE:
        scroll.page_up()
    elif key == curses.KEY_NPAGE:
        scroll.page_down()
    elif key == curses.KEY_HOME:
        scroll.go_top()
    elif key == curses.KEY_END:
        scroll.go_bottom()
    elif key == 4:  # Ctrl+D
        scroll.scroll_down(max(1, ps // 2))
    elif key == 21:  # Ctrl+U
        scroll.scroll_up(max(1, ps // 2))
    elif key == 5:  # Ctrl+E
        scroll.scroll_down(1)
    elif key == 25:  # Ctrl+Y
        scroll.scroll_up(1)
    elif key == curses.KEY_MOUSE:
        try:
            _, _, _, _, bstate = curses.getmouse()
        except curses.error:
            return False
        if bstate & curses.BUTTON4_PRESSED:
            scroll.scroll_up(3)
        elif bstate & _BUTTON5_PRESSED:
            scroll.scroll_down(3)
        else:
            return False
    else:
        return False
    return True


def _handle_text_input(key: int, text: str) -> tuple[str, str]:
    """Process a keypress in text-input mode (filter bar, search bar, etc.).

    Returns (new_text, action) where action is one of:
        "typing"  - text was modified (char added/deleted)
        "submit"  - Enter pressed, input committed
        "cancel"  - Esc pressed, input should be discarded
    """
    if key == 27:
        return "", "cancel"
    if key in (ord("\n"), curses.KEY_ENTER):
        return text, "submit"
    if key in (curses.KEY_BACKSPACE, 127, 8):
        if text:
            return text[:-1], "typing"
        return "", "cancel"
    if 32 <= key <= 126:
        return text + chr(key), "typing"
    return text, "typing"


def _draw_scrollbar(
    stdscr: curses.window,
    x: int,
    y_start: int,
    height: int,
    scroll: ScrollState,
    attr: int,
) -> None:
    """Draw a vertical scrollbar with sub-character precision positioning.

    Ported from linux/setup. Uses Unicode eighth-block characters for smooth
    thumb rendering at 8x finer granularity than integer cell positions.
    """
    if height < 2 or scroll.total <= scroll.visible:
        return

    thumb_size = max(1.0, height * scroll.visible / scroll.total)
    max_offset = max(1, scroll.total - scroll.visible)
    thumb_pos = (height - thumb_size) * scroll.offset / max_offset
    thumb_top = thumb_pos
    thumb_bottom = thumb_pos + thumb_size

    for i in range(height):
        y = y_start + i
        cell_top = float(i)
        cell_bottom = float(i + 1)

        if thumb_bottom <= cell_top or thumb_top >= cell_bottom:
            char = " "
        elif thumb_top <= cell_top and thumb_bottom >= cell_bottom:
            char = "█"
        elif thumb_top > cell_top and thumb_bottom < cell_bottom:
            eighths = max(1, min(8, round((thumb_bottom - thumb_top) * 8)))
            char = LOWER_EIGHTHS[eighths]
        elif thumb_top > cell_top:
            eighths = max(1, min(8, round((cell_bottom - thumb_top) * 8)))
            char = LOWER_EIGHTHS[eighths]
        else:
            eighths = max(1, min(8, round((thumb_bottom - cell_top) * 8)))
            char = UPPER_EIGHTHS[eighths]

        try:
            stdscr.addstr(y, x, char, attr)
        except curses.error:
            pass


