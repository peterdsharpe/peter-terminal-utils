@dataclass
class Partition:
    name: str
    gpu_per_node: int
    total: int = 0
    states: dict[str, int] = field(default_factory=dict)

    @property
    def display_name(self) -> str:
        if self.gpu_per_node > 0:
            return f"{self.name} ({self.gpu_per_node} gpu/node)"
        return self.name


@dataclass
class ShareEntry:
    account: str
    user: str
    raw_shares: int
    raw_usage: int
    norm_usage: float
    effectv_usage: float
    level_fs: float | None

    @property
    def is_group(self) -> bool:
        return not self.user


@dataclass
class Job:
    jobid: str
    partition: str
    name: str
    user: str
    state: str
    time_str: str
    nodes: int
    reason: str
    dep_count: int = 0
    array_count: int = 0
    task_count: int = 0
    more_count: int = 0
    collapsed_names: list[str] = field(default_factory=list)


@dataclass(frozen=True)
class SortSpec:
    """A sortable column definition: label for the picker, key for sorting.

    key is a sort-key callable, or None for sorts that require special handling
    (e.g. the compound default sort, or Shares/Nodes which needs external context).
    """
    label: str
    key: object | None


###############################################################################
### Subprocess Helpers
###############################################################################


CMD_TIMEOUT = 30


def _run(cmd: list[str], timeout: int | None = None) -> str:
    """Run a command, return stdout. Returns empty string on failure.

    Uses errors="replace" so partial multi-byte UTF-8 sequences (common in
    HPC log files with Unicode progress bars) produce replacement characters
    instead of crashing with UnicodeDecodeError.
    """
    try:
        r = subprocess.run(
            cmd, capture_output=True, text=True, errors="replace",
            timeout=timeout if timeout is not None else CMD_TIMEOUT,
        )
        return r.stdout
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        return ""


@functools.lru_cache(maxsize=None)
def _get_cluster_name() -> str:
    """Get the Slurm cluster name (cached after first call)."""
    out = _run(["scontrol", "show", "config"], timeout=10)
    for line in out.splitlines():
        if line.strip().startswith("ClusterName"):
            return line.split("=", 1)[1].strip()
    return ""


###############################################################################
### Data Fetching
###############################################################################


def _sinfo_cmd() -> list[str]:
    return ["sinfo", "--format=%P %t %D %G", "--noheader"]


def _sshare_cmd(scope: str) -> list[str]:
    fmt = "Account%50,User%30,RawShares,RawUsage,NormUsage,EffectvUsage,LevelFS"
    cmd = ["sshare", f"--format={fmt}"]
    if scope == "me":
        cmd.extend(["-A", SLURM_GROUP])
    elif scope == "group":
        cmd.extend(["-A", SLURM_GROUP, "-a"])
    else:
        cmd.append("-a")
    return cmd


def _squeue_cmd(scope: str, running_only: bool) -> list[str]:
    sep = "\x1f"
    fmt = sep.join(["%18i", "%12P", "%200j", "%20u", "%2t", "%10M", "%6D", "%60r"])
    cmd = ["squeue", f"--format={fmt}"]
    if scope == "me":
        cmd.append("--me")
    elif scope == "group":
        cmd.extend(["-A", SLURM_GROUP])
    if running_only:
        cmd.extend(["-t", "R"])
    return cmd


def _fetch_eta(jobid: str, now: float) -> tuple[str, str]:
    """Fetch ETA for a single job via scontrol."""
    try:
        out = _run(["scontrol", "show", "job", jobid], timeout=10)
        for token in out.split():
            if token.startswith("StartTime="):
                val = token.split("=", 1)[1]
                if val in ("Unknown", "N/A", ""):
                    return jobid, "Unknown"
                ts = datetime.datetime.fromisoformat(val).timestamp()
                diff = ts - now
                if diff < 0:
                    return jobid, "imminent"
                h, rem = divmod(int(diff), 3600)
                m = rem // 60
                return jobid, f"{h}:{m:02d}"
    except Exception:
        pass
    return jobid, "Unknown"


def fetch_all(
    scope: str, running_only: bool, timing: bool
) -> tuple[list[Partition], list[ShareEntry], list[Job], dict[str, str]]:
    """Fetch sinfo + sshare + squeue in parallel, process, return ready-to-render data.

    When running_only is True, we still fetch ALL jobs for chain collapsing
    (so +N dep counts are accurate), then filter to running afterward.
    """
    with ThreadPoolExecutor(max_workers=3) as pool:
        f_info = pool.submit(_run, _sinfo_cmd())
        f_share = pool.submit(_run, _sshare_cmd(scope))
        ### Always fetch all states for accurate chain counts
        f_queue = pool.submit(_run, _squeue_cmd(scope, running_only=False))

        partitions = parse_sinfo(f_info.result())
        shares = parse_sshare(f_share.result())
        jobs = parse_squeue(f_queue.result())

    jobs = collapse_chains(jobs)
    jobs = collapse_arrays(jobs)
    jobs = collapse_running_arrays(jobs)

    if running_only:
        jobs = [j for j in jobs if j.state == "R"]

    items = collapse_user_batches(jobs)
    items = sort_items(items)

    etas: dict[str, str] = {}
    if timing:
        prio_ids = [
            j.jobid for j in items if j.state == "PD" and j.reason == "Priority"
        ]
        if prio_ids:
            now = time.time()
            with ThreadPoolExecutor(max_workers=8) as pool:
                for jid, eta in pool.map(lambda jid: _fetch_eta(jid, now), prio_ids):
                    etas[jid] = eta

    return partitions, shares, items, etas


