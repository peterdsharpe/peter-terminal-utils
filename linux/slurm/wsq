def run_static(args: argparse.Namespace) -> None:
    """One-shot print to stdout."""
    partitions, shares, items, etas = fetch_all(
        args.scope, args.running, args.timing
    )
    for line in render_all(partitions, shares, items, etas):
        print(line)


