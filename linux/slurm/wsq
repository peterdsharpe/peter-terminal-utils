### Processing
###############################################################################


def collapse_chains(jobs: list[Job]) -> list[Job]:
    """Merge dependency-chain jobs into their head (Running or Priority) job.

    Groups by (name, user, partition, nodes). Within each group, the head is
    the Running job if one exists, otherwise the first Priority-pending job.
    All Dependency-pending members are absorbed into head.dep_count.
    """
    ### Build groups
    groups: dict[tuple[str, str, str, int], list[Job]] = {}
    for job in jobs:
        key = (job.name, job.user, job.partition, job.nodes)
        groups.setdefault(key, []).append(job)

    ### Identify heads and dependency counts
    heads: dict[tuple, Job] = {}
    dep_counts: dict[tuple, int] = {}

    for key, group in groups.items():
        head: Job | None = None
        dep_count = 0

        for job in group:
            if job.state == "R":
                if head is None or head.state != "R":
                    head = job
            elif job.reason == "Priority":
                if head is None or head.state != "R":
                    head = job
            elif job.reason == "Dependency":
                dep_count += 1

        if head is not None and dep_count > 0:
            heads[key] = head
            dep_counts[key] = dep_count

    ### Rebuild job list, skipping absorbed dependency jobs
    result: list[Job] = []
    for job in jobs:
        key = (job.name, job.user, job.partition, job.nodes)
        if key in heads:
            if job is heads[key]:
                job.dep_count = dep_counts[key]
                result.append(job)
            elif job.reason == "Dependency" and job.state == "PD":
                continue
            else:
                result.append(job)
        else:
            result.append(job)
    return result


def collapse_arrays(jobs: list[Job]) -> list[Job]:
    """Merge pending job-array tasks into the running array task.

    Detects pending array specs (jobid contains '[') and matches them to
    running tasks sharing the same base ID.
    """
    ### Map base_id -> pending array job
    pending: dict[str, Job] = {}
    for job in jobs:
        if job.state == "PD" and "[" in job.jobid:
            base = job.jobid.split("_")[0]
            pending[base] = job

    if not pending:
        return jobs

    ### Parse count from array spec like "[3-5%1]"
    def _array_count(spec: str) -> int:
        m = re.search(r"\[([^\]]+)\]", spec)
        if not m:
            return 0
        inner = m.group(1).split("%")[0]
        count = 0
        for part in inner.split(","):
            if "-" in part:
                try:
                    lo_str, rest = part.split("-", 1)
                    hi_str, _, step_str = rest.partition(":")
                    lo, hi = int(lo_str), int(hi_str)
                    step = int(step_str) if step_str else 1
                    count += (hi - lo) // step + 1
                except ValueError:
                    count += 1
            else:
                count += 1
        return count

    ### Match running tasks to pending array specs.
    ### Only strip the suffix and set array_count on the FIRST running task per base.
    absorbed: set[int] = set()
    running_by_base: dict[str, Job] = {}
    for job in jobs:
        if job.state in ("R", "CG") and "_" in job.jobid and "[" not in job.jobid:
            base = job.jobid.split("_")[0]
            if base not in running_by_base:
                running_by_base[base] = job
                if base in pending:
                    job.array_count = _array_count(pending[base].jobid)
                    job.jobid = base
                    absorbed.add(id(pending[base]))

    ### Second pass: catch individual pending array tasks (no bracket notation,
    ### e.g., "2014800_5" when only one task is pending)
    for job in jobs:
        if (
            job.state == "PD"
            and "_" in job.jobid
            and "[" not in job.jobid
            and id(job) not in absorbed
        ):
            base = job.jobid.split("_")[0]
            if base in running_by_base:
                running_by_base[base].array_count += 1
                running_by_base[base].jobid = base
                absorbed.add(id(job))

    return [j for j in jobs if id(j) not in absorbed]


def collapse_running_arrays(jobs: list[Job]) -> list[Job]:
    """Collapse running array tasks that share the same base job ID.

    Groups running jobs whose jobid contains '_' by (base_id, name, user,
    partition, nodes). For groups with >1 member, keeps the longest-running
    task, sets jobid to the base ID, multiplies nodes by the task count,
    and stores the count in task_count for display.
    """
    ### Identify running/completing jobs with array-task suffixes.
    ### Skip jobs already processed by collapse_arrays (they have array_count > 0
    ### and their jobid was already stripped to the base).
    array_groups: dict[tuple, list[Job]] = {}
    for job in jobs:
        if (
            job.state in ("R", "CG")
            and "_" in job.jobid
            and "[" not in job.jobid
            and job.array_count == 0
        ):
            base = job.jobid.split("_")[0]
            key = (base, job.name, job.user, job.partition, job.nodes)
            array_groups.setdefault(key, []).append(job)

    ### For every array-task group, strip the _N suffix from the jobid.
    ### For groups with >1 task, also merge into a single entry.
    collapsed_ids: set[int] = set()
    for (base, _name, _user, _part, nodes_per_task), group in array_groups.items():
        if len(group) == 1:
            group[0].jobid = base
            continue
        group.sort(key=lambda j: _time_seconds(j.time_str), reverse=True)
        head = group[0]
        head.jobid = base
        head.nodes = nodes_per_task * len(group)
        head.task_count = len(group)
        for other in group[1:]:
            collapsed_ids.add(id(other))

    return [j for j in jobs if id(j) not in collapsed_ids]


def collapse_user_batches(
    jobs: list[Job], threshold: int = 5
) -> list[Job]:
    """Collapse large blocks of same-user pending jobs into the first job.

    Keeps the first job as a normal table row and annotates it with
    more_count and collapsed_names for the +N more notation.
    """
    ### Group standalone pending jobs by (user, partition, reason, nodes)
    groups: dict[tuple, list[Job]] = {}
    for job in jobs:
        if (
            job.state == "PD"
            and job.dep_count == 0
            and job.array_count == 0
            and job.reason not in ("None", "")
        ):
            key = (job.user, job.partition, job.reason, job.nodes)
            groups.setdefault(key, []).append(job)

    collapsed_ids: set[int] = set()
    for group in groups.values():
        if len(group) > threshold:
            head = group[0]
            head.more_count = len(group) - 1
            head.collapsed_names = [j.name for j in group[1:]]
            for job in group[1:]:
                collapsed_ids.add(id(job))

    return [j for j in jobs if id(j) not in collapsed_ids]


###############################################################################
### Sorting
###############################################################################


def _time_seconds(t: str) -> int:
    """Convert Slurm time string (D-HH:MM:SS, HH:MM:SS, MM:SS) to seconds."""
    try:
        if "-" in t:
            day_part, rest = t.split("-", 1)
            parts = rest.split(":")
            return (
                int(day_part) * 86400
                + int(parts[0]) * 3600
                + int(parts[1]) * 60
                + (int(parts[2]) if len(parts) > 2 else 0)
            )
        parts = t.split(":")
        if len(parts) == 3:
            return int(parts[0]) * 3600 + int(parts[1]) * 60 + int(parts[2])
        if len(parts) == 2:
            return int(parts[0]) * 60 + int(parts[1])
    except ValueError:
        pass
    return 0


def _format_seconds(total: int) -> str:
    """Convert seconds back to Slurm-style time string (D-HH:MM:SS or H:MM:SS)."""
    if total < 0:
        total = 0
    days, remainder = divmod(total, 86400)
    hours, remainder = divmod(remainder, 3600)
    minutes, seconds = divmod(remainder, 60)
    if days > 0:
        return f"{days}-{hours:02d}:{minutes:02d}:{seconds:02d}"
    if hours > 0:
        return f"{hours}:{minutes:02d}:{seconds:02d}"
    return f"{minutes}:{seconds:02d}"


def _relative_time(slurm_ts: str) -> str:
    """Convert a Slurm absolute timestamp to a parenthesized relative string.

    Uses two-unit granularity where useful (e.g. "1 day, 7 hrs ago") and
    consistent abbreviations: min, hr/hrs, day/days.
    Returns "" for placeholders like "Unknown" or unparseable values.
    """
    if not slurm_ts or slurm_ts in ("Unknown", "N/A", "?"):
        return ""
    try:
        ts = datetime.datetime.fromisoformat(slurm_ts).timestamp()
    except ValueError:
        return ""
    diff = time.time() - ts
    if abs(diff) < 60:
        return "(just now)"
    future = diff < 0
    total = int(abs(diff))
    days, rem = divmod(total, 86400)
    hours, rem = divmod(rem, 3600)
    minutes = rem // 60

    if days > 7:
        label = f"{days} days"
    elif days >= 1:
        label = f"{days} {'day' if days == 1 else 'days'}"
        if hours > 0:
            label += f", {hours} {'hr' if hours == 1 else 'hrs'}"
    elif hours >= 4:
        label = f"{hours} hrs"
    elif hours >= 1:
        label = f"{hours} {'hr' if hours == 1 else 'hrs'}"
        if minutes > 0:
            label += f", {minutes} min"
    else:
        label = f"{minutes} min"
    return f"(in {label})" if future else f"({label} ago)"


def sort_items(items: list[Job]) -> list[Job]:
    """Sort: PD jobs first, then R jobs. Within each: user, nodes desc, time desc."""

    def key(item: Job) -> tuple:
        state_ord = 0 if item.state == "PD" else 1
        return (
            state_ord,
            item.user,
            -item.nodes,
            -_time_seconds(item.time_str),
            item.name,
        )

    return sorted(items, key=key)


###############################################################################
### Interactive Filter & Sort Helpers (TUI)
###############################################################################


def _match_filter(item: Job | ShareEntry, text: str) -> bool:
    """Return True if any visible field of item contains text (case-insensitive)."""
    low = text.lower()
    if isinstance(item, Job):
        return any(
            low in f.lower()
            for f in (item.jobid, item.partition, item.name, item.user,
                      item.state, item.time_str, str(item.nodes), item.reason)
        )
    if isinstance(item, ShareEntry):
        return any(
            low in f.lower()
            for f in (item.account, item.user, str(item.raw_shares), str(item.raw_usage))
        )
    return True


JOB_SORT_SPEC: list[SortSpec] = [
    SortSpec("Default (state > user > nodes)", None),
    SortSpec("JobID", lambda j: int(j.jobid.split("_")[0]) if j.jobid.split("_")[0].isdigit() else 0),
    SortSpec("Partition", lambda j: j.partition.lower()),
    SortSpec("Name", lambda j: j.name.lower()),
    SortSpec("User", lambda j: j.user.lower()),
    SortSpec("State", lambda j: j.state),
    SortSpec("Time", lambda j: _time_seconds(j.time_str)),
    SortSpec("Nodes", lambda j: j.nodes),
]

SHARE_SORT_SPEC: list[SortSpec] = [
    SortSpec("Default (by usage)", None),
    SortSpec("Account", lambda s: s.account.lower()),
    SortSpec("User", lambda s: s.user.lower()),
    SortSpec("RawShares", lambda s: s.raw_shares),
    SortSpec("Nodes", None),  # needs user_nodes context, special-cased in _sort_shares_by
    SortSpec("RawUsage", lambda s: s.raw_usage),
    SortSpec("NormUsage", lambda s: s.norm_usage),
    SortSpec("EffectvUsage", lambda s: s.effectv_usage),
    SortSpec("LevelFS", lambda s: s.level_fs if s.level_fs is not None else -1.0),
]


def _sort_jobs_by(
    items: list[Job], mode: int, ascending: bool,
) -> list[Job]:
    """Sort jobs by the given mode index. mode=0 falls back to default sort."""
    if mode == 0:
        return sort_items(items)
    spec = JOB_SORT_SPEC[mode] if mode < len(JOB_SORT_SPEC) else None
    if spec is None or spec.key is None:
        return list(items)
    jobs = list(items)
    jobs.sort(key=spec.key, reverse=not ascending)
    return jobs


def _sort_shares_by(
    shares: list[ShareEntry], mode: int, ascending: bool,
    user_nodes: dict[str, int] | None = None,
) -> list[ShareEntry]:
    """Sort shares by the given mode index. mode=0 falls back to default sort.

    The Nodes column (key=None, mode!=0) is special-cased because group-row
    node counts must be aggregated from member users via user_nodes.
    """
    if mode == 0:
        groups = sorted(
            [s for s in shares if s.is_group], key=lambda s: s.raw_usage, reverse=True,
        )
        users = sorted(
            [s for s in shares if not s.is_group], key=lambda s: s.raw_usage, reverse=True,
        )
        return groups + users

    spec = SHARE_SORT_SPEC[mode] if mode < len(SHARE_SORT_SPEC) else None
    if spec is None:
        return shares

    if spec.key is None:
        ### Nodes sort: for group entries, sum member node counts
        un = user_nodes or {}
        account_nodes: dict[str, int] = {}
        for s in shares:
            if not s.is_group:
                n = un.get(s.user, 0)
                if n > 0:
                    account_nodes[s.account] = account_nodes.get(s.account, 0) + n

        def node_key(s: ShareEntry) -> int:
            if s.is_group:
                return account_nodes.get(s.account, 0)
            return un.get(s.user, 0)

        return sorted(shares, key=node_key, reverse=not ascending)

    return sorted(shares, key=spec.key, reverse=not ascending)


