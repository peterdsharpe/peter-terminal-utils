def parse_sinfo(output: str) -> list[Partition]:
    """Parse sinfo --format='%P %t %D %G' --noheader output."""
    parts: dict[str, Partition] = {}

    for line in output.strip().splitlines():
        tokens = line.split()
        if len(tokens) < 3:
            continue

        name = tokens[0].rstrip("*")
        state_raw = tokens[1]
        try:
            count = int(tokens[2])
        except ValueError:
            continue
        gres = tokens[3] if len(tokens) > 3 else ""

        if name not in parts:
            gpu = 0
            if gres.startswith("gpu:"):
                ### Handle gpu:N, gpu:type:N, gpu:type:N(S:0-3), etc.
                for segment in reversed(gres.split(":")[1:]):
                    cleaned = segment.split("(")[0]
                    if cleaned.isdigit():
                        gpu = int(cleaned)
                        break
            parts[name] = Partition(name=name, gpu_per_node=gpu)

        p = parts[name]
        p.total += count
        cat = SINFO_STATE_MAP.get(state_raw, "")
        if cat:
            p.states[cat] = p.states.get(cat, 0) + count

    result = [p for p in parts.values() if p.total > 0]
    result.sort(key=lambda p: p.total, reverse=True)
    return result


def parse_sshare(output: str) -> list[ShareEntry]:
    """Parse sshare fixed-width output using the separator line to find column positions."""
    lines = output.strip().splitlines()
    if len(lines) < 3:
        return []

    # Column boundaries from the dash-separator line
    sep = lines[1]
    ranges: list[tuple[int, int]] = []
    in_dash = False
    start = 0
    for i, ch in enumerate(sep):
        if ch == "-" and not in_dash:
            start = i
            in_dash = True
        elif ch != "-" and in_dash:
            ranges.append((start, i))
            in_dash = False
    if in_dash:
        ranges.append((start, len(sep)))

    def field(line: str, idx: int) -> str:
        if idx >= len(ranges):
            return ""
        s, e = ranges[idx]
        return line[s:e].strip() if s < len(line) else ""

    entries: list[ShareEntry] = []
    for line in lines[2:]:
        account = field(line, 0)
        user = field(line, 1)
        if account == "root":
            continue

        try:
            raw_shares = int(field(line, 2) or "0")
        except ValueError:
            raw_shares = 0

        try:
            raw = int(field(line, 3) or "0")
        except ValueError:
            raw = 0
        if raw == 0:
            continue

        try:
            norm = float(field(line, 4) or "0")
        except ValueError:
            norm = 0.0
        try:
            eff = float(field(line, 5) or "0")
        except ValueError:
            eff = 0.0

        lfs_str = field(line, 6)
        try:
            lfs = float(lfs_str) if lfs_str else None
        except ValueError:
            lfs = None

        entries.append(
            ShareEntry(
                account=account, user=user, raw_shares=raw_shares,
                raw_usage=raw, norm_usage=norm, effectv_usage=eff,
                level_fs=lfs,
            )
        )

    return entries


def parse_squeue(output: str) -> list[Job]:
    """Parse squeue output delimited by \\x1f."""
    lines = output.strip().splitlines()
    if len(lines) < 2:
        return []

    jobs: list[Job] = []
    for line in lines[1:]:
        fields = line.split("\x1f")
        if len(fields) < 8:
            continue
        fields = [f.strip() for f in fields]

        name = fields[2]
        user = fields[3]

        ### Strip redundant {SLURM_GROUP}-{user}. prefix from job names
        prefix = f"{SLURM_GROUP}-{user}."
        if name.startswith(prefix):
            name = name[len(prefix):]

        try:
            nodes = int(fields[6])
        except ValueError:
            nodes = 0

        jobs.append(
            Job(
                jobid=fields[0], partition=fields[1], name=name,
                user=user, state=fields[4], time_str=fields[5],
                nodes=nodes, reason=fields[7] if fields[7] not in ("", "None") else "-",
            )
        )
    return jobs


