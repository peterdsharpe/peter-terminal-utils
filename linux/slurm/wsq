def _read_tail(path: str, max_lines: int = 500) -> list[str]:
    """Read the last max_lines from a file without loading the whole file.

    Uses the system `tail` command to avoid reading multi-GB log files into
    memory (common for long-running HPC training jobs).
    """
    out = _run(["tail", "-n", str(max_lines), path], timeout=10)
    if out:
        ### For lines with \r (progress bar overwrites), keep only the final
        ### segment - that's what a terminal would display after the carriage return.
        return [line.split("\r")[-1] for line in out.splitlines()]
    ### tail failed or returned empty - check why so we can show a useful message
    try:
        with open(path) as f:
            f.read(1)
        return ["  (file is empty)"]
    except FileNotFoundError:
        return [f"  (file not found: {path})"]
    except PermissionError:
        return [f"  (permission denied: {path})"]
    except OSError as e:
        return [f"  (error reading file: {e})"]


def _show_job_log(stdscr: curses.window, job: Job, h: int, w: int) -> None:
    """Show job stdout/stderr in a scrollable overlay with refresh and follow."""
    detail = _fetch_job_detail(job.jobid)
    stdout_path = detail.get("StdOut", "")
    stderr_path = detail.get("StdErr", "")

    if not stdout_path and not stderr_path:
        _draw_overlay_box(
            stdscr,
            ["", "  No output file path found for this job", "", "  q/Esc to close"],
            "Job Log", h, w,
        )
        return

    current = "stdout" if stdout_path else "stderr"
    path = stdout_path or stderr_path
    follow = True
    saved_offset = 0
    scrollbar_attr = curses.color_pair(C_SCROLLBAR)
    search_text = ""
    search_active = False
    match_indices: list[int] = []
    match_set: set[int] = set()

    while True:
        ### Full-screen overlay (no background bleed-through)
        box_w = w
        box_h = h - 1
        y0, x0 = 0, 0
        content_h = box_h - 2

        content = _read_tail(path)

        ### Build footer with search status
        search_hint = f"  /{search_text}" if search_text else ""
        match_hint = f" ({len(match_indices)} matches)" if search_text and match_indices else ""
        no_match_hint = " (no matches)" if search_text and not match_indices else ""
        hint_parts = ["r:refresh", "s:switch", f"f:follow({'on' if follow else 'off'})",
                      "/:search", "q:close"]
        hint = "  ".join(hint_parts)
        display = content + [
            "", f"  {DIM}{path}{search_hint}{match_hint}{no_match_hint}{RESET}",
            f"  {DIM}{hint}{RESET}", "",
        ]

        ### Recompute match indices after content reload
        if search_text:
            low = search_text.lower()
            match_indices = [i for i, line in enumerate(display)
                            if low in ANSI_RE.sub("", line).lower()]
            match_set = set(match_indices)

        scroll = ScrollState(total=len(display), visible=content_h)
        if follow:
            scroll.go_bottom()
        else:
            scroll.offset = saved_offset

        needs_sb = scroll.total > scroll.visible
        inner_w = box_w - 4 if needs_sb else box_w - 3

        title = f"Job {job.jobid} {current}"
        hline = "\u2500"
        top_border = f"\u256d\u2500 {title} {hline * max(0, box_w - len(title) - 5)}\u256e"
        bot_border = f"\u2570{hline * (box_w - 2)}\u256f"

        redraw = True
        while True:
            if redraw:
                scroll.clamp()
                stdscr.erase()
                try:
                    if search_active:
                        bar = f" Search: {search_text}\u2588"
                        stdscr.addstr(y0, x0, bar[:box_w].ljust(box_w), curses.A_REVERSE)
                    else:
                        stdscr.addstr(y0, x0, top_border[:box_w], curses.A_BOLD)
                    for i in range(content_h):
                        idx = scroll.offset + i
                        line = display[idx] if idx < len(display) else ""
                        is_match = search_text and idx in match_set
                        vis_len = len(ANSI_RE.sub("", line))
                        if vis_len > inner_w:
                            line = _truncate_ansi(line, inner_w)
                            vis_len = inner_w
                        pad = max(0, inner_w - vis_len)
                        sb_pad = " " if needs_sb else ""
                        row_str = f"\u2502 {line}{' ' * pad}{sb_pad}\u2502"
                        row_attr = curses.A_BOLD if is_match else 0
                        if is_match:
                            try:
                                stdscr.addstr(y0 + 1 + i, x0, " " * box_w, row_attr)
                            except curses.error:
                                pass
                        _addstr_ansi(
                            stdscr, y0 + 1 + i, x0, row_str, x0 + box_w,
                            base_attr=row_attr,
                        )
                    stdscr.addstr(y0 + box_h - 1, x0, bot_border[:box_w], curses.A_BOLD)
                except curses.error:
                    pass
                if needs_sb:
                    _draw_scrollbar(
                        stdscr, x0 + box_w - 2, y0 + 1, content_h,
                        scroll, scrollbar_attr,
                    )
                stdscr.refresh()
                redraw = False

            stdscr.timeout(2000 if follow else -1)
            key = stdscr.getch()

            ### ------- Search input mode -------
            if search_active:
                search_text, action = _handle_text_input(key, search_text)
                if action == "cancel":
                    match_indices = []
                    match_set = set()
                    search_active = False
                elif action == "submit":
                    search_active = False
                    if search_text:
                        low = search_text.lower()
                        match_indices = [
                            i for i, line in enumerate(display)
                            if low in ANSI_RE.sub("", line).lower()
                        ]
                        match_set = set(match_indices)
                        for mi in match_indices:
                            if mi >= scroll.offset:
                                scroll.offset = mi
                                scroll.clamp()
                                break
                redraw = True
                continue

            ### ------- Normal key handling -------
            if key == -1 and follow:
                saved_offset = scroll.offset
                break
            elif key in (ord("q"), 27):
                return
            elif key == ord("/"):
                search_active = True
                follow = False
                redraw = True
            elif key == ord("n") and match_indices:
                ### Jump to next match after current viewport top
                target = scroll.offset + 1
                hit = next((mi for mi in match_indices if mi >= target), None)
                if hit is None:
                    hit = match_indices[0]
                scroll.offset = hit
                scroll.clamp()
                redraw = True
            elif key == ord("N") and match_indices:
                ### Jump to previous match before current viewport top
                target = scroll.offset - 1
                hit = next((mi for mi in reversed(match_indices) if mi <= target), None)
                if hit is None:
                    hit = match_indices[-1]
                scroll.offset = hit
                scroll.clamp()
                redraw = True
            elif key == ord("r"):
                saved_offset = scroll.offset
                break
            elif key == ord("s"):
                if current == "stdout" and stderr_path:
                    current, path = "stderr", stderr_path
                elif current == "stderr" and stdout_path:
                    current, path = "stdout", stdout_path
                saved_offset = 0
                search_text = ""
                match_indices = []
                match_set = set()
                break
            elif key == ord("f"):
                follow = not follow
                if follow:
                    scroll.go_bottom()
                redraw = True
            elif _handle_viewport_scroll(key, scroll, content_h):
                follow = False
                redraw = True


def _job_action(
    stdscr: curses.window, job: Job, action: str, verb: str, h: int, w: int,
) -> bool:
    """Generic hold/release confirmation + execution. Returns True if acted."""
    if job.user != CURRENT_USER:
        _draw_overlay_box(
            stdscr,
            ["", f"  Cannot {verb}: job belongs to {job.user}", "", "  q/Esc to close"],
            verb.title(), h, w,
        )
        return False

    lines = [
        "",
        f"  {job.jobid}  {job.name}",
        f"  {job.user}  {job.state}  {job.nodes} nodes",
        "",
        f"  [y] {verb.title()} this job",
        "  [n/q] Cancel",
        "",
    ]
    _draw_prompt_box(stdscr, lines, f"{verb.title()} job?", h, w, max_width=60)
    while True:
        key = stdscr.getch()
        if key == ord("y"):
            _run(["scontrol", action, job.jobid], timeout=10)
            return True
        if key in (ord("n"), ord("q"), 27):
            return False


def _show_export_picker(stdscr: curses.window, h: int, w: int) -> str | None:
    """Show export format picker. Returns 'csv', 'json', or None."""
    lines = ["", "  [1] CSV", "  [2] JSON", "", "  q/Esc to cancel", ""]
    _draw_prompt_box(stdscr, lines, "Export format", h, w, max_width=30)
    while True:
        key = stdscr.getch()
        if key == ord("1"):
            return "csv"
        if key == ord("2"):
            return "json"
        if key in (27, ord("q")):
            return None


def _export_jobs(jobs: list[Job], fmt: str, path: str) -> None:
    """Write job data to a CSV or JSON file."""
    headers = ["JobID", "Partition", "Name", "User", "State", "Time", "Nodes", "Reason"]
    if fmt == "csv":
        with open(path, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(headers)
            for j in jobs:
                w.writerow([j.jobid, j.partition, j.name, j.user,
                            j.state, j.time_str, j.nodes, j.reason])
    else:
        data = [
            dict(zip(headers, [j.jobid, j.partition, j.name, j.user,
                                j.state, j.time_str, j.nodes, j.reason]))
            for j in jobs
        ]
        with open(path, "w") as f:
            json.dump(data, f, indent=2)


def _export_shares(shares: list[ShareEntry], fmt: str, path: str) -> None:
    """Write share data to a CSV or JSON file."""
    headers = ["Account", "User", "RawShares", "RawUsage", "NormUsage", "EffectvUsage", "LevelFS"]
    if fmt == "csv":
        with open(path, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(headers)
            for s in shares:
                w.writerow([s.account, s.user, s.raw_shares, s.raw_usage, s.norm_usage,
                            s.effectv_usage, s.level_fs if s.level_fs is not None else ""])
    else:
        data = [
            dict(zip(headers, [s.account, s.user, s.raw_shares, s.raw_usage, s.norm_usage,
                                s.effectv_usage, s.level_fs]))
            for s in shares
        ]
        with open(path, "w") as f:
            json.dump(data, f, indent=2)


def _fetch_node_details(nodelist: str = "") -> list[str]:
    """Fetch per-node status from sinfo and format with state colors.

    If nodelist is provided, shows only those nodes (for a specific job).
    If empty, shows only problematic nodes (drain/down/maint/reboot).
    """
    sep = "|"
    cmd = [
        "sinfo", "-N",
        f"--format=%N{sep}%P{sep}%T{sep}%c{sep}%m{sep}%e{sep}%G{sep}%R",
        "--noheader",
    ]
    if nodelist:
        cmd.extend(["-n", nodelist])
    else:
        cmd.extend(["-t", "drain,down,maint,reboot,fail,power_down"])

    out = _run(cmd, timeout=15)
    if not out.strip():
        if nodelist:
            return ["  (no node data for this job)"]
        return ["  (no problem nodes found - cluster looks healthy)"]

    ### Parse and deduplicate by node name (nodes in multiple partitions
    ### like batch/batch_long produce duplicate rows from sinfo -N)
    rows: list[list[str]] = []
    seen_nodes: set[str] = set()
    for line in out.strip().splitlines():
        parts = line.split(sep, 7)
        if len(parts) < 4:
            continue
        cleaned = [p.strip() for p in parts]
        node_name = cleaned[0]
        if node_name in seen_nodes:
            continue
        seen_nodes.add(node_name)
        for i in range(len(cleaned)):
            if cleaned[i] in ("(null)", "(none)", "N/A"):
                cleaned[i] = "-"
        rows.append(cleaned)

    if not rows:
        if nodelist:
            return ["  (no node data for this job)"]
        return ["  (no problem nodes found - cluster looks healthy)"]

    headers = ["Node", "Part", "State", "CPUs", "Mem", "FreeMem", "GRES", "Reason"]
    col_w = [len(h) for h in headers]
    for row in rows:
        for i in range(min(len(headers), len(row))):
            col_w[i] = max(col_w[i], len(row[i]))

    def fmt_row(vals: list[str]) -> str:
        parts = []
        for i in range(len(headers)):
            v = vals[i] if i < len(vals) else ""
            parts.append(f"{v:<{col_w[i]}}")
        return "  ".join(parts)

    hdr = fmt_row(headers)
    hline = "\u2500"
    lines: list[str] = [hdr, f"{DIM}{hline * len(hdr)}{RESET}"]

    state_colors = {
        "idle": GREEN, "idle~": GREEN,
        "mix": YELLOW, "mixed": YELLOW,
        "alloc": RED, "allocated": RED,
        "comp": BLUE, "completing": BLUE,
    }
    for row in rows:
        state_raw = row[2] if len(row) > 2 else ""
        state_key = state_raw.lower().rstrip("*$~+-")
        color = state_colors.get(state_key, DIM)
        lines.append(f"{color}{fmt_row(row)}{RESET}")

    return lines


def _show_node_details(
    stdscr: curses.window, h: int, w: int,
    nodelist: str = "", title: str = "",
) -> None:
    """Fetch and display node details in a scrollable overlay.

    When nodelist is given, shows those specific nodes (e.g., for a job).
    Otherwise shows only problematic nodes across the cluster.
    """
    lines = _fetch_node_details(nodelist)
    lines.extend(["", "  j/k to scroll \u00b7 q/Esc to close", ""])
    overlay_title = title or ("Problem Nodes" if not nodelist else "Node Details")
    _draw_overlay_box(stdscr, lines, overlay_title, h, w)


