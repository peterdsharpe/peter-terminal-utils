def _draw_help_overlay(stdscr: curses.window, h: int, w: int) -> None:
    """Draw a centered help box overlay and wait for any key to dismiss."""
    box_w = min(HELP_WIDTH, w - 4)
    box_h = len(HELP_LINES) + 2
    y0 = max(0, (h - box_h) // 2)
    x0 = max(0, (w - box_w) // 2)

    ### Draw box with opaque background - blank each row first
    top = f"╭─{HELP_TITLE}{'─' * (box_w - len(HELP_TITLE) - 3)}╮"
    bot = f"╰{'─' * (box_w - 2)}╯"

    try:
        stdscr.addstr(y0, x0, " " * box_w)
        stdscr.addstr(y0, x0, top[:box_w], curses.A_BOLD)
        for i, line in enumerate(HELP_LINES):
            stdscr.addstr(y0 + 1 + i, x0, " " * box_w)
            visible_len = len(ANSI_RE.sub("", line))
            pad = box_w - 3 - visible_len
            padded = f"│ {line}{' ' * max(0, pad)}│"
            _addstr_ansi(stdscr, y0 + 1 + i, x0, padded, x0 + box_w)
        stdscr.addstr(y0 + box_h - 1, x0, " " * box_w)
        stdscr.addstr(y0 + box_h - 1, x0, bot[:box_w], curses.A_BOLD)
    except curses.error:
        pass

    stdscr.refresh()
    stdscr.timeout(-1)
    stdscr.getch()


