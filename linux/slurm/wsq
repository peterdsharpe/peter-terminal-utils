### Processing
###############################################################################


def collapse_chains(jobs: list[Job]) -> list[Job]:
    """Merge dependency-chain jobs into their head (Running or Priority) job.

    Groups by (name, user, partition, nodes). Within each group, the head is
    the Running job if one exists, otherwise the first Priority-pending job.
    All Dependency-pending members are absorbed into head.dep_count.
    """
    ### Build groups
    groups: dict[tuple[str, str, str, int], list[Job]] = {}
    for job in jobs:
        key = (job.name, job.user, job.partition, job.nodes)
        groups.setdefault(key, []).append(job)

    ### Identify heads and dependency counts
    heads: dict[tuple, Job] = {}
    dep_counts: dict[tuple, int] = {}

    for key, group in groups.items():
        head: Job | None = None
        dep_count = 0

        for job in group:
            if job.state == "R":
                if head is None or head.state != "R":
                    head = job
            elif job.reason == "Priority":
                if head is None or head.state != "R":
                    head = job
            elif job.reason == "Dependency":
                dep_count += 1

        if head is not None and dep_count > 0:
            heads[key] = head
            dep_counts[key] = dep_count

    ### Rebuild job list, skipping absorbed dependency jobs
    result: list[Job] = []
    for job in jobs:
        key = (job.name, job.user, job.partition, job.nodes)
        if key in heads:
            if job is heads[key]:
                job.dep_count = dep_counts[key]
                result.append(job)
            elif job.reason == "Dependency" and job.state == "PD":
                continue
            else:
                result.append(job)
        else:
            result.append(job)
    return result


def collapse_arrays(jobs: list[Job]) -> list[Job]:
    """Merge pending job-array tasks into the running array task.

    Detects pending array specs (jobid contains '[') and matches them to
    running tasks sharing the same base ID.
    """
    ### Map base_id -> pending array job
    pending: dict[str, Job] = {}
    for job in jobs:
        if job.state == "PD" and "[" in job.jobid:
            base = job.jobid.split("_")[0]
            pending[base] = job

    if not pending:
        return jobs

    ### Parse count from array spec like "[3-5%1]"
    def _array_count(spec: str) -> int:
        m = re.search(r"\[([^\]]+)\]", spec)
        if not m:
            return 0
        inner = m.group(1).split("%")[0]
        count = 0
        for part in inner.split(","):
            if "-" in part:
                try:
                    lo, hi = part.split("-", 1)
                    count += int(hi) - int(lo) + 1
                except ValueError:
                    count += 1
            else:
                count += 1
        return count

    ### Match running tasks to pending array specs
    absorbed: set[int] = set()
    running_by_base: dict[str, Job] = {}
    for job in jobs:
        if job.state == "R" and "_" in job.jobid and "[" not in job.jobid:
            base = job.jobid.split("_")[0]
            running_by_base.setdefault(base, job)
            if base in pending:
                job.array_count = _array_count(pending[base].jobid)
                absorbed.add(id(pending[base]))

    ### Second pass: catch individual pending array tasks (no bracket notation,
    ### e.g., "2014800_5" when only one task is pending)
    for job in jobs:
        if (
            job.state == "PD"
            and "_" in job.jobid
            and "[" not in job.jobid
            and id(job) not in absorbed
        ):
            base = job.jobid.split("_")[0]
            if base in running_by_base:
                running_by_base[base].array_count += 1
                absorbed.add(id(job))

    return [j for j in jobs if id(j) not in absorbed]


def collapse_running_arrays(jobs: list[Job]) -> list[Job]:
    """Collapse running array tasks that share the same base job ID.

    Groups running jobs whose jobid contains '_' by (base_id, name, user,
    partition, nodes). For groups with >1 member, keeps the longest-running
    task, sets jobid to the base ID, multiplies nodes by the task count,
    and stores the count in task_count for display.
    """
    ### Identify running jobs with array-task suffixes
    array_groups: dict[tuple, list[Job]] = {}
    for job in jobs:
        if job.state == "R" and "_" in job.jobid and "[" not in job.jobid:
            base = job.jobid.split("_")[0]
            key = (base, job.name, job.user, job.partition, job.nodes)
            array_groups.setdefault(key, []).append(job)

    ### For groups with >1 task, pick the longest-running and annotate
    collapsed_ids: set[int] = set()
    for (base, _name, _user, _part, nodes_per_task), group in array_groups.items():
        if len(group) < 2:
            continue
        group.sort(key=lambda j: _time_seconds(j.time_str), reverse=True)
        head = group[0]
        head.jobid = base
        head.nodes = nodes_per_task * len(group)
        head.task_count = len(group)
        for other in group[1:]:
            collapsed_ids.add(id(other))

    return [j for j in jobs if id(j) not in collapsed_ids]


def collapse_user_batches(
    jobs: list[Job], threshold: int = 5
) -> list[JobOrSummary]:
    """Replace large blocks of same-user pending jobs with summary lines.

    Only collapses jobs that weren't already absorbed by chain/array collapse
    (i.e., standalone pending jobs with no dep_count or array_count).
    """
    ### Group standalone pending jobs by (user, partition, reason, nodes)
    groups: dict[tuple, list[Job]] = {}
    for job in jobs:
        if (
            job.state == "PD"
            and job.dep_count == 0
            and job.array_count == 0
            and job.reason not in ("None", "")
        ):
            key = (job.user, job.partition, job.reason, job.nodes)
            groups.setdefault(key, []).append(job)

    collapsed_ids: set[int] = set()
    summaries: list[SummaryLine] = []
    for (user, partition, reason, nodes), group in groups.items():
        if len(group) > threshold:
            for job in group:
                collapsed_ids.add(id(job))
            summaries.append(
                SummaryLine(
                    user=user, partition=partition,
                    count=len(group), nodes=nodes, reason=reason,
                )
            )

    result: list[JobOrSummary] = list(summaries)
    result.extend(j for j in jobs if id(j) not in collapsed_ids)
    return result


###############################################################################
### Sorting
###############################################################################


def _time_seconds(t: str) -> int:
    """Convert Slurm time string (D-HH:MM:SS, HH:MM:SS, MM:SS) to seconds."""
    if "-" in t:
        day_part, rest = t.split("-", 1)
        parts = rest.split(":")
        return (
            int(day_part) * 86400
            + int(parts[0]) * 3600
            + int(parts[1]) * 60
            + (int(parts[2]) if len(parts) > 2 else 0)
        )
    parts = t.split(":")
    if len(parts) == 3:
        return int(parts[0]) * 3600 + int(parts[1]) * 60 + int(parts[2])
    if len(parts) == 2:
        return int(parts[0]) * 60 + int(parts[1])
    return 0


def _format_seconds(total: int) -> str:
    """Convert seconds back to Slurm-style time string (D-HH:MM:SS or H:MM:SS)."""
    if total < 0:
        total = 0
    days, remainder = divmod(total, 86400)
    hours, remainder = divmod(remainder, 3600)
    minutes, seconds = divmod(remainder, 60)
    if days > 0:
        return f"{days}-{hours:02d}:{minutes:02d}:{seconds:02d}"
    if hours > 0:
        return f"{hours}:{minutes:02d}:{seconds:02d}"
    return f"{minutes}:{seconds:02d}"


def sort_items(items: list[JobOrSummary]) -> list[JobOrSummary]:
    """Sort: summaries with PD, then PD jobs, then R jobs. Within each: user, nodes desc, time desc."""

    def key(item: JobOrSummary) -> tuple:
        if isinstance(item, SummaryLine):
            return (0, item.user, -item.nodes, 0, "")
        state_ord = 0 if item.state == "PD" else 1
        return (
            state_ord,
            item.user,
            -item.nodes,
            -_time_seconds(item.time_str),
            item.name,
        )

    return sorted(items, key=key)


###############################################################################
### Rendering (produces ANSI-colored strings, shared by static + TUI)
###############################################################################


def _notes(job: Job, etas: dict[str, str]) -> str:
    """Build the Notes column value for a job."""
    parts: list[str] = []

    if job.state == "PD":
        if job.reason not in ("None", ""):
            parts.append(job.reason)
        eta = etas.get(job.jobid, "")
        if eta:
            parts.append(f"ETA:{eta}")
        if job.dep_count > 0:
            parts.append(f"+{job.dep_count} dep")
    else:
        if job.dep_count > 0:
            parts.append(f"+{job.dep_count} dep")
        if job.array_count > 0:
            parts.append(f"+{job.array_count} array")
        if job.task_count > 0:
            parts.append(f"split over {job.task_count} tasks")

    return " ".join(parts)


BAR_WIDTH = 20

### Bar segment definitions: (state_keys, block_char, ansi_color)
### Ordered: idle first (what you care about), then in-use, then unavailable.
BAR_SEGMENTS = [
    (["idle"], "█", GREEN),
    (["mixed"], "█", YELLOW),
    (["alloc"], "█", RED),
    (["comp"], "█", BLUE),
    (["plan"], "█", DIM),
    (["drain", "maint", "resv", "down"], "█", DIM),
]


def _utilization_bar(states: dict[str, int], total: int) -> str:
    """Render a 20-char multi-segment bar showing cluster state breakdown.

    Segments are colored to match the column headers (red=alloc, green=idle,
    etc.). The percentage shows idle fraction of the usable pool.
    """
    if total <= 0:
        return ""

    ### Build segment counts, folding unaccounted nodes into unavailable
    counts = []
    tracked = 0
    for keys, _, _ in BAR_SEGMENTS:
        c = sum(states.get(k, 0) for k in keys)
        counts.append(c)
        tracked += c
    counts[-1] += max(0, total - tracked)  # unaccounted → unavailable

    ### Quantize to characters using largest-remainder method
    raw = [c / total * BAR_WIDTH for c in counts]
    floors = [int(v) for v in raw]
    remainders = sorted(
        ((raw[i] - floors[i], i) for i in range(len(raw)) if counts[i] > 0),
        reverse=True,
    )
    gap = BAR_WIDTH - sum(floors)
    for _, idx in remainders[:gap]:
        floors[idx] += 1

    bar = ""
    for i, (_, char, color) in enumerate(BAR_SEGMENTS):
        if floors[i] > 0:
            bar += f"{color}{char * floors[i]}{RESET}"

    ### Show % idle of usable pool (excluding drain/maint/resv/down)
    unavail = sum(states.get(k, 0) for k in ("drain", "maint", "resv", "down"))
    usable = total - unavail
    idle = states.get("idle", 0)
    pct = f"{idle / usable * 100:3.0f}%" if usable > 0 else "  -"
    return f"  ▐{bar}▌ {DIM}{pct} idle{RESET}"


def _dedup_partitions(partitions: list[Partition]) -> list[Partition]:
    """Merge partitions that share identical nodes (same total, states, gpu).

    Overlapping partitions like batch/batch_long map to the same physical
    nodes and always have identical state counts. Merge their names into
    a single comma-separated entry to avoid duplicate rows.
    """
    groups: dict[tuple, list[Partition]] = {}
    for p in partitions:
        key = (p.total, tuple(sorted(p.states.items())), p.gpu_per_node)
        groups.setdefault(key, []).append(p)

    merged: list[Partition] = []
    for group in groups.values():
        if len(group) == 1:
            merged.append(group[0])
        else:
            combined = Partition(
                name=", ".join(p.name for p in group),
                gpu_per_node=group[0].gpu_per_node,
                total=group[0].total,
                states=group[0].states,
            )
            merged.append(combined)
    merged.sort(key=lambda p: p.total, reverse=True)
    return merged


def render_cluster_status(partitions: list[Partition]) -> list[str]:
    """Render the cluster status table with utilization bars and GPU summary."""
    if not partitions:
        return []

    partitions = _dedup_partitions(partitions)

    col_names = [name for name, _ in STATE_COLS]
    col_colors = [color for _, color in STATE_COLS]

    ### Compute column widths
    col_w = [len(n) for n in col_names]
    part_w = max(len(p.display_name) for p in partitions)

    for p in partitions:
        col_w[0] = max(col_w[0], len(str(p.total)))
        for i, name in enumerate(col_names[1:], 1):
            v = p.states.get(name, 0)
            if v > 0:
                col_w[i] = max(col_w[i], len(str(v)))

    ### GPU summary from the largest GPU partition (avoids double-counting
    ### overlapping partitions like batch / batch_long)
    gpu_parts = [p for p in partitions if p.gpu_per_node > 0]
    gpu_summary = ""
    if gpu_parts:
        biggest = max(gpu_parts, key=lambda p: p.total)
        total_gpus = biggest.total * biggest.gpu_per_node
        alloc_gpus = biggest.states.get("alloc", 0) * biggest.gpu_per_node
        gpu_summary = f" \u2014 {alloc_gpus:,}/{total_gpus:,} GPUs allocated"

    lines: list[str] = []
    cluster = _get_cluster_name()
    title_parts = ["Cluster Status"]
    if cluster:
        title_parts[0] += f" ({cluster})"
    title_parts[0] += gpu_summary + ":"
    lines.append(f"{BOLD}{title_parts[0]}{RESET}")

    ### Header row
    hdr = f"  {'':>{part_w}}"
    for i, name in enumerate(col_names):
        hdr += f"  {col_colors[i]}{name:>{col_w[i]}}{RESET}"
    lines.append(hdr)

    ### Data rows with utilization bars
    for p in partitions:
        row = f"  {p.display_name:<{part_w}}"
        row += f"  {col_colors[0]}{p.total:>{col_w[0]}}{RESET}"
        for i, name in enumerate(col_names[1:], 1):
            v = p.states.get(name, 0)
            if v > 0:
                row += f"  {col_colors[i]}{v:>{col_w[i]}}{RESET}"
            else:
                row += f"  {DIM}{'-':>{col_w[i]}}{RESET}"
        row += _utilization_bar(p.states, p.total)
        lines.append(row)

    return lines


def _active_nodes_by_user(items: list[JobOrSummary]) -> dict[str, int]:
    """Sum running-job nodes per user for the Shares table 'Nodes' column."""
    totals: dict[str, int] = {}
    for item in items:
        if isinstance(item, Job) and item.state == "R":
            totals[item.user] = totals.get(item.user, 0) + item.nodes
    return totals


def render_shares(
    shares: list[ShareEntry],
    items: list[JobOrSummary] | None = None,
) -> list[str]:
    """Render the sshare table with an active-nodes column from job data."""
    if not shares:
        return []

    groups = sorted(
        [s for s in shares if s.is_group], key=lambda s: s.raw_usage, reverse=True
    )
    users = sorted(
        [s for s in shares if not s.is_group], key=lambda s: s.raw_usage, reverse=True
    )
    ordered = groups + users

    ### Compute active nodes per user from job data
    user_nodes = _active_nodes_by_user(items) if items else {}
    ### For group rows, sum across all users belonging to that account
    account_nodes: dict[str, int] = {}
    for s in users:
        if user_nodes.get(s.user, 0) > 0:
            account_nodes[s.account] = (
                account_nodes.get(s.account, 0) + user_nodes[s.user]
            )

    ### Build row data as strings
    headers = ["Account", "User", "Nodes", "RawUsage", "NormUsage", "EffectvUsage", "LevelFS"]

    def fmt_row(s: ShareEntry) -> list[str]:
        lfs = f"{s.level_fs:.6f}" if s.level_fs is not None else ""
        if s.is_group:
            n = account_nodes.get(s.account, 0)
        else:
            n = user_nodes.get(s.user, 0)
        nodes_str = str(n) if n > 0 else "-"
        return [
            s.account,
            s.user,
            nodes_str,
            f"{s.raw_usage:,}",
            f"{s.norm_usage:.6f}",
            f"{s.effectv_usage:.6f}",
            lfs,
        ]

    rows = [fmt_row(s) for s in ordered]

    ### Column widths; right-align numeric columns for easier scanning
    RIGHT_COLS = {2, 3, 6}  # Nodes, RawUsage, LevelFS
    widths = [len(h) for h in headers]
    for row in rows:
        for i, val in enumerate(row):
            widths[i] = max(widths[i], len(val))

    def pad(vals: list[str]) -> str:
        parts = []
        for i, v in enumerate(vals):
            if i in RIGHT_COLS:
                parts.append(f"{v:>{widths[i]}}")
            else:
                parts.append(f"{v:<{widths[i]}}")
        return "  ".join(parts)

    header_str = pad(headers)
    header_width = sum(widths) + 2 * (len(widths) - 1)
    lines: list[str] = [header_str, f"{DIM}{'─' * header_width}{RESET}"]
    for entry, row in zip(ordered, rows):
        raw = pad(row)
        color = usage_color(entry.raw_usage)
        is_me = entry.user == CURRENT_USER or (
            entry.is_group and entry.account == SLURM_GROUP
        )
        if is_me:
            lines.append(f"{BOLD}{color}{raw}{RESET}")
        else:
            lines.append(f"{color}{raw}{RESET}")

    return lines


def render_jobs(
    items: list[JobOrSummary], etas: dict[str, str], time_offset: int = 0
) -> list[str]:
    """Render the job table with chain/array annotations.

    Args:
        time_offset: Seconds to add to running job times (for TUI live ticking).
    """
    if not items:
        return []

    ### Separate jobs from summaries for column width computation
    job_items = [j for j in items if isinstance(j, Job)]

    headers = ["JobID", "Part", "Name", "User", "St", "Time", "#", "Notes"]

    def job_row(j: Job) -> list[str]:
        displayed_time = j.time_str
        if time_offset > 0 and j.state == "R":
            displayed_time = _format_seconds(_time_seconds(j.time_str) + time_offset)
        return [
            j.jobid, j.partition, j.name, j.user,
            j.state, displayed_time, str(j.nodes), _notes(j, etas),
        ]

    rows = {id(j): job_row(j) for j in job_items}

    ### Truncate other users' names to avoid extreme horizontal sprawl.
    ### Cap is max(65, longest current-user name) so the column is never wider
    ### than needed for your own jobs.
    my_names = [r[2] for j, r in zip(job_items, rows.values()) if j.user == CURRENT_USER]
    name_cap = max(65, max((len(n) for n in my_names), default=0))
    for j, row in zip(job_items, rows.values()):
        if j.user != CURRENT_USER and len(row[2]) > name_cap:
            row[2] = row[2][: name_cap - 1] + "\u2026"

    ### Column widths from headers + job data
    widths = [len(h) for h in headers]
    for row in rows.values():
        for i, val in enumerate(row):
            widths[i] = max(widths[i], len(val))

    ### Right-align # column, left-align everything else
    def fmt_line(vals: list[str]) -> str:
        parts = []
        for i, v in enumerate(vals):
            if i in (5, 6):  # Time and # columns are right-aligned
                parts.append(f"{v:>{widths[i]}}")
            else:
                parts.append(f"{v:<{widths[i]}}")
        return "  ".join(parts)

    header_str = fmt_line(headers)
    header_width = sum(widths) + 2 * (len(widths) - 1)
    lines: list[str] = [header_str, f"{DIM}{'─' * header_width}{RESET}"]

    for item in items:
        if isinstance(item, SummaryLine):
            text = (
                f"  {item.user}: {item.count} {item.partition} jobs pending"
                f" ({item.reason}), {item.nodes} nodes each"
            )
            lines.append(f"{DIM}{text}{RESET}")
            continue

        row = rows[id(item)]
        raw = fmt_line(row)

        if item.state == "PD":
            colored = f"{DIM}{raw}{RESET}"
        else:
            colored = f"{node_color(item.nodes)}{raw}{RESET}"

        if item.user == CURRENT_USER:
            colored = f"{BOLD}{colored}"

        lines.append(colored)

    return lines


SEPARATOR_WIDTH = 80


def _separator() -> str:
    """A dim horizontal rule for visual separation between sections."""
    return f"{DIM}{'─' * SEPARATOR_WIDTH}{RESET}"


def render_all(
    partitions: list[Partition],
    shares: list[ShareEntry],
    items: list[JobOrSummary],
    etas: dict[str, str],
    time_offset: int = 0,
) -> list[str]:
    """Render all sections into a flat list of ANSI-colored lines.

    Args:
        time_offset: Seconds to add to running job times (for TUI live ticking).
    """
    if not partitions and not shares and not items:
        return [
            f"{DIM}No data available (Slurm controller may be unreachable).{RESET}",
            f"{DIM}Retrying on next refresh...{RESET}",
        ]

    lines: list[str] = []
    cluster = render_cluster_status(partitions)
    share_lines = render_shares(shares, items)
    job_lines = render_jobs(items, etas, time_offset=time_offset)

    if cluster:
        lines.extend(cluster)
    if share_lines:
        if lines:
            lines.append(_separator())
        lines.extend(share_lines)
    if job_lines:
        if lines:
            lines.append(_separator())
        lines.extend(job_lines)
    return lines


