### Continuous heat-map gradient (blue → cyan → green → yellow → orange → red)
GRADIENT_STOPS = [
    (0.0, (80, 130, 255)),
    (0.2, (0, 210, 220)),
    (0.4, (50, 205, 80)),
    (0.6, (230, 210, 0)),
    (0.8, (255, 150, 0)),
    (1.0, (255, 70, 60)),
]


def _gradient_rgb(t: float) -> tuple[int, int, int]:
    """Interpolate the heat gradient at position t in [0, 1]."""
    t = max(0.0, min(1.0, t))
    for i in range(len(GRADIENT_STOPS) - 1):
        t0, (r0, g0, b0) = GRADIENT_STOPS[i]
        t1, (r1, g1, b1) = GRADIENT_STOPS[i + 1]
        if t <= t1:
            f = (t - t0) / (t1 - t0)
            return (int(r0 + (r1 - r0) * f), int(g0 + (g1 - g0) * f), int(b0 + (b1 - b0) * f))
    return GRADIENT_STOPS[-1][1]


def _gradient_ansi(t: float) -> str:
    """ANSI true color escape for gradient position t."""
    r, g, b = _gradient_rgb(t)
    return f"\033[38;2;{r};{g};{b}m"


def usage_color(raw_usage: int) -> str:
    """Continuous gradient for RawUsage on a log10 scale (1 → blue, 100M → red)."""
    t = math.log10(max(1, raw_usage)) / 8.0
    return _gradient_ansi(t)


def node_color(nodes: int) -> str:
    """Continuous gradient for node count on a log2 scale (1 → blue, 512 → red)."""
    t = math.log2(max(1, nodes)) / 9.0
    return _gradient_ansi(t)


