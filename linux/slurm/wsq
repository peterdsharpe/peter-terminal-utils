ANSI_RE = re.compile(r"\033\[([0-9;]*)m")

### Scrollbar and gradient color pair indices
C_SCROLLBAR = 7
GRADIENT_STEPS = 64
C_GRADIENT_BASE = 10
LOWER_EIGHTHS = " ▁▂▃▄▅▆▇█"
UPPER_EIGHTHS = " ▔🮂🮃▀🮄🮅🮆█"

SCROLL_STEP = 3


@dataclass
class ScrollState:
    """Scroll position tracking for the TUI content area."""

    offset: int = 0
    total: int = 0
    visible: int = 0

    def clamp(self) -> None:
        self.offset = max(0, min(self.offset, max(0, self.total - self.visible)))

    def scroll_up(self, n: int = SCROLL_STEP) -> None:
        self.offset -= n
        self.clamp()

    def scroll_down(self, n: int = SCROLL_STEP) -> None:
        self.offset += n
        self.clamp()

    def page_up(self) -> None:
        self.scroll_up(max(1, self.visible - 1))

    def page_down(self) -> None:
        self.scroll_down(max(1, self.visible - 1))

    def go_top(self) -> None:
        self.offset = 0

    def go_bottom(self) -> None:
        self.offset = max(0, self.total - self.visible)

    def ensure_visible(self, idx: int) -> None:
        """Adjust offset so item at idx is within the visible window."""
        if idx < self.offset:
            self.offset = idx
        elif idx >= self.offset + self.visible:
            self.offset = idx - self.visible + 1
        self.clamp()


def _rgb_to_256(r: int, g: int, b: int) -> int:
    """Nearest 256-color index for an RGB value (6x6x6 cube, indices 16-231)."""
    return 16 + 36 * round(r / 255 * 5) + 6 * round(g / 255 * 5) + round(b / 255 * 5)


def _init_colors() -> None:
    """Initialize curses color pairs: base ANSI, scrollbar, and gradient palette."""
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(C_RED, curses.COLOR_RED, -1)
    curses.init_pair(C_GREEN, curses.COLOR_GREEN, -1)
    curses.init_pair(C_YELLOW, curses.COLOR_YELLOW, -1)
    curses.init_pair(C_BLUE, curses.COLOR_BLUE, -1)
    curses.init_pair(C_CYAN, curses.COLOR_CYAN, -1)
    if curses.COLORS >= 256:
        curses.init_pair(C_ORANGE, 208, -1)
        curses.init_pair(C_SCROLLBAR, 249, 236)
        ### Pre-allocate gradient palette for continuous color mapping
        for i in range(GRADIENT_STEPS):
            t = i / (GRADIENT_STEPS - 1)
            r, g, b = _gradient_rgb(t)
            curses.init_pair(C_GRADIENT_BASE + i, _rgb_to_256(r, g, b), -1)
    else:
        curses.init_pair(C_ORANGE, curses.COLOR_YELLOW, -1)
        curses.init_pair(C_SCROLLBAR, curses.COLOR_WHITE, curses.COLOR_BLACK)


### Map ANSI SGR code -> curses attribute
_ANSI_ATTR: dict[str, int] = {}


def _build_attr_map() -> None:
    """Populate _ANSI_ATTR after curses is initialized."""
    _ANSI_ATTR.update(
        {
            "1": curses.A_BOLD,
            "2": curses.A_DIM,
            "31": curses.color_pair(C_RED),
            "32": curses.color_pair(C_GREEN),
            "33": curses.color_pair(C_YELLOW),
            "34": curses.color_pair(C_BLUE),
            "36": curses.color_pair(C_CYAN),
            "38;5;208": curses.color_pair(C_ORANGE),
        }
    )


### Pre-computed table mapping each gradient step's 256-color index back to its pair.
### Built once by _build_attr_map; used by _parse_ansi for O(1) true-color lookup.
_gradient_256_to_pair: dict[int, int] = {}


def _build_gradient_lookup() -> None:
    """Build reverse lookup from 256-color index to gradient curses pair."""
    for i in range(GRADIENT_STEPS):
        t = i / (GRADIENT_STEPS - 1)
        r, g, b = _gradient_rgb(t)
        c256 = _rgb_to_256(r, g, b)
        _gradient_256_to_pair[c256] = curses.color_pair(C_GRADIENT_BASE + i)


def _nearest_gradient_pair(r: int, g: int, b: int) -> int:
    """Find the curses color pair closest to an RGB value from the gradient palette."""
    c256 = _rgb_to_256(r, g, b)
    if c256 in _gradient_256_to_pair:
        return _gradient_256_to_pair[c256]
    ### Fallback: find nearest by RGB distance across all gradient steps
    best_pair = 0
    best_dist = float("inf")
    for i in range(GRADIENT_STEPS):
        t = i / (GRADIENT_STEPS - 1)
        gr, gg, gb = _gradient_rgb(t)
        dist = (r - gr) ** 2 + (g - gg) ** 2 + (b - gb) ** 2
        if dist < best_dist:
            best_dist = dist
            best_pair = curses.color_pair(C_GRADIENT_BASE + i)
    return best_pair


def _parse_ansi(text: str) -> list[tuple[str, int]]:
    """Parse ANSI-escaped string into (text_segment, curses_attr) pairs.

    Handles standard SGR codes (bold, dim, basic colors, 256-color) and
    true color codes (38;2;R;G;B) by mapping to the nearest gradient pair.
    """
    segments: list[tuple[str, int]] = []
    attr = 0
    pos = 0

    for m in ANSI_RE.finditer(text):
        if m.start() > pos:
            segments.append((text[pos : m.start()], attr))
        code = m.group(1)
        if code in ("0", ""):
            attr = 0
        elif code in ("1", "2"):
            attr |= _ANSI_ATTR.get(code, 0)
        elif code.startswith("38;2;"):
            ### True color: map to nearest gradient palette entry
            parts = code.split(";")
            try:
                r, g, b = int(parts[2]), int(parts[3]), int(parts[4])
                pair = _nearest_gradient_pair(r, g, b)
                attr = (attr & (curses.A_BOLD | curses.A_DIM)) | pair
            except (IndexError, ValueError):
                pass
        else:
            ### Standard color code: keep bold/dim, replace color
            attr = (attr & (curses.A_BOLD | curses.A_DIM)) | _ANSI_ATTR.get(code, 0)
        pos = m.end()

    if pos < len(text):
        segments.append((text[pos:], attr))
    return segments


def _addstr_ansi(win: curses.window, y: int, x: int, text: str, max_x: int) -> None:
    """Write ANSI-colored text to a curses window, clipping at max_x."""
    col = x
    for segment, attr in _parse_ansi(text):
        if col >= max_x:
            break
        avail = max_x - col
        fragment = segment[:avail]
        try:
            win.addstr(y, col, fragment, attr)
        except curses.error:
            pass
        col += len(fragment)


def _draw_scrollbar(
    stdscr: curses.window,
    x: int,
    y_start: int,
    height: int,
    scroll: ScrollState,
    attr: int,
) -> None:
    """Draw a vertical scrollbar with sub-character precision positioning.

    Ported from linux/setup. Uses Unicode eighth-block characters for smooth
    thumb rendering at 8x finer granularity than integer cell positions.
    """
    if height < 2 or scroll.total <= scroll.visible:
        return

    thumb_size = max(1.0, height * scroll.visible / scroll.total)
    max_offset = max(1, scroll.total - scroll.visible)
    thumb_pos = (height - thumb_size) * scroll.offset / max_offset
    thumb_top = thumb_pos
    thumb_bottom = thumb_pos + thumb_size

    for i in range(height):
        y = y_start + i
        cell_top = float(i)
        cell_bottom = float(i + 1)

        if thumb_bottom <= cell_top or thumb_top >= cell_bottom:
            char = " "
        elif thumb_top <= cell_top and thumb_bottom >= cell_bottom:
            char = "█"
        elif thumb_top > cell_top and thumb_bottom < cell_bottom:
            eighths = max(1, min(8, round((thumb_bottom - thumb_top) * 8)))
            char = LOWER_EIGHTHS[eighths]
        elif thumb_top > cell_top:
            eighths = max(1, min(8, round((cell_bottom - thumb_top) * 8)))
            char = LOWER_EIGHTHS[eighths]
        else:
            eighths = max(1, min(8, round((thumb_bottom - cell_top) * 8)))
            char = UPPER_EIGHTHS[eighths]

        try:
            stdscr.addstr(y, x, char, attr)
        except curses.error:
            pass


