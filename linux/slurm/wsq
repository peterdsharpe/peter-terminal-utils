def _draw_overlay_box(
    stdscr: curses.window,
    lines: list[str],
    title: str,
    h: int,
    w: int,
) -> None:
    """Draw a centered, scrollable overlay box and block until dismissed."""
    box_w = min(max(len(ANSI_RE.sub("", l)) for l in lines) + 6, w - 6)
    box_h = min(len(lines) + 2, h - 4)
    y0 = max(0, (h - box_h) // 2)
    x0 = max(0, (w - box_w) // 2)
    content_h = box_h - 2

    scroll = ScrollState(total=len(lines), visible=content_h)
    needs_sb = scroll.total > scroll.visible
    inner_w = box_w - 4 if needs_sb else box_w - 3
    scrollbar_attr = curses.color_pair(C_SCROLLBAR) if needs_sb else 0

    top_border = f"╭─ {title} {'─' * max(0, box_w - len(title) - 5)}╮"
    bot_border = f"╰{'─' * (box_w - 2)}╯"

    while True:
        scroll.clamp()
        for row in range(box_h):
            try:
                stdscr.addstr(y0 + row, x0, " " * box_w)
            except curses.error:
                pass

        try:
            stdscr.addstr(y0, x0, top_border[:box_w], curses.A_BOLD)
            for i in range(content_h):
                idx = scroll.offset + i
                line = lines[idx] if idx < len(lines) else ""
                vis_len = len(ANSI_RE.sub("", line))
                if vis_len > inner_w:
                    line = _truncate_ansi(line, inner_w)
                    vis_len = inner_w
                pad = max(0, inner_w - vis_len)
                sb_pad = " " if needs_sb else ""
                row_str = f"│ {line}{' ' * pad}{sb_pad}│"
                _addstr_ansi(stdscr, y0 + 1 + i, x0, row_str, x0 + box_w)
            stdscr.addstr(y0 + box_h - 1, x0, bot_border[:box_w], curses.A_BOLD)
        except curses.error:
            pass

        if needs_sb:
            _draw_scrollbar(
                stdscr, x0 + box_w - 2, y0 + 1, content_h, scroll, scrollbar_attr,
            )

        stdscr.refresh()
        stdscr.timeout(-1)
        key = stdscr.getch()

        if key in (ord("q"), 27, ord("\n")):
            break
        else:
            _handle_viewport_scroll(key, scroll)


def _fetch_job_detail(jobid: str) -> dict[str, str]:
    """Fetch and parse scontrol show job output into a key-value dict.

    scontrol output uses `Key=Value` pairs separated by whitespace, but values
    can contain spaces (e.g., `Reason=ReqNodeNotAvail, UnavailableNodes:...`).
    We handle this by scanning for the `Key=` pattern: a token is a new key
    only if it matches `AlphaKey=...`; otherwise it's a continuation of the
    previous value.

    For array base IDs, scontrol returns multiple job blocks separated by
    blank lines. We parse only the first block.
    """
    out = _run(["scontrol", "show", "job", jobid], timeout=10)
    detail: dict[str, str] = {}
    key_re = re.compile(r"^([A-Za-z][A-Za-z0-9_]*)=(.*)")
    last_key = ""
    for line in out.splitlines():
        if not line.strip():
            if detail:
                break
            continue
        for token in line.split():
            m = key_re.match(token)
            if m:
                last_key = m.group(1)
                detail[last_key] = m.group(2)
            elif last_key:
                detail[last_key] += " " + token
    return detail


def _show_job_detail(stdscr: curses.window, job: Job, h: int, w: int) -> None:
    """Fetch job details via scontrol and display in an overlay."""
    detail = _fetch_job_detail(job.jobid)
    if not detail:
        detail = {"Error": "Could not fetch job details"}

    submit = detail.get("SubmitTime", "?")
    start = detail.get("StartTime", "?")
    end = detail.get("EndTime", "?")

    lines = [
        "",
        f"  State:       {detail.get('JobState', '?')}  ({detail.get('Reason', '')})",
        f"  Account:     {detail.get('Account', '?')}",
        f"  Partition:   {detail.get('Partition', '?')}    QOS: {detail.get('QOS', '?')}",
        f"  Nodes:       {detail.get('NumNodes', '?')}    GPUs: {detail.get('TresPerNode', '-')}",
        f"  TimeLimit:   {detail.get('TimeLimit', '?')}    RunTime: {detail.get('RunTime', '?')}",
        f"  Submit:      {submit}  {_relative_time(submit)}".rstrip(),
        f"  Start:       {start}  {_relative_time(start)}".rstrip(),
        f"  End:         {end}  {_relative_time(end)}".rstrip(),
        "",
        f"  WorkDir:     {detail.get('WorkDir', '?')}",
        f"  Command:     {detail.get('Command', '?')}",
        f"  StdOut:      {detail.get('StdOut', '?')}",
        "",
        f"  Dependency:  {detail.get('Dependency', 'None')}",
    ]
    if job.dep_count > 0:
        lines.append(f"  Chain:       +{job.dep_count} dependency jobs queued")
    if job.array_count > 0:
        lines.append(f"  Array:       +{job.array_count} pending array tasks")
    if job.task_count > 0:
        lines.append(f"  Tasks:       split over {job.task_count} running tasks")
    if job.more_count > 0:
        lines.extend(["", f"  +{job.more_count} similar jobs collapsed:"])
        for name in job.collapsed_names:
            lines.append(f"    {name}")
    lines.extend(["", "  j/k to scroll · q/Esc to close", ""])

    _draw_overlay_box(stdscr, lines, f"Job {job.jobid}: {job.name}", h, w)


def _draw_prompt_box(
    stdscr: curses.window,
    lines: list[str],
    title: str,
    h: int,
    w: int,
    max_width: int = 70,
) -> None:
    """Draw a centered prompt box (background + border + content).

    Shared rendering for simple confirmation/picker dialogs. After calling
    this, the dialog's key-handling loop should call stdscr.getch() directly.
    """
    box_w = min(max(len(ln) for ln in lines) + 6, w - 4, max_width)
    box_h = len(lines) + 2
    y0 = max(0, (h - box_h) // 2)
    x0 = max(0, (w - box_w) // 2)

    top = f"╭─ {title} {'─' * max(0, box_w - len(title) - 5)}╮"
    bot = f"╰{'─' * (box_w - 2)}╯"

    for row in range(box_h):
        try:
            stdscr.addstr(y0 + row, x0, " " * box_w)
        except curses.error:
            pass
    try:
        stdscr.addstr(y0, x0, top[:box_w], curses.A_BOLD)
        for i, line in enumerate(lines):
            padded = f"│ {line:<{box_w - 3}}│"
            stdscr.addstr(y0 + 1 + i, x0, padded[:box_w])
        stdscr.addstr(y0 + box_h - 1, x0, bot[:box_w], curses.A_BOLD)
    except curses.error:
        pass

    stdscr.refresh()
    stdscr.timeout(-1)


def _show_cancel_confirm(
    stdscr: curses.window, job: Job, h: int, w: int
) -> str | None:
    """Show cancel confirmation dialog. Returns 'y', 'a', 'p', or None."""
    if job.user != CURRENT_USER:
        lines = ["", f"  Cannot cancel: job belongs to {job.user}", "", "  q/Esc to close"]
        _draw_overlay_box(stdscr, lines, "Cancel", h, w)
        return None

    lines = [
        "",
        f"  {job.jobid}  {job.name}",
        f"  {job.user}  {job.state}  {job.time_str}  {job.nodes} nodes",
        "",
    ]

    has_chain = job.dep_count > 0
    has_array = job.array_count > 0 or job.task_count > 0
    has_pending = (has_chain or has_array) and job.state == "R"

    if has_chain:
        lines.append("  [y] Cancel this job only")
        if has_pending:
            lines.append(f"  [p] Cancel {job.dep_count} pending (keep running)")
        lines.append(f"  [a] Cancel all {job.dep_count + 1} (this + {job.dep_count} chained)")
    elif has_array:
        total = job.array_count + job.task_count + 1
        lines.append("  [y] Cancel this job only")
        if has_pending:
            lines.append("  [p] Cancel pending tasks (keep running)")
        lines.append(f"  [a] Cancel entire array ({total} tasks)")
    else:
        lines.append("  [y] Cancel this job")

    lines.extend(["  [n/q] Cancel", ""])

    _draw_prompt_box(stdscr, lines, "Cancel job?", h, w)
    while True:
        key = stdscr.getch()
        if key == ord("y"):
            return "y"
        if key == ord("p") and has_pending:
            return "p"
        if key == ord("a") and (has_chain or has_array):
            return "a"
        if key in (ord("n"), ord("q"), 27):
            return None


def _do_cancel(job: Job, mode: str) -> None:
    """Execute scancel for a job. mode='y' cancels one, 'a' cancels chain/array, 'p' pending only."""
    if mode == "y":
        _run(["scancel", job.jobid], timeout=10)
    elif mode == "p":
        if job.dep_count > 0:
            _run(["scancel", "-t", "PENDING", "-n", job.name, "-u", CURRENT_USER], timeout=10)
        else:
            base = job.jobid.split("_")[0] if "_" in job.jobid else job.jobid
            _run(["scancel", "-t", "PENDING", base], timeout=10)
    elif mode == "a":
        if job.dep_count > 0:
            _run(["scancel", "-n", job.name, "-u", CURRENT_USER], timeout=10)
        else:
            base = job.jobid.split("_")[0] if "_" in job.jobid else job.jobid
            _run(["scancel", base], timeout=10)


