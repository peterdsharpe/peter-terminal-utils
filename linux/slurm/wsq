### TUI Main Loop
###############################################################################


def _run_tui(stdscr: curses.window, args: argparse.Namespace) -> None:
    """Main TUI loop with cursor selection, tabbed panes, and action overlays."""
    _init_colors()
    _build_attr_map()
    _build_gradient_lookup()
    curses.curs_set(0)
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)

    scope = args.scope
    running_only = args.running
    timing = args.timing
    interval = args.interval

    ### Cached data from last fetch
    partitions: list[Partition] = []
    shares: list[ShareEntry] = []
    items: list[Job] = []
    etas: dict[str, str] = {}
    ordered_shares: list[ShareEntry] = []
    user_nodes: dict[str, int] = {}

    active_tab = 0
    cursor_per_tab = [0, 0]
    scroll_per_tab = [ScrollState(), ScrollState()]
    last_fetch = 0.0
    needs_refresh = True
    scrollbar_attr = curses.color_pair(C_SCROLLBAR)

    ### Filter state (per-tab)
    filter_text = ["", ""]
    filter_active = False

    ### Sort state (per-tab): mode index + ascending flag
    sort_mode = [0, 0]
    sort_ascending = [True, True]

    ### Transient flash message for the status bar (e.g., "exported to ...")
    flash_msg = ""
    flash_until = 0.0
    while True:
        now = time.time()
        h, w = stdscr.getmaxyx()

        ### Refresh data from Slurm if interval elapsed or forced
        if needs_refresh or (now - last_fetch) >= interval:
            partitions, shares, items, etas = fetch_all(scope, running_only, timing)
            ordered_shares = _sort_shares_by(shares, mode=0, ascending=True)
            user_nodes = _active_nodes_by_user(items)
            last_fetch = time.time()
            now = last_fetch
            needs_refresh = False

        ### Determine selectable items for current tab, applying sort + filter
        if active_tab == 0:
            all_selectable: list = list(items)  # Job or ShareEntry, narrowed by active_tab
            if sort_mode[0] != 0:
                all_selectable = _sort_jobs_by(all_selectable, sort_mode[0], sort_ascending[0])
        else:
            all_selectable = list(ordered_shares)
            if sort_mode[1] != 0:
                all_selectable = _sort_shares_by(
                    all_selectable, sort_mode[1], sort_ascending[1], user_nodes,
                )

        ft = filter_text[active_tab]
        if ft:
            selectable = [s for s in all_selectable if _match_filter(s, ft)]
        else:
            selectable = all_selectable

        cursor = cursor_per_tab[active_tab]
        cursor = max(0, min(cursor, len(selectable) - 1)) if selectable else 0
        cursor_per_tab[active_tab] = cursor

        ### Render fixed header (cluster status)
        header_lines = render_cluster_status(partitions)
        if header_lines:
            header_lines.append(_separator())
        header_h = len(header_lines)

        ### Render tab content from the (possibly filtered/sorted) selectable list
        time_offset = int(now - last_fetch)
        if active_tab == 0:
            if ft or sort_mode[0] != 0:
                tab_lines = render_jobs(selectable, etas, time_offset=time_offset)
            else:
                tab_lines = render_jobs(items, etas, time_offset=time_offset)
        else:
            if ft or sort_mode[1] != 0:
                tab_lines = render_shares(
                    selectable, items, pre_sorted=True, user_nodes=user_nodes,
                )
            else:
                tab_lines = render_shares(shares, items, user_nodes=user_nodes)

        ### Build mapping: tab content line index -> selectable item index
        line_to_sel: list[int] = []
        sel_idx = 0
        for line_i, line in enumerate(tab_lines):
            if line_i < 2:
                line_to_sel.append(-1)
                continue
            if not ANSI_RE.sub("", line).strip():
                line_to_sel.append(-1)
            elif sel_idx < len(selectable):
                line_to_sel.append(sel_idx)
                sel_idx += 1
            else:
                line_to_sel.append(-1)

        cursor_line = -1
        for i, si in enumerate(line_to_sel):
            if si == cursor:
                cursor_line = i
                break

        ### Scrollable area dimensions
        list_h = h - 1 - header_h
        scroll = scroll_per_tab[active_tab]
        scroll.total = len(tab_lines)
        scroll.visible = list_h
        if cursor_line >= 0:
            scroll.ensure_visible(cursor_line)
        scroll.clamp()

        needs_scrollbar = scroll.total > scroll.visible
        content_w = w - 1 if needs_scrollbar else w

        ### Draw
        stdscr.erase()

        for i, line in enumerate(header_lines):
            if i < h - 1:
                _addstr_ansi(stdscr, i, 0, line, content_w)

        for i in range(min(list_h, max(0, len(tab_lines) - scroll.offset))):
            line_idx = scroll.offset + i
            y = header_h + i
            sel = line_to_sel[line_idx] if line_idx < len(line_to_sel) else -1
            is_selected = sel == cursor and sel >= 0

            if is_selected:
                try:
                    stdscr.addstr(y, 0, " " * content_w, curses.A_REVERSE)
                except curses.error:
                    pass
                _addstr_ansi(
                    stdscr, y, 0, tab_lines[line_idx], content_w,
                    base_attr=curses.A_REVERSE,
                )
            else:
                _addstr_ansi(stdscr, y, 0, tab_lines[line_idx], content_w)

        if needs_scrollbar:
            _draw_scrollbar(stdscr, w - 1, header_h, list_h, scroll, scrollbar_attr)

        ### Tab indicators right-aligned on the title line (row 0)
        tab_segments = [
            (f"[{name}]" if i == active_tab else f" {name} ",
             curses.A_BOLD if i == active_tab else curses.A_DIM)
            for i, name in enumerate(TAB_NAMES)
        ]
        tab_total_w = sum(len(s) for s, _ in tab_segments) + 2 * (len(TAB_NAMES) - 1)
        col = max(0, w - tab_total_w - 1)
        for segment, attr in tab_segments:
            try:
                stdscr.addstr(0, col, segment, attr)
            except curses.error:
                pass
            col += len(segment) + 2

        ### Status bar
        if filter_active:
            status = f" Filter: {ft}\u2588"
        elif now < flash_until and flash_msg:
            status = f" {flash_msg}"
        else:
            age = int(now - last_fetch)
            age_str = f"{age}s ago" if age > 0 else "just now"
            timing_tag = " \u00b7 etas:on" if timing else ""
            filter_tag = f" \u00b7 filter:\"{ft}\"" if ft else ""
            sort_spec = JOB_SORT_SPEC if active_tab == 0 else SHARE_SORT_SPEC
            sm = sort_mode[active_tab]
            if sm != 0:
                arrow = "\u2191" if sort_ascending[active_tab] else "\u2193"
                sort_tag = f" \u00b7 sort:{sort_spec[sm].label.split()[0].lower()}{arrow}"
            else:
                sort_tag = ""
            pos_tag = f" \u00b7 {cursor + 1}/{len(selectable)}" if selectable else " \u00b7 0/0"
            status = (
                f" {scope}{pos_tag}{timing_tag}{filter_tag}{sort_tag} \u00b7 {age_str}"
                f" \u00b7 /:filter S:sort o:details ?:help"
            )
        try:
            padded = status[:w].ljust(w)
            stdscr.addstr(h - 1, 0, padded[:w - 1], curses.A_REVERSE)
        except curses.error:
            pass

        stdscr.refresh()

        ### Input handling
        stdscr.timeout(1000)
        key = stdscr.getch()

        ### ------- Filter input mode -------
        if filter_active:
            new_text, action = _handle_text_input(key, ft)
            if action == "cancel":
                filter_text[active_tab] = ""
                filter_active = False
                cursor_per_tab[active_tab] = 0
            elif action == "submit":
                filter_text[active_tab] = new_text
                filter_active = False
            else:
                filter_text[active_tab] = new_text
                cursor_per_tab[active_tab] = 0
            continue

        ### ------- Normal key handling -------
        if key == ord("q") or key == 27:
            break
        elif key == ord("?"):
            _draw_help_overlay(stdscr, h, w)
        elif key == ord("/"):
            filter_active = True
        elif key == ord("S"):
            picked = _show_sort_picker(stdscr, active_tab, sort_mode[active_tab], h, w)
            if picked is not None:
                if picked == sort_mode[active_tab] and picked != 0:
                    sort_ascending[active_tab] = not sort_ascending[active_tab]
                else:
                    sort_mode[active_tab] = picked
                    ### Numeric columns default to descending (biggest first)
                    if active_tab == 0:
                        sort_ascending[active_tab] = picked not in (4, 5)  # Time, Nodes
                    else:
                        sort_ascending[active_tab] = picked not in (2, 3)  # RawUsage, Nodes
                cursor_per_tab[active_tab] = 0
        elif key == ord("o") and selectable:
            sel_item = selectable[cursor]
            if active_tab == 0 and isinstance(sel_item, Job):
                _show_job_detail(stdscr, sel_item, h, w)
            elif active_tab == 1 and isinstance(sel_item, ShareEntry):
                _show_share_detail(
                    stdscr, sel_item, shares, items, h, w, user_nodes=user_nodes,
                )
        elif key == ord("l") and selectable and active_tab == 0:
            sel_item = selectable[cursor]
            if isinstance(sel_item, Job) and sel_item.state in ("R", "CG"):
                _show_job_log(stdscr, sel_item, h, w)
        elif key == ord("c") and selectable and active_tab == 0:
            sel_item = selectable[cursor]
            if isinstance(sel_item, Job):
                result = _show_cancel_confirm(stdscr, sel_item, h, w)
                if result:
                    _do_cancel(sel_item, result)
                    needs_refresh = True
        elif key == ord("h") and selectable and active_tab == 0:
            sel_item = selectable[cursor]
            if isinstance(sel_item, Job):
                if _job_action(stdscr, sel_item, "hold", "hold", h, w):
                    needs_refresh = True
        elif key == ord("u") and selectable and active_tab == 0:
            sel_item = selectable[cursor]
            if isinstance(sel_item, Job):
                if _job_action(stdscr, sel_item, "release", "release", h, w):
                    needs_refresh = True
        elif key == ord("e"):
            fmt = _show_export_picker(stdscr, h, w)
            if fmt:
                ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
                tab_name = "jobs" if active_tab == 0 else "shares"
                path = os.path.expanduser(f"~/sq_export_{tab_name}_{ts}.{fmt}")
                try:
                    if active_tab == 0:
                        _export_jobs(selectable, fmt, path)
                    else:
                        _export_shares(selectable, fmt, path)
                    flash_msg = f"Exported to {path}"
                    flash_until = time.time() + 5.0
                except OSError as exc:
                    flash_msg = f"Export failed: {exc}"
                    flash_until = time.time() + 5.0
        elif key == ord("n"):
            ### Context-sensitive: job's nodes if a running job is selected,
            ### otherwise show only problematic nodes across the cluster
            job_nodelist = ""
            node_title = ""
            if active_tab == 0 and selectable:
                sel_item = selectable[cursor]
                if isinstance(sel_item, Job) and sel_item.state in ("R", "CG"):
                    detail = _fetch_job_detail(sel_item.jobid)
                    job_nodelist = detail.get("NodeList", "")
                    node_title = f"Nodes: {sel_item.name} ({sel_item.jobid})"
            _show_node_details(stdscr, h, w, nodelist=job_nodelist, title=node_title)
        elif key == ord("\t"):
            active_tab = 1 - active_tab
        elif key == ord("r"):
            needs_refresh = True
        elif key == ord("m"):
            scope = "me"
            needs_refresh = True
        elif key == ord("a"):
            scope = "all"
            needs_refresh = True
        elif key == ord("g"):
            if scope != "group":
                scope = "group"
                needs_refresh = True
        elif key == ord("t"):
            timing = not timing
            needs_refresh = True
        elif key in (curses.KEY_UP, ord("k")):
            cursor_per_tab[active_tab] = max(0, cursor - 1)
        elif key in (curses.KEY_DOWN, ord("j")):
            cursor_per_tab[active_tab] = min(len(selectable) - 1, cursor + 1) if selectable else 0
        elif key == 5:  # Ctrl+E: scroll viewport down (cursor stays)
            scroll_per_tab[active_tab].scroll_down(1)
        elif key == 25:  # Ctrl+Y: scroll viewport up (cursor stays)
            scroll_per_tab[active_tab].scroll_up(1)
        elif key == 4 and selectable:  # Ctrl+D: half-page down
            cursor_per_tab[active_tab] = min(len(selectable) - 1, cursor + max(1, list_h // 2))
        elif key == 21 and selectable:  # Ctrl+U: half-page up
            cursor_per_tab[active_tab] = max(0, cursor - max(1, list_h // 2))
        elif key == curses.KEY_PPAGE:
            cursor_per_tab[active_tab] = max(0, cursor - list_h)
        elif key == curses.KEY_NPAGE:
            cursor_per_tab[active_tab] = min(len(selectable) - 1, cursor + list_h) if selectable else 0
        elif key == curses.KEY_HOME:
            cursor_per_tab[active_tab] = 0
        elif key == curses.KEY_END:
            cursor_per_tab[active_tab] = len(selectable) - 1 if selectable else 0
        elif key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, bstate = curses.getmouse()
            except curses.error:
                continue

            if bstate & curses.BUTTON4_PRESSED and selectable:
                cursor_per_tab[active_tab] = max(0, cursor - 3)
            elif bstate & _BUTTON5_PRESSED and selectable:
                cursor_per_tab[active_tab] = min(len(selectable) - 1, cursor + 3)
            elif bstate & (curses.BUTTON1_CLICKED | curses.BUTTON1_PRESSED):
                if header_h <= my < h - 1:
                    line_idx = scroll.offset + (my - header_h)
                    if 0 <= line_idx < len(line_to_sel):
                        clicked_sel = line_to_sel[line_idx]
                        if clicked_sel >= 0:
                            cursor_per_tab[active_tab] = clicked_sel
            elif bstate & curses.BUTTON1_DOUBLE_CLICKED and selectable:
                if header_h <= my < h - 1:
                    line_idx = scroll.offset + (my - header_h)
                    if 0 <= line_idx < len(line_to_sel):
                        clicked_sel = line_to_sel[line_idx]
                        if clicked_sel >= 0:
                            cursor_per_tab[active_tab] = clicked_sel
                            sel_item = selectable[clicked_sel]
                            if active_tab == 0 and isinstance(sel_item, Job):
                                _show_job_detail(stdscr, sel_item, h, w)
                            elif active_tab == 1 and isinstance(sel_item, ShareEntry):
                                _show_share_detail(
                                    stdscr, sel_item, shares, items, h, w,
                                    user_nodes=user_nodes,
                                )

        elif key == curses.KEY_RESIZE:
            pass


def run_tui(args: argparse.Namespace) -> None:
    """Entry point for TUI mode - wraps curses."""
    try:
        curses.wrapper(lambda stdscr: _run_tui(stdscr, args))
    except curses.error:
        print(
            "Cannot start TUI (no terminal available). "
            "Use --static for non-interactive output.",
            file=sys.stderr,
        )
        sys.exit(1)


###############################################################################
### CLI
###############################################################################


def main() -> None:
    global SLURM_GROUP

    parser = argparse.ArgumentParser(
        prog="wsq",
        description="Slurm queue monitor with TUI and static output modes.",
    )

    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument(
        "--static", "-1", action="store_true",
        help="One-shot print to stdout (default when invoked as 'sq')",
    )

    scope_group = parser.add_mutually_exclusive_group()
    scope_group.add_argument(
        "--me", "-m", action="store_const", const="me", dest="scope",
        help="Show only your jobs and shares",
    )
    scope_group.add_argument(
        "--all", "-a", action="store_const", const="all", dest="scope",
        help="Show all jobs and shares across the cluster",
    )
    parser.set_defaults(scope="group")

    parser.add_argument(
        "--running", "-r", action="store_true",
        help="Show only running jobs",
    )
    parser.add_argument(
        "--timing", "-t", action="store_true",
        help="Show estimated start time for pending Priority jobs",
    )
    parser.add_argument(
        "--interval", "-n", type=int, default=5,
        help="TUI refresh interval in seconds (default: 5)",
    )
    parser.add_argument(
        "--account", "-A", type=str, default="",
        help="Slurm account/group name (default: $SQ_ACCOUNT or coreai_modulus_cae)",
    )

    args = parser.parse_args()

    ### Resolve account: CLI > env > default
    SLURM_GROUP = (
        args.account
        or os.environ.get("SQ_ACCOUNT", "")
        or os.environ.get("SLURM_ACCOUNT", "")
        or "coreai_modulus_cae"
    )

    ### Auto-detect static mode when invoked as 'sq'
    if os.path.basename(sys.argv[0]) == "sq":
        args.static = True

    if args.static:
        run_static(args)
    else:
        run_tui(args)


if __name__ == "__main__":
    main()
