            lines.append(f"    {m.user:<20s}  {node_str}  {m.raw_usage:>12,} usage")
    else:
        ### User detail: show their jobs + account info
        title = f"{entry.user} @ {entry.account}"
        running = [j for j in items if j.user == entry.user and j.state == "R"]
        pending = [j for j in items if j.user == entry.user and j.state == "PD"]
        r_nodes = sum(j.nodes for j in running)
        p_nodes = sum(j.nodes for j in pending)

        sacctmgr_out = _run(
            ["sacctmgr", "show", "assoc", f"user={entry.user}", f"account={entry.account}",
             "format=Share,MaxJobs,MaxNodes,MaxSubmit,QOS%60", "--noheader", "--parsable2"],
            timeout=10,
        )
        qos = ""
        share_raw = ""
        for line in sacctmgr_out.strip().splitlines():
            parts = line.split("|")
            if len(parts) >= 5:
                share_raw = parts[0]
                qos = parts[4]

        lines = ["", f"  Account:     {entry.account}"]
        if share_raw:
            lines.append(f"  Share:       {share_raw}")
        lines.append(f"  RawUsage:    {entry.raw_usage:,}")
        lines.append(f"  EffectvUsage:{entry.effectv_usage:.6f}")
        if entry.level_fs is not None:
            lines.append(f"  LevelFS:     {entry.level_fs:.6f}")
        if qos:
            lines.append(f"  QOS:         {qos}")
        lines.append("")
        lines.append(f"  Running:     {r_nodes} nodes across {len(running)} jobs")
        lines.append(f"  Pending:     {len(pending)} jobs ({p_nodes} nodes requested)")

    lines.extend(["", "  j/k to scroll · q/Esc to close", ""])
    _draw_overlay_box(stdscr, lines, title, h, w)


